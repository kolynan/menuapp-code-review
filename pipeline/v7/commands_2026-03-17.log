$testDir = Join-Path $PWD 'pipeline/v7/test-output/finding-stream-smoke'; if (Test-Path -LiteralPath $testDir) { Remove-Item -LiteralPath $testDir -Recurse -Force }; New-Item -ItemType Directory -Path $testDir -Force | Out-Null; . (Join-Path $PWD 'pipeline/v7/scripts/V7.Common.ps1'); $path = Get-V7FindingStreamPath -ArtifactsDir $testDir -WorkerName 'codex-reviewer'; Add-V7FindingStreamEntry -Path $path -Worker 'codex-reviewer' -WorkerKey 'codex_reviewer' -Sequence 1 -Kind 'finding' -Summary 'First' -TaskId 'task-1'; Add-V7FindingStreamEntry -Path $path -Worker 'codex-reviewer' -WorkerKey 'codex_reviewer' -Sequence 2 -Kind 'finding' -Summary 'Second' -TaskId 'task-1'; $r1 = Read-V7FindingStreamEntries -Path $path -SkipLines 0; Add-V7FindingStreamEntry -Path $path -Worker 'codex-reviewer' -WorkerKey 'codex_reviewer' -Sequence 3 -Kind 'finding' -Summary 'Third' -TaskId 'task-1'; $r2 = Read-V7FindingStreamEntries -Path $path -SkipLines $r1.next_line; $payload = [pscustomobject]@{ findings = @([pscustomobject]@{ title='First'; severity='P1'; file='a.jsx'; line=10; description='x' }, [pscustomobject]@{ title='Second'; severity='P2'; file='b.jsx'; line=20; description='y' }, [pscustomobject]@{ title='Third'; severity='P3'; file='c.jsx'; line=30; description='z' }) }; Sync-V7ReviewFindingsToStream -Path $path -ReviewPayload $payload -TaskId 'task-1'; $r3 = Read-V7FindingStreamEntries -Path $path -SkipLines 0; Write-Output ('initial=' + @($r1.entries).Count + ' next1=' + $r1.next_line + ' incremental=' + @($r2.entries).Count + ' seq=' + $r2.entries[0].seq + ' total=' + @($r3.entries).Count)
