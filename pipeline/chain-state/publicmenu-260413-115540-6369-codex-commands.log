git fetch origin 2>$null; git reset --hard origin/main
if (Get-Process git -ErrorAction SilentlyContinue) { Get-Process git | Select-Object Id, ProcessName, Path | Format-Table -AutoSize } else { 'NO_GIT_PROCESS' }
if (Test-Path .git/index.lock) { Get-Item .git/index.lock | Select-Object FullName, Length, LastWriteTime | Format-List } else { 'NO_INDEX_LOCK' }
git fetch origin 2>$null; git reset --hard origin/main
Get-Content -Raw 'ux-concepts/HelpDrawer/260407-00 HelpDrawer UX S234 FINAL.md'
$lines = Get-Content 'references/Monetization_Ads_Model.md'; $start = ($lines | Select-String '^## 8\\.1\\b').LineNumber; $next = ($lines | Select-String '^## ' | Where-Object { $_.LineNumber -gt $start } | Select-Object -First 1).LineNumber; if (-not $next) { $next = $lines.Length + 1 }; $lines[($start-1)..($next-2)] -join "`n"; "`n`n--- SECTION 12 ---`n"; $start12 = ($lines | Select-String '^## 12\\b').LineNumber; $next12 = ($lines | Select-String '^## ' | Where-Object { $_.LineNumber -gt $start12 } | Select-Object -First 1).LineNumber; if (-not $next12) { $next12 = $lines.Length + 1 }; $lines[($start12-1)..($next12-2)] -join "`n"
$lines = Get-Content 'DECISIONS_INDEX.md'; $start = ($lines | Select-String '^## 9\\b').LineNumber; $next = ($lines | Select-String '^## ' | Where-Object { $_.LineNumber -gt $start } | Select-Object -First 1).LineNumber; if (-not $next) { $next = $lines.Length + 1 }; $lines[($start-1)..($next-2)] -join "`n"
$lines = Get-Content 'BACKLOG.md'; $match180 = $lines | Select-String '^#180\\b|^## #180\\b|^### #180\\b|^- \\*\\*#180\\*\\*|^- #180\\b'; $match181 = $lines | Select-String '^#181\\b|^## #181\\b|^### #181\\b|^- \\*\\*#181\\*\\*|^- #181\\b'; if ($match180) { $start180 = $match180.LineNumber[0]; $next180 = ($lines | Select-String '^(#|##|###|- \\*\\*#|\\- #)\\d+' | Where-Object { $_.LineNumber -gt $start180 } | Select-Object -First 1).LineNumber; if (-not $next180) { $next180 = $lines.Length + 1 }; "#180`n" + ($lines[($start180-1)..($next180-2)] -join "`n") }; "`n`n---`n`n"; if ($match181) { $start181 = $match181.LineNumber[0]; $next181 = ($lines | Select-String '^(#|##|###|- \\*\\*#|\\- #)\\d+' | Where-Object { $_.LineNumber -gt $start181 } | Select-Object -First 1).LineNumber; if (-not $next181) { $next181 = $lines.Length + 1 }; "#181`n" + ($lines[($start181-1)..($next181-2)] -join "`n") }
Get-ChildItem -Name
if (Test-Path 'ux-concepts') { Get-ChildItem 'ux-concepts' -Name } else { 'NO_UX_CONCEPTS_DIR' }
if (Test-Path 'references') { Get-ChildItem 'references' -Name } else { 'NO_REFERENCES_DIR' }
if (Test-Path 'pipeline') { Get-ChildItem 'pipeline' -Name } else { 'NO_PIPELINE_DIR' }
Get-ChildItem 'menuapp-code-review' -Name
if (Test-Path 'menuapp-code-review/ux-concepts') { Get-ChildItem 'menuapp-code-review/ux-concepts' -Name } else { 'NO_NESTED_UX_CONCEPTS_DIR' }
if (Test-Path 'menuapp-code-review/references') { Get-ChildItem 'menuapp-code-review/references' -Name } else { 'NO_NESTED_REFERENCES_DIR' }
Get-ChildItem 'menuapp-code-review' -File -Name
rg --files -g '260407-00 HelpDrawer UX S234 FINAL.md' -g 'Monetization_Ads_Model.md' -g 'DECISIONS_INDEX.md' -g 'BACKLOG.md'
