git fetch origin 2>$null; git reset --hard origin/main
Get-ChildItem -Name scripts
Get-Item scripts/README.md, scripts/BUGS.md, KNOWLEDGE_BASE_VSC.md, CLAUDE.md, scripts/task-watcher-multi.py, scripts/task-watcher-v3.py | Select-Object FullName,Length,LastWriteTime
Get-Item README.md, BUGS.md, pipeline, pipeline/chain-state, scripts/task-watcher-v3-legacy.py | Select-Object FullName,Length,LastWriteTime
Get-ChildItem -Name
Get-Content README.md
Get-Content CLAUDE.md
Get-Content scripts/task-watcher-v3-legacy.py -TotalCount 120
$i=0; Get-Content CLAUDE.md | ForEach-Object { $i++; '{0,4}: {1}' -f $i, $_ } | Select-Object -First 120
$i=0; Get-Content scripts/task-watcher-v3-legacy.py | ForEach-Object { $i++; '{0,4}: {1}' -f $i, $_ } | Select-Object -First 80
@('scripts/task-watcher-multi.py','scripts/task-watcher-v3.py','KNOWLEDGE_BASE_VSC.md','BUGS.md') | ForEach-Object { '{0}: {1}' -f $_, (Test-Path $_) }
Select-String -Path CLAUDE.md -Pattern 'multi|task-watcher-v3|task-watcher-multi|MULTI' -CaseSensitive:$false | ForEach-Object { '{0}: {1}' -f $_.LineNumber, $_.Line }
$i=0; Get-Content README.md | ForEach-Object { $i++; '{0,4}: {1}' -f $i, $_ }
