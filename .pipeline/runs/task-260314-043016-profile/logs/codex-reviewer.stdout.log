te();\r\n  34:   const { t } = useI18n();\r\n  35: \r\n  36:   // Safe translation with fallback (t() returns key when missing)\r\n  37:   const tr = (key, fallback) => {\r\n  38:     const val = typeof t === \"function\" ? t(key) : \"\";\r\n  39:     if (!val || typeof val !== \"string\") return fallback;\r\n  40:     const norm = val.trim();\r\n  41:     if (norm === key || norm.startsWith(key + \":\")) return fallback;\r\n  42:     return norm;\r\n  43:   };\r\n  44: \r\n  45:   const [user, setUser] = useState(null);\r\n  46:   const [partnerName, setPartnerName] = useState(null);\r\n  47:   const [fullName, setFullName] = useState(\"\");\r\n  48:   const [initialFullName, setInitialFullName] = useState(\"\");\r\n  49:   const [isUserLoading, setIsUserLoading] = useState(true);\r\n  50:   const [isLoadError, setIsLoadError] = useState(false);\r\n  51:   const [isPartnerLoading, setIsPartnerLoading] = useState(false);\r\n  52:   const [saveStatus, setSaveStatus] = useState(\"idle\"); // idle | saving | success\r\n  53:   const timerRef = useRef(null);\r\n  54:   const isMountedRef = useRef(true);\r\n  55: \r\n  56:   // Cleanup timer on unmount\r\n  57:   useEffect(() => {\r\n  58:     return () => {\r\n  59:       isMountedRef.current = false;\r\n  60:       if (timerRef.current) clearTimeout(timerRef.current);\r\n  61:     };\r\n  62:   }, []);\r\n  63: \r\n  64:   // ============================================================\r\n  65:   // BLOCK 02 ├óΓé¼ΓÇ¥ DATA LOADING\r\n  66:   // ============================================================\r\n  67: \r\n  68:   useEffect(() => {\r\n  69:     let isMounted = true;\r\n  70:     const loadUser = async () => {\r\n  71:       try {\r\n  72:         const userData = await base44.auth.me();\r\n  73:         if (!isMounted) return;\r\n  74:         setUser(userData);\r\n  75:         setFullName((userData.full_name || \"\").trim());\r\n  76:         setInitialFullName((userData.full_name || \"\").trim());\r\n  77: \r\n  78:         if (isMounted) setIsUserLoading(false);\r\n  79: \r\n  80:         // Load partner name if exists\r\n  81:         if (userData.partner && userData.partner !== GLOBAL_ADMIN_PARTNER) {\r\n  82:           if (isMounted) setIsPartnerLoading(true);\r\n  83:           try {\r\n  84:             const partner = await base44.entities.Partner.get(userData.partner);\r\n  85:             if (isMounted && partner) {\r\n  86:               setPartnerName(partner.name);\r\n  87:             }\r\n  88:           } catch (err) {\r\n  89:             // Partner load failed ├óΓé¼ΓÇ¥ user sees \"├É┬¥├É┬╡ ├É┬┐├æΓé¼├É┬╕├É┬▓├æ┬Å├É┬╖├É┬░├É┬╜\"\r\n  90:           } finally {\r\n  91:             if (isMounted) setIsPartnerLoading(false);\r\n  92:           }\r\n  93:         }\r\n  94:       } catch (error) {\r\n  95:         if (!isMounted) return;\r\n  96:         setIsLoadError(true);\r\n  97:         setIsUserLoading(false);\r\n  98:       }\r\n  99:     };\r\n 100: \r\n 101:     loadUser();\r\n 102:     return () => { isMounted = false; };\r\n 103:   }, []); // eslint-disable-line react-hooks/exhaustive-deps\r\n 104: \r\n 105:   // ============================================================\r\n 106:   // BLOCK 03 ├óΓé¼ΓÇ¥ HANDLERS\r\n 107:   // ============================================================\r\n 108: \r\n 109:   const hasChanges = fullName.trim() !== initialFullName;\r\n 110:   const canSave = hasChanges && fullName.trim().length > 0;\r\n 111: \r\n 112:   const handleSave = async () => {\r\n 113:     if (!canSave || saveStatus === \"saving\") return;\r\n 114: \r\n 115:     setSaveStatus(\"saving\");\r\n 116:     try {\r\n 117:       await base44.auth.updateMe({ full_name: fullName.trim() });\r\n 118:       if (!isMountedRef.current) return;\r\n 119:       setInitialFullName(fullName.trim());\r\n 120:       setSaveStatus(\"success\");\r\n 121:       toast.success(tr(\"toast.saved\", \"├É┬í├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├É┬╡├É┬╜├É┬╛\"), { id: \"mm1\" });\r\n 122: \r\n 123:       timerRef.current = setTimeout(() => {\r\n 124:         if (isMountedRef.current) setSaveStatus(\"idle\");\r\n 125:       }, 2000);\r\n 126:     } catch (error) {\r\n 127:       if (!isMountedRef.current) return;\r\n 128:       toast.error(tr(\"toast.error\", \"├É┼╛├æ╦å├É┬╕├É┬▒├É┬║├É┬░\"), { id: \"mm1\" });\r\n 129:       setSaveStatus(\"idle\");\r\n 130:     }\r\n 131:   };\r\n 132: \r\n 133:   const getRoleLabel = (userRole) => {\r\n 134:     return tr(`profile.role.${userRole}`, userRole);\r\n 135:   };\r\n 136: \r\n 137:   const getRoleBadgeClass = (userRole) => {\r\n 138:     return ROLE_BADGE_CLASSES[userRole] || \"bg-gray-100 text-gray-800\";\r\n 139:   };\r\n 140: \r\n 141:   // ============================================================\r\n 142:   // BLOCK 04 ├óΓé¼ΓÇ¥ LOADING STATE\r\n 143:   // ============================================================\r\n 144: \r\n 145:   if (isUserLoading) {\r\n 146:     return (\r\n 147:       <div className=\"min-h-screen bg-gray-50 flex items-center justify-center\">\r\n 148:         <div className=\"flex items-center gap-2 text-gray-500\" role=\"status\" aria-live=\"polite\">\r\n 149:           <Loader2 className=\"w-5 h-5 animate-spin\" />\r\n 150:           <span>{tr(\"common.loading\", \"├ÉΓÇö├É┬░├É┬│├æΓé¼├æ╞Æ├É┬╖├É┬║├É┬░...\")}</span>\r\n 151:         </div>\r\n 152:       </div>\r\n 153:     );\r\n 154:   }\r\n 155: \r\n 156:   if (isLoadError) {\r\n 157:     return (\r\n 158:       <div className=\"min-h-screen bg-gray-50 flex flex-col items-center justify-center gap-4 p-4\">\r\n 159:         <AlertCircle className=\"w-10 h-10 text-red-400\" />\r\n 160:         <p className=\"text-gray-600 text-center\">{tr(\"profile.load_error\", \"├É┬¥├É┬╡ ├æ╞Æ├É┬┤├É┬░├É┬╗├É┬╛├æ┬ü├æ┼Æ ├É┬╖├É┬░├É┬│├æΓé¼├æ╞Æ├É┬╖├É┬╕├æΓÇÜ├æ┼Æ ├É┬┐├æΓé¼├É┬╛├æΓÇ₧├É┬╕├É┬╗├æ┼Æ\")}</p>\r\n 161:         <Button\r\n 162:           variant=\"outline\"\r\n 163:           onClick={() => navigate(BACK_ROUTE)}\r\n 164:           className=\"min-h-[44px] min-w-[44px]\"\r\n 165:         >\r\n 166:           <ArrowLeft className=\"w-4 h-4 mr-2\" />\r\n 167:           {tr(\"common.back\", \"├É┬¥├É┬░├É┬╖├É┬░├É┬┤\")}\r\n 168:         </Button>\r\n 169:       </div>\r\n 170:     );\r\n 171:   }\r\n 172: \r\n 173:   // ============================================================\r\n 174:   // BLOCK 05 ├óΓé¼ΓÇ¥ SAVE BUTTON CONTENT\r\n 175:   // ============================================================\r\n 176: \r\n 177:   const getSaveButtonContent = () => {\r\n 178:     if (saveStatus === \"saving\") {\r\n 179:       return (\r\n 180:         <>\r\n 181:           <Loader2 className=\"w-4 h-4 animate-spin mr-2\" />\r\n 182:           {tr(\"common.saving\", \"├É┬í├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├É┬╡├É┬╜├É┬╕├É┬╡...\")}\r\n 183:         </>\r\n 184:       );\r\n 185:     }\r\n 186:     if (saveStatus === \"success\") {\r\n 187:       return (\r\n 188:         <>\r\n 189:           <Check className=\"w-4 h-4 mr-2\" />\r\n 190:           {tr(\"common.saved\", \"├É┬í├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├É┬╡├É┬╜├É┬╛\")}\r\n 191:         </>\r\n 192:       );\r\n 193:     }\r\n 194:     return tr(\"common.save\", \"├É┬í├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├É┬╕├æΓÇÜ├æ┼Æ\");\r\n 195:   };\r\n 196: \r\n 197:   // ============================================================\r\n 198:   // BLOCK 06 ├óΓé¼ΓÇ¥ RENDER\r\n 199:   // ============================================================\r\n 200: \r\n 201:   const restaurantDisplay = partnerName || tr(\"profile.no_restaurant\", \"├É┬¥├É┬╡ ├É┬┐├æΓé¼├É┬╕├É┬▓├æ┬Å├É┬╖├É┬░├É┬╜\");\r\n 202: \r\n 203:   return (\r\n 204:     <div className=\"min-h-screen bg-gray-50\">\r\n 205:       {/* Header */}\r\n 206:       <div className=\"bg-white border-b px-4 py-3\">\r\n 207:         <Button\r\n 208:           variant=\"ghost\"\r\n 209:           size=\"sm\"\r\n 210:           onClick={() => navigate(BACK_ROUTE)}\r\n 211:           className=\"flex items-center gap-1 -ml-2 min-h-[44px]\"\r\n 212:         >\r\n 213:           <ArrowLeft className=\"w-4 h-4\" />\r\n 214:           {tr(\"common.back\", \"├É┬¥├É┬░├É┬╖├É┬░├É┬┤\")}\r\n 215:         </Button>\r\n 216:       </div>\r\n 217: \r\n 218:       {/* Content */}\r\n 219:       <div className=\"p-4 max-w-lg mx-auto\">\r\n 220:         <Card>\r\n 221:           <CardHeader>\r\n 222:             <CardTitle>{tr(\"profile.title\", \"├É┼╕├æΓé¼├É┬╛├æΓÇ₧├É┬╕├É┬╗├æ┼Æ\")}</CardTitle>\r\n 223:           </CardHeader>\r\n 224:           <CardContent>\r\n 225:             <form className=\"space-y-4\" onSubmit={(e) => { e.preventDefault(); handleSave(); }}>\r\n 226:             {/* Full Name - editable */}\r\n 227:             <div className=\"space-y-2\">\r\n 228:               <Label htmlFor=\"fullName\">{tr(\"profile.full_name\", \"├É┼╕├É┬╛├É┬╗├É┬╜├É┬╛├É┬╡ ├É┬╕├É┬╝├æ┬Å\")}</Label>\r\n 229:               <Input\r\n 230:                 id=\"fullName\"\r\n 231:                 value={fullName}\r\n 232:                 onChange={(e) => setFullName(e.target.value)}\r\n 233:               />\r\n 234:             </div>\r\n 235: \r\n 236:             {/* Email - readonly */}\r\n 237:             <div className=\"space-y-2\">\r\n 238:               <Label htmlFor=\"email\">{tr(\"profile.email\", \"Email\")}</Label>\r\n 239:               <Input\r\n 240:                 id=\"email\"\r\n 241:                 value={user?.email || \"\"}\r\n 242:                 readOnly\r\n 243:                 className=\"bg-gray-50 text-gray-600\"\r\n 244:               />\r\n 245:             </div>\r\n 246: \r\n 247:             {/* Role - badge */}\r\n 248:             <div className=\"space-y-2\">\r\n 249:               <p className=\"text-sm font-medium\">{tr(\"profile.role\", \"├É┬á├É┬╛├É┬╗├æ┼Æ\")}</p>\r\n 250:               <div>\r\n 251:                 <span\r\n 252:                   className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${getRoleBadgeClass(user?.user_role)}`}\r\n 253:                 >\r\n 254:              