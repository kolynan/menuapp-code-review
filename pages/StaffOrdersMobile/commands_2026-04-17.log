function Show-Range($path, $start, $end, $label) {
  Write-Output "=== $label ($start-$end) ==="
  $i = 0
  [System.IO.File]::ReadLines($path) | ForEach-Object {
    $i++
    if ($i -ge $start -and $i -le $end) { '{0,5}: {1}' -f $i, $_ }
    elseif ($i -gt $end) { break }
  }
}
