{"type":"item.completed","item":{"id":"item_1","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command \"Get-Content -Raw 'C:\\\\Dev\\\\menuapp-code-review\\\\.pipeline\\\\runs\\\\task-260316-221319-publicmenu\\\\prompts\\\\codex-reviewer.bundle.md'\"","aggregated_output":"# Review Bundle\n\n## Target Code: CartView.jsx\n```\nimport React from \"react\";\nimport { XIcon, Loader2, ChevronDown, ChevronUp, Users, Gift, ShoppingBag, Bell, X } from \"lucide-react\";\nimport { Card, CardContent } from \"@/components/ui/card\";\nimport { Button } from \"@/components/ui/button\";\nimport { Input } from \"@/components/ui/input\";\nimport Rating from \"@/components/Rating\";\n\nexport default function CartView({\n  partner,\n  currentTable,\n  currentGuest,\n  t,\n  setView,\n  isEditingName,\n  guestNameInput,\n  setGuestNameInput,\n  handleUpdateGuestName,\n  setIsEditingName,\n  getGuestDisplayName,\n  cart,\n  formatPrice,\n  updateQuantity,\n  sessionGuests,\n  splitType,\n  setSplitType,\n  showLoginPromptAfterRating,\n  customerEmail,\n  setCustomerEmail,\n  loyaltyLoading,\n  loyaltyAccount,\n  earnedPoints,\n  maxRedeemPoints,\n  redeemedPoints,\n  setRedeemedPoints,\n  toast,\n  cartTotalAmount,\n  discountAmount,\n  pointsDiscountAmount,\n  isSubmitting,\n  submitError,\n  setSubmitError,\n  handleSubmitOrder,\n  myOrders,\n  itemsByOrder,\n  getOrderStatus,\n  reviewedItems,\n  draftRatings,\n  updateDraftRating,\n  sessionItems,\n  sessionOrders,\n  myBill,\n  reviewableItems,\n  openReviewDialog,\n  setOtherGuestsExpanded,\n  otherGuestsExpanded,\n  getLinkId,\n  otherGuestsReviewableItems,\n  tableTotal,\n  formatOrderTime,\n  handleRateDish,\n  ratingSavingByItemId,\n  // TASK-260203-01 P0: Drawer props\n  onClose,\n  onCallWaiter,\n  isTableVerified,\n  tableCodeInput,\n  setTableCodeInput,\n  isVerifyingCode,\n  verifyTableCode,\n  codeVerificationError,\n  hallGuestCodeEnabled,\n  guestCode,\n}) {\n  // ===== P0: Safe prop defaults (BUG-PM-023, BUG-PM-025) =====\n  const safeReviewedItems = reviewedItems || new Set();\n  const safeDraftRatings = draftRatings || {};\n\n  // ===== P1 Expandable States =====\n  const [splitExpanded, setSplitExpanded] = React.useState(false);\n  const [loyaltyExpanded, setLoyaltyExpanded] = React.useState(false);\n  const [myOrdersExpanded, setMyOrdersExpanded] = React.useState(true); // default open\n  const [showRewardEmailForm, setShowRewardEmailForm] = React.useState(false);\n  const [rewardEmail, setRewardEmail] = React.useState('');\n  const [rewardEmailSubmitting, setRewardEmailSubmitting] = React.useState(false);\n\n  // ===== P0: Table-code verification UX (mask + auto-verify + cooldown) =====\n  const [infoModal, setInfoModal] = React.useState(null); // 'online' | 'tableCode' | null\n  const [codeAttempts, setCodeAttempts] = React.useState(0);\n  const [codeLockedUntil, setCodeLockedUntil] = React.useState(null); // timestamp ms\n  const [nowTs, setNowTs] = React.useState(() => Date.now());\n\n  const codeInputRef = React.useRef(null);\n  const lastVerifyCodeRef = React.useRef(null);\n  const countedErrorForCodeRef = React.useRef(null);\n  const lastSentVerifyCodeRef = React.useRef(null);\n\n  // Partner-configurable settings (fallbacks until Base44 adds real fields)\n  const tableCodeLength = React.useMemo(() => {\n    const n = Number(partner?.table_code_length);\n    if (Number.isFinite(n) && n > 0) return Math.max(3, Math.min(8, Math.round(n)));\n    return 5;\n  }, [partner?.table_code_length]);\n\n  const maxCodeAttempts = React.useMemo(() => {\n    const n = Number(partner?.table_code_max_attempts);\n    if (Number.isFinite(n) && n > 0) return Math.max(1, Math.min(10, Math.round(n)));\n    return 3;\n  }, [partner?.table_code_max_attempts]);\n\n  const codeCooldownSeconds = React.useMemo(() => {\n    const n = Number(partner?.table_code_cooldown_seconds);\n    if (Number.isFinite(n) && n >= 0) return Math.max(0, Math.min(600, Math.round(n)));\n    return 60;\n  }, [partner?.table_code_cooldown_seconds]);\n\n  const isCodeLocked = Boolean(codeLockedUntil && nowTs < codeLockedUntil);\n  const codeSecondsLeft = isCodeLocked ? Math.max(0, Math.ceil((codeLockedUntil - nowTs) / 1000)) : 0;\n\n  // Tick timer only while locked\n  React.useEffect(() => {\n    if (!isCodeLocked) return;\n    if (typeof window === \"undefined\") return;\n    const id = window.setInterval(() => setNowTs(Date.now()), 250);\n    return () => window.clearInterval(id);\n  }, [isCodeLocked]);\n\n  // Auto-unlock when time passes\n  React.useEffect(() => {\n    if (!codeLockedUntil) return;\n    if (nowTs < codeLockedUntil) return;\n    setCodeLockedUntil(null);\n    setCodeAttempts(0);\n  }, [nowTs, codeLockedUntil]);\n\n  // Reset attempts on successful verification\n  React.useEffect(() => {\n    if (isTableVerified === true) {\n      setCodeAttempts(0);\n      setCodeLockedUntil(null);\n    }\n  }, [isTableVerified]);\n\n  // Count failed attempts (UI-level), and apply cooldown after max attempts.\n  React.useEffect(() => {\n    if (!codeVerificationError) return;\n    if (isVerifyingCode) return;\n    const lastCode = lastVerifyCodeRef.current;\n    if (!lastCode) return;\n\n    // Count once per verified code\n    if (countedErrorForCodeRef.current === lastCode) return;\n    countedErrorForCodeRef.current = lastCode;\n\n    setCodeAttempts((prev) => {\n      const next = prev + 1;\n      if (maxCodeAttempts > 0 && next >= maxCodeAttempts) {\n        if (codeCooldownSeconds > 0) {\n          setCodeLockedUntil(Date.now() + codeCooldownSeconds * 1000);\n        }\n        return maxCodeAttempts;\n      }\n      return next;\n    });\n  }, [codeVerificationError, isVerifyingCode, maxCodeAttempts, codeCooldownSeconds]);\n\n  // Auto-verify when code is fully entered (debounced)\n  React.useEffect(() => {\n    if (typeof verifyTableCode !== \"function\") return;\n    if (isTableVerified === true) return;\n    if (isCodeLocked) return;\n\n    const safe = String(tableCodeInput || \"\").replace(/\\D/g, \"\").slice(0, tableCodeLength);\n    if (safe.length !== tableCodeLength) return;\n    if (safe === String(lastSentVerifyCodeRef.current || \"\")) return;\n\n    const id = setTimeout(() => {\n      if (typeof verifyTableCode !== \"function\") return;\n      if (isTableVerified === true) return;\n      if (isVerifyingCode) return;\n      if (codeLockedUntil && Date.now() < codeLockedUntil) return;\n\n      const codeToVerify = String(safe);\n      if (codeToVerify.length !== tableCodeLength) return;\n      if (codeToVerify === String(lastSentVerifyCodeRef.current || \"\")) return;\n\n      lastSentVerifyCodeRef.current = codeToVerify;\n      lastVerifyCodeRef.current = codeToVerify;\n      countedErrorForCodeRef.current = null;\n\n      verifyTableCode(codeToVerify);\n    }, 250);\n\n    return () => clearTimeout(id);\n  }, [\n    tableCodeInput,\n    tableCodeLength,\n    verifyTableCode,\n    isTableVerified,\n    isVerifyingCode,\n    isCodeLocked,\n    codeLockedUntil,\n  ]);\n\n\n  // ===== P0 UX helpers =====\n\n  // Safe translation with fallback\n  const tr = (key, fallback) => {\n    const val = typeof t === \"function\" ? t(key) : \"\";\n    if (!val || typeof val !== \"string\") return fallback;\n    const norm = val.trim();\n    if (norm === key || norm.startsWith(key + \":\")) return fallback;\n    return norm;\n  };\n\n  // Translation with params\n  const trFormat = (key, params, fallback) => {\n    const val = typeof t === \"function\" ? t(key, params) : \"\";\n    if (!val || typeof val !== \"string\") return fallback;\n    const norm = val.trim();\n    if (norm === key || norm.startsWith(key)) return fallback;\n    return norm;\n  };\n\n  // Safe status label - prevents showing raw translation keys like \"orderprocess.default.new\"\n  const getSafeStatus = (status) => {\n    if (!status) {\n      return { icon: '├░┼╕ΓÇ¥┬╡', label: tr('status.new', '├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖├É┬░├É┬╜├É┬╛'), color: '#3B82F6' };\n    }\n\n    let label = status.label || '';\n\n    // Check if label is a raw translation key (contains dots and looks like a key)\n    if (label.includes('.') && (label.startsWith('orderprocess') || label.startsWith('status'))) {\n      // Extract code from key like \"orderprocess.default.new\" ├óΓÇáΓÇÖ \"new\"\n      const parts = label.split('.');\n      const code = parts[parts.length - 1];\n\n      // Use human-readable fallbacks based on code\n      const fallbacks = {\n        'new': tr('status.new', '├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖├É┬░├É┬╜├É┬╛'),\n        'start': tr('status.cooking', '├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╕├æΓÇÜ├æ┬ü├æ┬Å'),\n        'cook': tr('status.cooking', '├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╕├æΓÇÜ├æ┬ü├æ┬Å'),\n        'cooking': tr('status.cooking', '├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╕├æΓÇÜ├æ┬ü├æ┬Å'),\n        'finish': tr('status.ready', '├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╛'),\n        'ready': tr('status.ready', '├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╛'),\n        'done': tr('status.ready', '├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╛'),\n        'cancel': tr('status.cancelled', '├É┼╛├æΓÇÜ├É┬╝├É┬╡├É┬╜├æΓÇÿ├É┬╜'),\n        'cancelled': tr('status.cancelled', '├É┼╛├æΓÇÜ├É┬╝├É┬╡├É┬╜├æΓÇÿ├É┬╜'),\n      };\n\n      label = fallbacks[code] || tr('status.new', '├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖├É┬░├É┬╜├É┬╛');\n    }\n\n    return {\n      icon: status.icon || '├░┼╕ΓÇ¥┬╡',\n      label: label,\n      color: status.color || '#3B82F6'\n    };\n  };\n\n  // Guest code from localStorage (e.g., \"#6475\")\n  const guestCodeFromStorage = React.useMemo(() => {\n    if (typeof window === \"undefined\") return null;\n    try {\n      const raw = window.localStorage.getItem(\"menu_guest_code\");\n      return raw ? String(raw).trim() : null;\n    } catch {\n      return null;\n    }\n  }, []);\n\n  // Effective guest code: prop takes priority, fallback to localStorage\n  const effectiveGuestCode = guestCode || guestCodeFromStorage;\n\n  // Guest display: \"├É╦£├É┬╝├æ┬Å #6475\" or \"├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ #6475\"\n  const guestBaseName = currentGuest\n    ? (currentGuest.name || getGuestDisplayName(currentGuest))\n    : tr(\"cart.guest\", \"├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ\");\n\n  const guestDisplay = effectiveGuestCode \n    ? `${guestBaseName} #${effectiveGuestCode}` \n    : guestBaseName;\n\n  // Table label: avoid \"├É┬í├æΓÇÜ├É┬╛├É┬╗ ├É┬í├æΓÇÜ├É┬╛├É┬╗ 3\"\n  const tablePrefix = tr(\"form.table\", \"├É┬í├æΓÇÜ├É┬╛├É┬╗\");\n  const rawTableLabel = currentTable?.name || currentTable?.code || \"├óΓé¼ΓÇ¥\";\n  const tableLabel = React.useMemo(() => {\n    if (typeof rawTableLabel !== \"string\" || typeof tablePrefix !== \"string\") {\n      return `${tablePrefix} ${rawTableLabel}`;\n    }\n    if (rawTableLabel.trim().toLowerCase().startsWith(tablePrefix.trim().toLowerCase())) {\n      return rawTableLabel;\n    }\n    return `${tablePrefix} ${rawTableLabel}`;\n  }, [rawTableLabel, tablePrefix]);\n\n  // Cart grand total (after discounts)\n  const cartGrandTotal = Math.max(\n    0,\n    (Number(cartTotalAmount) || 0) - (Number(discountAmount) || 0) - (Number(pointsDiscountAmount) || 0)\n  );\n\n  // ===== Guest count (stable, from orders OR guests) =====\n  const guestCountFromOrders = React.useMemo(() => {\n    try {\n      const ids = new Set(\n        (sessionOrders || [])\n          .map(o => (getLinkId ? getLinkId(o.guest) : o.guest))\n          .filter(Boolean)\n          .map(x => String(x))\n      );\n      return ids.size;\n    } catch {\n      return 0;\n    }\n  }, [sessionOrders, getLinkId]);\n\n  const guestCount = Math.max(\n    Array.isArray(sessionGuests) ? sessionGuests.length : 0,\n    guestCountFromOrders,\n    1\n  );\n  const canSplit = guestCount > 1;\n\n  // ===== Table Orders from sessionOrders =====\n  const ordersByGuestId = React.useMemo(() => {\n    const map = new Map();\n    (sessionOrders || []).forEach((o) => {\n      const gid = getLinkId ? getLinkId(o.guest) : o.guest;\n      if (!gid) return;\n      const k = String(gid);\n      if (!map.has(k)) map.set(k, []);\n      map.get(k).push(o);\n    });\n    return map;\n  }, [sessionOrders, getLinkId]);\n\n  const myGuestId = currentGuest?.id ? String(currentGuest.id) : null;\n\n  const otherGuestIdsFromOrders = React.useMemo(() => {\n    return Array.from(ordersByGuestId.keys()).filter((gid) => !myGuestId || gid !== myGuestId);\n  }, [ordersByGuestId, myGuestId]);\n\n  const tableOrdersTotal = React.useMemo(() => {\n    let sum = 0;\n    otherGuestIdsFromOrders.forEach((gid) => {\n      const orders = ordersByGuestId.get(gid) || [];\n      orders.forEach((o) => {\n        sum += Number(o.total_amount) || 0;\n      });\n    });\n    return sum;\n  }, [ordersByGuestId, otherGuestIdsFromOrders]);\n\n  const getGuestLabelById = (guestId) => {\n    const gid = String(guestId);\n    const found = (sessionGuests || []).find((g) => String(g.id) === gid);\n    if (found) return getGuestDisplayName(found);\n    const suffix = gid.length >= 4 ? gid.slice(-4) : gid;\n    return `${tr(\"cart.guest\", \"├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ\")} ${suffix}`;\n  };\n\n  const showTableOrdersSection = otherGuestIdsFromOrders.length > 0;\n\n  // ===== Review Reward Flow (P1) =====\n  const reviewRewardPoints = Number(partner?.loyalty_review_points || 0);\n  const isReviewRewardActive = Number.isFinite(reviewRewardPoints) && reviewRewardPoints > 0;\n\n  // ├ÉΓÇö├É┬▓├æΓÇÿ├É┬╖├É┬┤├æΓÇ╣ ├É┬┐├É┬╛├É┬║├É┬░├É┬╖├æΓÇ╣├É┬▓├É┬░├É┬╡├É┬╝ ├É┬╡├æ┬ü├É┬╗├É┬╕: show_dish_reviews ├É╦£├ÉΓÇ║├É╦£ ├É┬╡├æ┬ü├æΓÇÜ├æ┼Æ ├É┬╜├É┬░├É┬│├æΓé¼├É┬░├É┬┤├É┬░ ├É┬╖├É┬░ ├É┬╛├æΓÇÜ├É┬╖├æΓÇ╣├É┬▓\n  const reviewsEnabled = Boolean(partner?.show_dish_reviews || isReviewRewardActive);\n\n  // ├ÉΓÇó├æ┬ü├æΓÇÜ├æ┼Æ ├É┬╗├É┬╕ ├æΓÇª├É┬╛├æΓÇÜ├æ┼Æ ├É┬╛├É┬┤├É┬╜├É┬░ ├É┬╛├æΓÇá├É┬╡├É┬╜├É┬║├É┬░ (draft ├É┬╕├É┬╗├É┬╕ ├æ┬ü├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├æΓÇÿ├É┬╜├É┬╜├É┬░├æ┬Å)\n  const hasAnyRating = React.useMemo(() => {\n    const reviewedCount = safeReviewedItems.size ? Number(safeReviewedItems.size) : 0;\n    const draftCount = safeDraftRatings ? Object.values(safeDraftRatings).filter(v => Number(v) > 0).length : 0;\n    return reviewedCount > 0 || draftCount > 0;\n  }, [reviewedItems, draftRatings]);\n\n  // ├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ ├É┬╕├É┬┤├É┬╡├É┬╜├æΓÇÜ├É┬╕├æΓÇ₧├É┬╕├æΓÇá├É┬╕├æΓé¼├É┬╛├É┬▓├É┬░├É┬╜?\n  const isCustomerIdentified = Boolean(\n    loyaltyAccount?.id || loyaltyAccount?._id || loyaltyAccount?.email || (customerEmail && String(customerEmail).trim())\n  );\n\n  // ├É┼╕├É┬╛├É┬║├É┬░├É┬╖├æΓÇ╣├É┬▓├É┬░├æΓÇÜ├æ┼Æ hint \"├ÉΓÇö├É┬░ ├É┬╛├æΓÇÜ├É┬╖├æΓÇ╣├É┬▓ +N ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├É┬╛├É┬▓\" ├æ┬ü├æΓé¼├É┬░├É┬╖├æ╞Æ\n  const shouldShowReviewRewardHint = isReviewRewardActive && (myOrders?.length > 0);\n\n  // ├É┼╕├É┬╛├É┬║├É┬░├É┬╖├æΓÇ╣├É┬▓├É┬░├æΓÇÜ├æ┼Æ nudge \"├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ email\" ├É┬┐├É┬╛├æ┬ü├É┬╗├É┬╡ ├É┬┐├É┬╡├æΓé¼├É┬▓├É┬╛├É┬╣ ├É┬╛├æΓÇá├É┬╡├É┬╜├É┬║├É┬╕\n  const shouldShowReviewRewardNudge = isReviewRewardActive && hasAnyRating && !isCustomerIdentified;\n\n  // Split summary text\n  const splitSummary = splitType === \"all\" \n    ? `${tr('cart.for_all', '├É┬¥├É┬░ ├É┬▓├æ┬ü├É┬╡├æΓÇª')} (├â┬╖${guestCount})`\n    : tr('cart.only_me', '├É┬ó├É┬╛├É┬╗├æ┼Æ├É┬║├É┬╛ ├æ┬Å');\n\n  // Loyalty summary\n  const loyaltySummary = React.useMemo(() => {\n    if (Number(loyaltyAccount?.balance || 0) > 0) {\n      return `${Number(loyaltyAccount.balance || 0).toLocaleString('ru-RU')} ${tr('loyalty.points_short', '├É┬▒├É┬░├É┬╗├É┬╗├É┬╛├É┬▓')}`;\n    }\n    if (earnedPoints > 0) {\n      return `+${earnedPoints}`;\n    }\n    return null;\n  }, [loyaltyAccount, earnedPoints]);\n\n  // Reward for review (shown in Loyalty header if partner configured)\n  const reviewRewardLabel = React.useMemo(() => {\n    const pts = Number(partner?.loyalty_review_points);\n    if (Number.isFinite(pts) && pts > 0) return `+${pts}`;\n    return null;\n  }, [partner?.loyalty_review_points]);\n\n  return (\n    <div className=\"max-w-2xl mx-auto px-4 mt-2 pb-4\">\n      {/* P0 Header: [├░┼╕ΓÇ¥ΓÇ¥] ├É┬í├æΓÇÜ├É┬╛├É┬╗ ├é┬╖ ├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ [├ó┼ôΓÇó] */}\n      <div className=\"bg-white rounded-lg shadow-sm border p-3 mb-4\">\n        <div className=\"flex items-center justify-between\">\n          {/* Left: Call waiter */}\n          {onCallWaiter && (\n            <button\n              onClick={onCallWaiter}\n              className=\"p-2 rounded-full bg-amber-50 text-amber-600 hover:bg-amber-100\"\n              title={tr('help.call_waiter', '├É┼╕├É┬╛├É┬╖├É┬▓├É┬░├æΓÇÜ├æ┼Æ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├É┬░')}\n            >\n              <Bell className=\"w-5 h-5\" />\n            </button>\n          )}\n\n          {/* Center: Table & Guest */}\n          <div className=\"text-center flex-1 mx-2\">\n            <div className=\"text-sm font-medium text-slate-700\">{tableLabel}</div>\n            <div className=\"flex items-center justify-center gap-1 text-xs\">\n              <span className=\"text-slate-500\">{tr('cart.you', '├ÉΓÇÖ├æΓÇ╣')}:</span>\n              {isEditingName ? (\n                <span className=\"inline-flex items-center gap-1\">\n                  <input\n                    type=\"text\"\n                    value={guestNameInput}\n                    onChange={(e) => setGuestNameInput(e.target.value)}\n                    placeholder={tr('guest.name_placeholder', '├É╦£├É┬╝├æ┬Å')}\n                    className=\"w-20 px-1 py-0.5 text-xs border rounded\"\n                    autoFocus\n                    onKeyDown={(e) => {\n                      if (e.key === 'Enter' && guestNameInput.trim()) handleUpdateGuestName();\n                      if (e.key === 'Escape') { setIsEditingName(false); setGuestNameInput(''); }\n                    }}\n                  />\n                  <button onClick={handleUpdateGuestName} disabled={!guestNameInput.trim()} className=\"text-green-600\">├ó┼ôΓÇ£</button>\n                  <button onClick={() => { setIsEditingName(false); setGuestNameInput(''); }} className=\"text-slate-400\">├ó┼ôΓÇó</button>\n                </span>\n              ) : (\n                <button \n                  onClick={() => { setGuestNameInput(currentGuest?.name || ''); setIsEditingName(true); }}\n                  className=\"text-indigo-600 hover:underline\"\n                >\n                  {guestDisplay} {(!currentGuest?.name) && <span className=\"text-xs\">├ó┼ô┬Å├»┬╕┬Å</span>}\n                </button>\n              )}\n            </div>\n          </div>\n\n          {/* Right: Close */}\n          <button\n            onClick={() => onClose ? onClose() : setView(\"menu\")}\n            className=\"p-2 rounded-full bg-slate-100 text-slate-500 hover:bg-slate-200\"\n          >\n            <X className=\"w-5 h-5\" />\n          </button>\n        </div>\n      </div>\n\n      {/* Review reward hint */}\n      {shouldShowReviewRewardHint && (\n        <div className=\"mb-4 text-xs text-amber-700 bg-amber-50 rounded-md px-3 py-2 flex items-center gap-2\">\n          <span>├ó┬¡┬É</span>\n          <span>{tr('loyalty.review_reward_hint', '├ÉΓÇö├É┬░ ├É┬╛├æΓÇÜ├É┬╖├æΓÇ╣├É┬▓')} +{reviewRewardPoints} {tr('loyalty.points_short', '├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├É┬╛├É┬▓')}</span>\n        </div>\n      )}\n\n      {/* Review reward nudge - ├É┬┐├É┬╛├É┬║├É┬░├É┬╖├æΓÇ╣├É┬▓├É┬░├É┬╡├É┬╝ ├É┬┐├É┬╛├æ┬ü├É┬╗├É┬╡ ├É┬┐├É┬╡├æΓé¼├É┬▓├É┬╛├É┬╣ ├É┬╛├æΓÇá├É┬╡├É┬╜├É┬║├É┬╕ ├æ┬ü ├æΓÇ₧├É┬╛├æΓé¼├É┬╝├É┬╛├É┬╣ email */}\n      {shouldShowReviewRewardNudge && (\n        <div className=\"mb-4 text-sm bg-green-50 border border-green-200 rounded-md p-3\">\n          {!showRewardEmailForm ? (\n            <div className=\"flex items-center justify-between\">\n              <span className=\"text-slate-700\">\n                ├ó┼ôΓÇª {tr('loyalty.thanks_for_rating', '├É┬í├É┬┐├É┬░├æ┬ü├É┬╕├É┬▒├É┬╛ ├É┬╖├É┬░ ├É┬╛├æΓÇá├É┬╡├É┬╜├É┬║├æ╞Æ!')}\n              </span>\n              <button\n                type=\"button\"\n                className=\"text-indigo-600 hover:underline font-medium text-sm\"\n                onClick={() => setShowRewardEmailForm(true)}\n              >\n                {tr('loyalty.get_bonus', '├É┼╕├É┬╛├É┬╗├æ╞Æ├æΓÇí├É┬╕├æΓÇÜ├æ┼Æ ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├æΓÇ╣')} ├óΓÇáΓÇÖ\n              </button>\n            </div>\n          ) : (\n            <div className=\"space-y-2\">\n              <p className=\"text-slate-700 text-xs\">\n                {tr('loyalty.enter_email_for_bonus', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ email ├É┬┤├É┬╗├æ┬Å ├É┬╜├É┬░├æΓÇí├É┬╕├æ┬ü├É┬╗├É┬╡├É┬╜├É┬╕├æ┬Å ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├É┬╛├É┬▓:')}\n              </p>\n              <div className=\"flex gap-2\">\n                <Input\n                  type=\"email\"\n                  value={rewardEmail}\n                  onChange={(e) => setRewardEmail(e.target.value)}\n                  placeholder=\"email@example.com\"\n                  className=\"flex-1 h-9 text-sm\"\n                />\n                <Button\n                  size=\"sm\"\n                  className=\"h-9\"\n                  disabled={!rewardEmail.trim() || rewardEmailSubmitting}\n                  onClick={() => {\n                    if (!rewardEmail.trim()) return;\n                    setRewardEmailSubmitting(true);\n                    // ├É╦£├æ┬ü├É┬┐├É┬╛├É┬╗├æ┼Æ├É┬╖├æ╞Æ├É┬╡├É┬╝ ├æ┬ü├æ╞Æ├æΓÇ░├É┬╡├æ┬ü├æΓÇÜ├É┬▓├æ╞Æ├æ┼╜├æΓÇ░├É┬╕├É┬╣ setCustomerEmail ├É┬┤├É┬╗├æ┬Å ├æ┬ü├É┬╕├É┬╜├æΓÇª├æΓé¼├É┬╛├É┬╜├É┬╕├É┬╖├É┬░├æΓÇá├É┬╕├É┬╕\n                    if (setCustomerEmail) setCustomerEmail(rewardEmail);\n                    // ├É┼╕├É┬╛├É┬║├É┬░├É┬╖├æΓÇ╣├É┬▓├É┬░├É┬╡├É┬╝ toast\n                    if (toast) toast.success(tr('loyalty.email_saved', 'Email ├æ┬ü├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├æΓÇÿ├É┬╜! ├ÉΓÇÿ├É┬╛├É┬╜├æ╞Æ├æ┬ü├æΓÇ╣ ├É┬▒├æ╞Æ├É┬┤├æ╞Æ├æΓÇÜ ├É┬╜├É┬░├æΓÇí├É┬╕├æ┬ü├É┬╗├É┬╡├É┬╜├æΓÇ╣.'));\n                    setTimeout(() => {\n                      setRewardEmailSubmitting(false);\n                      setShowRewardEmailForm(false);\n                    }, 1000);\n                  }}\n                >\n                  {rewardEmailSubmitting ? '...' : tr('common.save', '├É┬í├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├É┬╕├æΓÇÜ├æ┼Æ')}\n                </Button>\n              </div>\n            </div>\n          )}\n        </div>\n      )}\n\n      {/* SECTION 5: TABLE ORDERS (other guests) - STABLE based on sessionOrders */}\n      {showTableOrdersSection && (\n        <Card className=\"mb-4\">\n          <CardContent className=\"p-4\">\n            <button\n              onClick={() => setOtherGuestsExpanded(!otherGuestsExpanded)}\n              className=\"w-full flex items-center justify-between text-left\"\n            >\n              <div className=\"flex items-center gap-2\">\n                <Users className=\"w-4 h-4 text-slate-500\" />\n                <span className=\"text-sm font-semibold text-slate-600\">\n                  {tr('cart.table_orders', '├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖├æΓÇ╣ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░')} ({otherGuestIdsFromOrders.length})\n                </span>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                {sessionItems.length === 0 && sessionOrders.length > 0 ? (\n                  <span className=\"text-sm text-slate-400\">{tr('common.loading', '├ÉΓÇö├É┬░├É┬│├æΓé¼├æ╞Æ├É┬╖├É┬║├É┬░')}</span>\n                ) : (\n                  <span className=\"font-bold text-slate-700\">{formatPrice(tableOrdersTotal)}</span>\n                )}\n                {otherGuestsExpanded ? (\n                  <ChevronUp className=\"w-4 h-4 text-slate-400\" />\n                ) : (\n                  <ChevronDown className=\"w-4 h-4 text-slate-400\" />\n                )}\n              </div>\n            </button>\n\n            {otherGuestsExpanded && (\n              <div className=\"mt-4 pt-4 border-t space-y-4\">\n                {otherGuestIdsFromOrders.map((gid) => {\n                  const guestOrders = ordersByGuestId.get(gid) || [];\n                  const guestTotal = guestOrders.reduce((sum, o) => sum + (Number(o.total_amount) || 0), 0);\n\n                  return (\n                    <div key={gid} className=\"text-sm\">\n                      <div className=\"flex items-center justify-between mb-2\">\n                        <span className=\"font-medium text-slate-700\">{getGuestLabelById(gid)}</span>\n                        {sessionItems.length === 0 && sessionOrders.length > 0 ? (\n                          <span className=\"text-slate-400\">{tr('common.loading', '├ÉΓÇö├É┬░├É┬│├æΓé¼├æ╞Æ├É┬╖├É┬║├É┬░')}</span>\n                        ) : (\n                          <span className=\"font-bold text-slate-600\">{formatPrice(guestTotal)}</span>\n                        )}\n                      </div>\n\n                      {guestOrders.length > 0 ? (\n                        <div className=\"pl-2 border-l-2 border-slate-200 space-y-1\">\n                          {guestOrders.map((order) => {\n                            const items = itemsByOrder.get(order.id) || [];\n                            const status = getSafeStatus(getOrderStatus(order));\n\n                            if (items.length === 0) {\n                              return (\n                                <div key={order.id} className=\"flex justify-between items-center text-xs\">\n                                  <span className=\"text-slate-600\">\n                                    {tr('cart.order_total', '├É┬í├æ╞Æ├É┬╝├É┬╝├É┬░ ├É┬╖├É┬░├É┬║├É┬░├É┬╖├É┬░')}: {formatPrice(order.total_amount)}\n                                  </span>\n                                  <span className=\"text-xs\" style={{ color: status.color }}>{status.label}</span>\n                                </div>\n                              );\n                            }\n\n                            return items.map((item, idx) => (\n                              <div key={`${order.id}-${idx}`} className=\"flex justify-between items-center text-xs\">\n                                <span className=\"text-slate-600\">{item.dish_name} ├âΓÇö {item.quantity}</span>\n                                <span className=\"text-xs\" style={{ color: status.color }}>{status.label}</span>\n                              </div>\n                            ));\n                          })}\n                        </div>\n                      ) : (\n                        <div className=\"pl-2 text-xs text-slate-400\">\n                          {tr('cart.no_orders_yet', '├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖├É┬╛├É┬▓ ├É┬┐├É┬╛├É┬║├É┬░ ├É┬╜├É┬╡├æΓÇÜ')}\n                        </div>\n                      )}\n                    </div>\n                  );\n                })}\n\n                {/* Review button for other guests' dishes */}\n                {otherGuestsReviewableItems.length > 0 && (\n                  <Button\n                    variant=\"outline\"\n                    size=\"sm\"\n                    className=\"w-full mt-2\"\n                    onClick={() => openReviewDialog(otherGuestsReviewableItems)}\n                  >\n                    ├ó┬¡┬É {tr('review.rate_others', '├É┼╛├æΓÇá├É┬╡├É┬╜├É┬╕├æΓÇÜ├æ┼Æ ├É┬▒├É┬╗├æ┼╜├É┬┤├É┬░ ├É┬│├É┬╛├æ┬ü├æΓÇÜ├É┬╡├É┬╣')}\n                    {loyaltyAccount && ` (+${otherGuestsReviewableItems.length * (partner?.loyalty_review_points || 10)} ${tr('review.points', '├É┬▒├É┬░├É┬╗├É┬╗├É┬╛├É┬▓')})`}\n                  </Button>\n                )}\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      )}\n\n      {/* SECTION 6: TABLE TOTAL */}\n      {(sessionGuests.length > 1 || showTableOrdersSection) && (\n        <Card className=\"mb-4 bg-slate-50\">\n          <CardContent className=\"p-4\">\n            <div className=\"flex items-center justify-between\">\n              <span className=\"font-medium text-slate-700\">{tr('cart.table_total', '├É┬í├æΓÇí├æΓÇÿ├æΓÇÜ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░')}:</span>\n              <span className=\"text-xl font-bold text-slate-900\">{formatPrice(tableTotal)}</span>\n            </div>\n          </CardContent>\n        </Card>\n      )}\n\n      {/* SECTION 3: YOUR ORDERS (submitted) - COLLAPSIBLE */}\n      {myOrders.length > 0 && (\n        <Card className=\"mb-4\">\n          <CardContent className=\"p-4\">\n            <button\n              type=\"button\"\n              className=\"w-full flex items-center justify-between text-left\"\n              onClick={() => setMyOrdersExpanded(!myOrdersExpanded)}\n            >\n              <div className=\"flex items-center gap-2\">\n                <ShoppingBag className=\"w-4 h-4 text-green-600\" />\n                <span className=\"text-base font-semibold text-slate-800\">\n                  {tr('cart.your_orders', '├ÉΓÇÖ├É┬░├æ╦å├É┬╕ ├É┬╖├É┬░├É┬║├É┬░├É┬╖├æΓÇ╣')} ({myOrders.length})\n                </span>\n              </div>\n              <div className=\"flex items-center gap-2\">\n                <span className=\"font-bold text-slate-700\">{formatPrice(myBill.total)}</span>\n                {myOrdersExpanded ? (\n                  <ChevronUp className=\"w-4 h-4 text-slate-400\" />\n                ) : (\n                  <ChevronDown className=\"w-4 h-4 text-slate-400\" />\n                )}\n              </div>\n            </button>\n\n            {myOrdersExpanded && (\n              <div className=\"mt-4 pt-4 border-t space-y-3\">\n                {myOrders.map((order) => {\n                  const orderItems = itemsByOrder.get(order.id) || [];\n                  const rawStatus = getOrderStatus(order);\n                  const status = getSafeStatus(rawStatus);\n\n                  return (\n                    <div key={order.id} className=\"border-b pb-3 last:border-0 last:pb-0\">\n                      <div className=\"flex items-center justify-between mb-2\">\n                        <span className=\"text-xs text-slate-400\">\n                          {formatOrderTime(order)}\n                        </span>\n                        <span className=\"text-xs px-2 py-1 rounded-full\" style={{ backgroundColor: `${status.color}15`, color: status.color }}>\n                          {status.label}\n                        </span>\n                      </div>\n                      {/* Order items with draft rating stars */}\n                      {orderItems.length > 0 ? (\n                        <div className=\"space-y-2\">\n                          {orderItems.map((item, idx) => {\n                            const itemId = item.id || `${order.id}_${idx}`;\n                            const hasReview = safeReviewedItems.has(itemId);\n                            const draftRating = safeDraftRatings[itemId] || 0;\n\n                            return (\n                              <div key={itemId} className=\"space-y-1\">\n                                <div className=\"flex justify-between items-center text-sm\">\n                                  <span className=\"text-slate-700\">{item.dish_name} ├âΓÇö {item.quantity}</span>\n                                  <span className=\"text-slate-600\">{formatPrice(item.line_total ?? (item.dish_price * item.quantity))}</span>\n                                </div>\n\n                                {/* Draft rating stars - show always if reviews enabled */}\n                                {reviewsEnabled && (\n                                  <div className=\"flex items-center gap-2 pl-2\">\n                                    <Rating\n                                      value={draftRating}\n                                      onChange={(val) => {\n                                        if (draftRating > 0 || hasReview) return; // ├æ╞Æ├É┬╢├É┬╡ ├É┬╛├æΓÇá├É┬╡├É┬╜├É┬╡├É┬╜├É┬╛\n                                        updateDraftRating(itemId, val);\n                                        if (val > 0 && handleRateDish) {\n                                          const dishId = typeof item.dish === 'object' ? item.dish?.id : item.dish;\n                                          handleRateDish({\n                                            itemId,\n                                            dishId,\n                                            orderId: order.id,\n                                            rating: val,\n                                          });\n                                        }\n                                      }}\n                                      size=\"sm\"\n                                      readonly={draftRating > 0 || hasReview || ratingSavingByItemId?.[itemId]}\n                                    />\n                                    {ratingSavingByItemId?.[itemId] && (\n                                      <Loader2 className=\"w-3 h-3 animate-spin text-slate-400\" />\n                                    )}\n                                    {(draftRating > 0 || hasReview) && !ratingSavingByItemId?.[itemId] && (\n                                      <span className=\"text-xs text-green-600\">├ó┼ôΓÇ£</span>\n                                    )}\n                                  </div>\n                                )}\n                              </div>\n                            );\n                          })}\n                        </div>\n                      ) : (\n                        <div className=\"text-sm text-slate-500\">\n                          {tr('cart.order_total', '├É┬í├æ╞Æ├É┬╝├É┬╝├É┬░ ├É┬╖├É┬░├É┬║├É┬░├É┬╖├É┬░')}: {formatPrice(order.total_amount)}\n                        </div>\n                      )}\n                    </div>\n                  );\n                })}\n\n                {/* Review button */}\n                {reviewableItems.length > 0 && (\n                  <Button\n                    variant=\"outline\"\n                    size=\"sm\"\n                    className=\"w-full mt-3\"\n                    onClick={() => openReviewDialog(reviewableItems)}\n                  >\n                    ├░┼╕ΓÇÖ┬¼ {tr('review.add_comments', '├ÉΓÇ¥├É┬╛├É┬▒├É┬░├É┬▓├É┬╕├æΓÇÜ├æ┼Æ ├É┬║├É┬╛├É┬╝├É┬╝├É┬╡├É┬╜├æΓÇÜ├É┬░├æΓé¼├É┬╕├É┬╕')}\n                  </Button>\n                )}\n              </div>\n            )}\n          </CardContent>\n        </Card>\n      )}\n\n      {/* SECTION 2: NEW ORDER */}\n      {cart.length > 0 && (\n        <Card className=\"mb-4\">\n          <CardContent className=\"p-4\">\n            <h2 className=\"text-base font-semibold text-slate-800 mb-3 flex items-center gap-2\">\n              ├░┼╕ΓÇ║ΓÇÖ {tr('cart.new_order', '├É┬¥├É┬╛├É┬▓├æΓÇ╣├É┬╣ ├É┬╖├É┬░├É┬║├É┬░├É┬╖')}\n            </h2>\n\n            <div className=\"space-y-2\">\n              {cart.map((item) => (\n                <div key={item.dishId} className=\"flex items-center justify-between py-2 border-b last:border-0\">\n                  <div className=\"flex-1\">\n                    <div className=\"font-medium text-slate-900\">{item.name}</div>\n                    <div className=\"text-xs text-slate-500\">{formatPrice(item.price)} ├âΓÇö {item.quantity}</div>\n                  </div>\n                  <div className=\"flex items-center gap-3\">\n                    <span className=\"font-semibold text-slate-900\">{formatPrice(item.price * item.quantity)}</span>\n                    <button \n                      onClick={() => updateQuantity(item.dishId, -item.quantity)}\n                      className=\"p-1.5 rounded-full hover:bg-red-50 text-slate-400 hover:text-red-600 transition-colors\"\n                    >\n                      <XIcon className=\"w-4 h-4\" />\n                    </button>\n                  </div>\n                </div>\n              ))}\n            </div>\n\n            {/* P1: Split toggle - STABLE (always visible, disabled if < 2 guests) */}\n            {isTableVerified === true && (\n            <div className=\"mt-4 pt-4 border-t\">\n              <button\n                type=\"button\"\n                className={`w-full flex items-center justify-between text-left ${\n                  canSplit ? \"cursor-pointer\" : \"cursor-not-allowed\"\n                }`}\n                onClick={() => canSplit && setSplitExpanded(!splitExpanded)}\n                disabled={!canSplit}\n              >\n                <span className=\"text-sm font-medium text-slate-700\">\n                  {tr('cart.split_title', '├ÉΓÇ¥├É┬╗├æ┬Å ├É┬║├É┬╛├É┬│├É┬╛ ├É┬╖├É┬░├É┬║├É┬░├É┬╖')}\n                </span>\n                <div className=\"flex items-center gap-2\">\n                  <span className={`text-sm ${canSplit ? 'text-slate-600' : 'text-slate-400'}`}>\n                    {splitSummary}\n                  </span>\n                  {canSplit ? (\n                    splitExpanded ? (\n                      <ChevronUp className=\"w-4 h-4 text-slate-400\" />\n                    ) : (\n                      <ChevronDown className=\"w-4 h-4 text-slate-400\" />\n                    )\n                  ) : (\n                    <span className=\"text-xs text-slate-400\">\n                      {tr('cart.split_disabled_hint', '(2+ ├É┬│├É┬╛├æ┬ü├æΓÇÜ├É┬╡├É┬╣)')}\n                    </span>\n                  )}\n                </div>\n              </button>\n\n              {splitExpanded && canSplit && (\n                <div className=\"mt-3 flex items-center justify-center gap-6\">\n                  <label className=\"flex items-center gap-2 cursor-pointer\">\n                    <input\n                      type=\"radio\"\n                      name=\"splitType\"\n                      checked={splitType === 'single'}\n                      onChange={() => setSplitType('single')}\n                      className=\"w-4 h-4 text-indigo-600\"\n                    />\n                    <span className=\"text-sm text-slate-700\">{tr('cart.only_me', '├É┬ó├É┬╛├É┬╗├æ┼Æ├É┬║├É┬╛ ├æ┬Å')}</span>\n                  </label>\n                  <label className=\"flex items-center gap-2 cursor-pointer\">\n                    <input\n                      type=\"radio\"\n                      name=\"splitType\"\n                      checked={splitType === 'all'}\n                      onChange={() => setSplitType('all')}\n                      className=\"w-4 h-4 text-indigo-600\"\n                    />\n                    <span className=\"text-sm text-slate-700\">{tr('cart.for_all', '├É┬¥├É┬░ ├É┬▓├æ┬ü├É┬╡├æΓÇª')} (├â┬╖{guestCount})</span>\n                  </label>\n                  {/* P2 placeholder - disabled until data model supports custom split */}\n                  <label className=\"flex items-center gap-2 opacity-50 cursor-not-allowed\">\n                    <input\n                      type=\"radio\"\n                      disabled\n                      className=\"w-4 h-4\"\n                    />\n                    <span className=\"text-sm text-slate-400\">\n                      {tr('cart.split_pick_guests_soon', '├ÉΓÇÖ├æΓÇ╣├É┬▒├æΓé¼├É┬░├æΓÇÜ├æ┼Æ ├É┬│├É┬╛├æ┬ü├æΓÇÜ├É┬╡├É┬╣ (├æ┬ü├É┬║├É┬╛├æΓé¼├É┬╛)')}\n                    </span>\n                  </label>\n                </div>\n              )}\n            </div>\n            )}\n\n            {/* P1: Loyalty section - COLLAPSIBLE */}\n            {showLoginPromptAfterRating && (\n              <div className=\"mt-4 pt-4 border-t\">\n                <button\n                  type=\"button\"\n                  className=\"w-full flex items-center justify-between text-left\"\n                  onClick={() => setLoyaltyExpanded(!loyaltyExpanded)}\n                >\n                  <div className=\"flex items-center gap-2\">\n                    <Gift className=\"w-4 h-4 text-amber-500\" />\n                    <span className=\"text-sm font-medium text-slate-700\">\n                      {tr('loyalty.title', '├ÉΓÇÿ├É┬╛├É┬╜├æ╞Æ├æ┬ü├æΓÇ╣')}\n                      {reviewRewardLabel && (\n                        <span className=\"ml-2 text-xs text-slate-500 font-normal\">\n                          ├óΓé¼┬ó {tr('loyalty.review_reward_prefix', '├É┬╖├É┬░ ├É┬╛├æΓÇÜ├É┬╖├æΓÇ╣├É┬▓')} {reviewRewardLabel}\n                        </span>\n                      )}\n                    </span>\n                  </div>\n                  <div className=\"flex items-center gap-2\">\n                    {loyaltySummary && (\n                      <span className=\"text-sm font-semibold text-green-600\">\n                        {loyaltySummary}\n                      </span>\n                    )}\n                    {loyaltyExpanded ? (\n                      <ChevronUp className=\"w-4 h-4 text-slate-400\" />\n                    ) : (\n                      <ChevronDown className=\"w-4 h-4 text-slate-400\" />\n                    )}\n                  </div>\n                </button>\n\n                {loyaltyExpanded && (\n                  <div className=\"mt-3 space-y-3\">\n                    <div className=\"space-y-2\">\n                      <label className=\"text-sm font-medium text-slate-700\">\n                        {tr('loyalty.email_label', 'Email ├É┬┤├É┬╗├æ┬Å ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├É┬╛├É┬▓')}\n                      </label>\n                      <Input\n                        type=\"email\"\n                        value={customerEmail}\n                        onChange={(e) => setCustomerEmail(e.target.value)}\n                        placeholder={tr('loyalty.email_placeholder', 'email@example.com')}\n                      />\n                    </div>\n\n                    {!customerEmail.trim() ? (\n                      <p className=\"text-xs text-slate-500\">{tr('loyalty.enter_email_hint', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ email ├É┬┤├É┬╗├æ┬Å ├É┬╜├É┬░├æΓÇí├É┬╕├æ┬ü├É┬╗├É┬╡├É┬╜├É┬╕├æ┬Å ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├É┬╛├É┬▓')}</p>\n                    ) : loyaltyLoading ? (\n                      <div className=\"flex items-center gap-2 text-xs text-slate-500\">\n                        <Loader2 className=\"w-3 h-3 animate-spin\" />\n                        {tr('common.loading', '├ÉΓÇö├É┬░├É┬│├æΓé¼├æ╞Æ├É┬╖├É┬║├É┬░')}\n                      </div>\n                    ) : !loyaltyAccount ? (\n                      partner?.loyalty_enabled && (\n                        <div className=\"text-xs text-green-600 bg-green-50 p-2 rounded-lg\">\n                          {trFormat('loyalty.new_customer', { points: earnedPoints }, `├ÉΓÇÖ├æΓÇ╣ ├É┬┐├É┬╛├É┬╗├æ╞Æ├æΓÇí├É┬╕├æΓÇÜ├É┬╡ ${earnedPoints} ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├É┬╛├É┬▓ ├É┬╖├É┬░ ├É┬┐├É┬╡├æΓé¼├É┬▓├æΓÇ╣├É┬╣ ├É┬╖├É┬░├É┬║├É┬░├É┬╖`)}\n                        </div>\n                      )\n                    ) : (\n                      <div className=\"space-y-2\">\n                        <div className=\"bg-indigo-50 p-2 rounded-lg text-xs\">\n                          <div className=\"text-slate-600\">\n                            {trFormat('loyalty.your_balance', { points: Number(loyaltyAccount.balance || 0).toLocaleString('ru-RU') }, `├ÉΓÇÖ├É┬░├æ╦å ├É┬▒├É┬░├É┬╗├É┬░├É┬╜├æ┬ü: ${Number(loyaltyAccount.balance || 0).toLocaleString('ru-RU')} ├É┬▒├É┬░├É┬╗├É┬╗├É┬╛├É┬▓`)}\n                          </div>\n                          <div className=\"text-slate-500\">\n                            = {(Number(loyaltyAccount.balance || 0) * (partner?.loyalty_redeem_rate || 1)).toLocaleString('ru-RU')}├óΓÇÜ┬╕\n                          </div>\n                        </div>\n\n                        {loyaltyAccount.balance > 0 && maxRedeemPoints > 0 && (\n                          <div className=\"space-y-1\">\n                            <label className=\"text-xs font-medium text-slate-700\">\n                              {tr('loyalty.redeem_points', '├É┬í├É┬┐├É┬╕├æ┬ü├É┬░├æΓÇÜ├æ┼Æ ├É┬▒├É┬░├É┬╗├É┬╗├æΓÇ╣')}\n                            </label>\n                            <div className=\"flex items-center gap-2\">\n                              <Input\n                                type=\"number\"\n                                min={0}\n                                max={maxRedeemPoints}\n                                value={redeemedPoints}\n                                onChange={(e) => {\n                                  const val = parseInt(e.target.value) || 0;\n                                  setRedeemedPoints(Math.min(Math.max(0, val), maxRedeemPoints));\n                                }}\n                                className=\"w-24 h-8 text-sm\"\n                              />\n                              <Button\n                                size=\"sm\"\n                                className=\"h-8 text-xs\"\n                                onClick={() => {\n                                  setRedeemedPoints(maxRedeemPoints);\n                                  toast.success(tr('loyalty.points_applied', '├ÉΓÇÿ├É┬░├É┬╗├É┬╗├æΓÇ╣ ├É┬┐├æΓé¼├É┬╕├É┬╝├É┬╡├É┬╜├É┬╡├É┬╜├æΓÇ╣'), { id: 'mm1' });\n                                }}\n                              >\n                                {tr('loyalty.apply', '├É┼╕├æΓé¼├É┬╕├É┬╝├É┬╡├É┬╜├É┬╕├æΓÇÜ├æ┼Æ')}\n                              </Button>\n                            </div>\n                            <p className=\"text-xs text-slate-500\">\n                              {trFormat('loyalty.max_redeem', { \n                                max: maxRedeemPoints.toLocaleString('ru-RU'), \n                                percent: partner?.loyalty_max_redeem_percent || 0 \n                              }, `├É┼ô├É┬░├É┬║├æ┬ü├É┬╕├É┬╝├æ╞Æ├É┬╝ ${maxRedeemPoints} ├É┬▒├É┬░├É┬╗├É┬╗├É┬╛├É┬▓ (${partner?.loyalty_max_redeem_percent || 0}% ├É┬╛├æΓÇÜ ├É┬╖├É┬░├É┬║├É┬░├É┬╖├É┬░)`) }\n                            </p>\n                          </div>\n                        )}\n                      </div>\n                    )}\n\n                    {partner?.discount_enabled && (\n                      partner.discount_allow_anonymous === true || customerEmail.trim() ? (\n                        <div className=\"text-xs text-green-600 bg-green-50 p-2 rounded-lg border border-green-200\">\n                          {trFormat('loyalty.instant_discount', { percent: partner.discount_percent || 0 }, `├É┬í├É┬║├É┬╕├É┬┤├É┬║├É┬░ ${partner.discount_percent || 0}% ├É┬┐├æΓé¼├É┬╕├É┬╝├É┬╡├É┬╜├É┬╡├É┬╜├É┬░`)}\n                        </div>\n                      ) : (\n                        <div className=\"text-xs text-amber-600 bg-amber-50 p-2 rounded-lg border border-amber-200\">\n                          {trFormat('loyalty.enter_email_for_discount', { percent: partner.discount_percent || 0 }, `├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ email ├É┬┤├É┬╗├æ┬Å ├æ┬ü├É┬║├É┬╕├É┬┤├É┬║├É┬╕ ${partner.discount_percent || 0}%`)}\n                        </div>\n                      )\n                    )}\n                  </div>\n                )}\n              </div>\n            )}\n\n            {/* Subtotal and submit */}\n            <div className=\"mt-4 pt-4 border-t space-y-3\">\n              {partner?.loyalty_enabled && earnedPoints > 0 && !loyaltyExpanded && (\n                <div className=\"flex justify-between text-sm text-green-600\">\n                  <span>{tr('loyalty.online_bonus_label', '├ÉΓÇÿ├É┬╛├É┬╜├æ╞Æ├æ┬ü├æΓÇ╣ ├É┬╖├É┬░ ├É┬╛├É┬╜├É┬╗├É┬░├É┬╣├É┬╜-├É┬╖├É┬░├É┬║├É┬░├É┬╖')}</span>\n                  <span>+{Number(earnedPoints || 0).toLocaleString('ru-RU')}├ÉΓÇÿ</span>\n                </div>\n              )}\n\n              {/* ├É╦£├É┬ó├É┼╛├ÉΓÇ£├É┼╛ - bold total */}\n              <div className=\"flex justify-between items-end pt-2 border-t\">\n                <span className=\"text-sm font-semibold text-slate-700 uppercase tracking-wide\">\n                  {tr('cart.total', '├É╦£├É┬ó├É┼╛├ÉΓÇ£├É┼╛')}:\n                </span>\n                <span className=\"text-lg font-bold text-slate-900\">{formatPrice(Number(cartTotalAmount) || 0)}</span>\n              </div>\n\n              {/* Online order to waiter (verification + benefits) */}\n              <div className=\"mt-4 p-3 bg-amber-50 border border-amber-200 rounded-lg\">\n                <div className=\"flex items-center justify-between mb-2\">\n                  <p className=\"text-amber-900 font-semibold text-sm\">\n                    {tr('cart.verify.online_order_title', '├É┼╛├É┬╜├É┬╗├É┬░├É┬╣├É┬╜-├É┬╖├É┬░├É┬║├É┬░├É┬╖ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ')}\n                  </p>\n                  <button\n                    type=\"button\"\n                    className=\"text-amber-700 hover:text-amber-900 text-sm px-2\"\n                    onClick={() => setInfoModal('online')}\n                    title={tr('common.info', '├É╦£├É┬╜├æΓÇ₧├É┬╛├æΓé¼├É┬╝├É┬░├æΓÇá├É┬╕├æ┬Å')}\n                  >\n                    ├óΓÇ£╦£\n                  </button>\n                </div>\n\n                {/* AC-03: Expected savings ├óΓé¼ΓÇ¥ separate from total, not subtracted */}\n                {(discountAmount > 0 || (partner?.loyalty_enabled && earnedPoints > 0) || pointsDiscountAmount > 0) && (\n                  <p className=\"text-xs text-amber-700 font-medium mb-1\">\n                    {tr('cart.expected_savings', '├É┼╛├É┬╢├É┬╕├É┬┤├É┬░├É┬╡├É┬╝├É┬░├æ┬Å ├É┬▓├æΓÇ╣├É┬│├É┬╛├É┬┤├É┬░')}:\n                  </p>\n                )}\n                {discountAmount > 0 && (\n                  <div className=\"flex justify-between text-sm text-amber-900\">\n                    <span>{tr('cart.verify.discount_label', '├É┬í├É┬║├É┬╕├É┬┤├É┬║├É┬░ ├É┬╖├É┬░ ├É┬╛├É┬╜├É┬╗├É┬░├É┬╣├É┬╜-├É┬╖├É┬░├É┬║├É┬░├É┬╖')}</span>\n                    <span>├ó╦åΓÇÖ{formatPrice(discountAmount)}</span>\n                  </div>\n                )}\n\n                {partner?.loyalty_enabled && earnedPoints > 0 && (\n                  <div className=\"flex justify-between text-sm text-amber-900\">\n                    <span>{tr('cart.verify.bonus_label', '├ÉΓÇÿ├É┬╛├É┬╜├æ╞Æ├æ┬ü├æΓÇ╣ ├É┬╖├É┬░ ├É┬╛├É┬╜├É┬╗├É┬░├É┬╣├É┬╜-├É┬╖├É┬░├É┬║├É┬░├É┬╖')}</span>\n                    <span>+{Number(earnedPoints || 0).toLocaleString('ru-RU')}├ÉΓÇÿ</span>\n                  </div>\n                )}\n\n                {/* Redeem points (if user applied) */}\n                {pointsDiscountAmount > 0 && (\n                  <div className=\"flex justify-between text-sm text-amber-900\">\n                    <span>{tr('cart.verify.points_discount_label', '├É┬í├É┬┐├É┬╕├æ┬ü├É┬░├É┬╜├É┬╕├É┬╡ ├É┬▒├É┬░├É┬╗├É┬╗├É┬╛├É┬▓')}</span>\n                    <span>├ó╦åΓÇÖ{formatPrice(pointsDiscountAmount)}</span>\n                  </div>\n                )}\n\n                <div className=\"mt-3 pt-3 border-t border-amber-200\">\n                  {isTableVerified === true ? (\n                    <div className=\"text-sm text-green-700 text-center\">\n                      ├ó┼ôΓÇª {tr('cart.verify.table_verified', '├É┬í├æΓÇÜ├É┬╛├É┬╗ ├É┬┐├É┬╛├É┬┤├æΓÇÜ├É┬▓├É┬╡├æΓé¼├É┬╢├É┬┤├æΓÇÿ├É┬╜')}\n                    </div>\n                  ) : (\n                    <>\n                      <div className=\"flex items-center justify-between mb-2\">\n                        <p className=\"text-amber-900 font-medium text-sm\">\n                          {tr('cart.verify.enter_table_code', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ ├É┬║├É┬╛├É┬┤ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░')}\n                        </p>\n                        <button\n                          type=\"button\"\n                          className=\"text-amber-700 hover:text-amber-900 text-sm px-2\"\n                          onClick={() => setInfoModal('tableCode')}\n                          title={tr('common.info', '├É╦£├É┬╜├æΓÇ₧├É┬╛├æΓé¼├É┬╝├É┬░├æΓÇá├É┬╕├æ┬Å')}\n                        >\n                          ├óΓÇ£╦£\n                        </button>\n                      </div>\n\n                      {/* Slots UI + invisible input (auto-verify when fully entered) */}\n                      <div className=\"space-y-2\">\n                        <div className=\"flex items-center justify-center gap-3\">\n                          <div className={`relative ${isCodeLocked ? 'opacity-60' : ''}`}>\n                            <div\n                              className=\"flex items-center gap-2\"\n                              onClick={() => !isCodeLocked && codeInputRef.current && codeInputRef.current.focus()}\n                            >\n                              <div className=\"flex gap-2\">\n                                {Array.from({ length: tableCodeLength }).map((_, idx) => {\n                                  const safe = String(tableCodeInput || '').replace(/\\D/g, '').slice(0, tableCodeLength);\n                                  const ch = safe[idx] || '_';\n                                  return (\n                                    <div\n                                      key={idx}\n                                      className=\"w-9 h-11 rounded-lg border border-amber-200 bg-white flex items-center justify-center text-xl font-mono text-amber-900\"\n                                    >\n                                      {ch}\n                                    </div>\n                                  );\n                                })}\n                              </div>\n                              {isVerifyingCode && (\n                                <Loader2 className=\"w-4 h-4 animate-spin text-amber-700\" />\n                              )}\n                            </div>\n\n                            <Input\n                              ref={codeInputRef}\n                              type=\"text\"\n                              inputMode=\"numeric\"\n                              maxLength={tableCodeLength}\n                              value={String(tableCodeInput || '').replace(/\\D/g, '').slice(0, tableCodeLength)}\n                              disabled={isCodeLocked}\n                              onChange={(e) => {\n                                const next = String(e.target.value || '').replace(/\\D/g, '').slice(0, tableCodeLength);\n                                if (typeof setTableCodeInput === 'function') setTableCodeInput(next);\n                              }}\n                              className=\"absolute inset-0 opacity-0 cursor-text\"\n                              aria-label={tr('cart.verify.enter_table_code', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ ├É┬║├É┬╛├É┬┤ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░')}\n                              placeholder={tr('cart.verify.enter_code_placeholder', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ ├É┬║├É┬╛├É┬┤')}\n                            />\n                          </div>\n                        </div>\n\n                        {!String(tableCodeInput || '').trim() && (\n                          <div className=\"text-center text-xs text-amber-700\">\n                            {tr('cart.verify.enter_code_placeholder', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ ├É┬║├É┬╛├É┬┤')}\n                          </div>\n                        )}\n\n                        {isCodeLocked ? (\n                          <div className=\"text-center text-xs text-amber-800\">\n                            ├ó┬Å┬│ {tr('cart.verify.locked', '├É┬í├É┬╗├É┬╕├æ╦å├É┬║├É┬╛├É┬╝ ├É┬╝├É┬╜├É┬╛├É┬│├É┬╛ ├É┬┐├É┬╛├É┬┐├æΓÇ╣├æΓÇÜ├É┬╛├É┬║. ├É┼╕├É┬╛├É┬▓├æΓÇÜ├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡ ├æΓÇí├É┬╡├æΓé¼├É┬╡├É┬╖')}{' '}\n                            {String(Math.floor(codeSecondsLeft / 60)).padStart(2, '0')}:{String(codeSecondsLeft % 60).padStart(2, '0')}\n                          </div>\n                        ) : (\n                          <>\n                            {codeVerificationError && !isVerifyingCode && (\n                              <div className=\"text-center text-xs text-red-700\">\n                                {codeVerificationError}\n                                {maxCodeAttempts > 0 && (\n                                  <div className=\"mt-1 text-red-600\">\n                                    {tr('cart.verify.attempts', '├É┼╕├É┬╛├É┬┐├æΓÇ╣├æΓÇÜ├É┬║├É┬╕')}: {Math.min(codeAttempts, maxCodeAttempts)} {tr('common.of', '├É┬╕├É┬╖')} {maxCodeAttempts}\n                                  </div>\n                                )}\n                              </div>\n                            )}\n                          </>\n                        )}\n\n                        {/* Option 2: Tell code to waiter (same effect) */}\n                        {hallGuestCodeEnabled && effectiveGuestCode && (\n                          <div className=\"mt-3 pt-3 border-t border-amber-200 text-center\">\n                            <div className=\"flex items-center justify-center gap-2 text-xs text-amber-600 mb-2\">\n                              <span className=\"flex-1 border-t border-amber-300\"></span>\n                              <span>{tr('common.or', '├É┬╕├É┬╗├É┬╕')}</span>\n                              <span className=\"flex-1 border-t border-amber-300\"></span>\n                            </div>\n                            <p className=\"text-xs text-amber-800 mb-1\">\n                              {tr('cart.tell_code_to_waiter', '├É┬¥├É┬░├É┬╖├É┬╛├É┬▓├É┬╕├æΓÇÜ├É┬╡ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ ├æ┬ì├æΓÇÜ├É┬╛├æΓÇÜ ├É┬║├É┬╛├É┬┤')}:\n                            </p>\n                            <p className=\"text-2xl font-bold text-amber-900 font-mono\">\n                              {String(effectiveGuestCode)}\n                            </p>\n                          </div>\n                        )}\n                      </div>\n                    </>\n                  )}\n                </div>\n              </div>\n\n              {/* Info modal */}\n              {infoModal && (\n                <div\n                  className=\"fixed inset-0 z-50 flex items-center justify-center bg-black/40 p-4\"\n                  onMouseDown={() => setInfoModal(null)}\n                >\n                  <div\n                    className=\"w-full max-w-sm bg-white rounded-xl shadow-lg border p-4\"\n                    onMouseDown={(e) => e.stopPropagation()}\n                  >\n                    <div className=\"flex items-center justify-between mb-3\">\n                      <div className=\"font-semibold text-slate-900\">\n                        {infoModal === 'online'\n                          ? tr('cart.verify.info_online_title', '├É┼╛├É┬╜├É┬╗├É┬░├É┬╣├É┬╜-├É┬╖├É┬░├É┬║├É┬░├É┬╖ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ')\n                          : tr('cart.verify.info_table_code_title', '├É┼í├É┬╛├É┬┤ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░')}\n                      </div>\n                      <button\n                        type=\"button\"\n                        className=\"p-1 rounded hover:bg-slate-100 text-slate-500\"\n                        onClick={() => setInfoModal(null)}\n                        aria-label={tr('common.close', '├ÉΓÇö├É┬░├É┬║├æΓé¼├æΓÇ╣├æΓÇÜ├æ┼Æ')}\n                      >\n                        ├ó┼ôΓÇó\n                      </button>\n                    </div>\n\n                    {infoModal === 'online' ? (\n                      <ul className=\"text-sm text-slate-700 list-disc pl-5 space-y-2\">\n                        <li>{tr('cart.verify.info_online_point1', '├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖ ├æ┬ü├æΓé¼├É┬░├É┬╖├æ╞Æ ├É┬┐├É┬╛├É┬┐├É┬░├É┬┤├É┬░├É┬╡├æΓÇÜ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ')}</li>\n                        <li>{tr('cart.verify.info_online_point2', '├É┼╛├É┬▒├æΓÇ╣├æΓÇí├É┬╜├É┬╛ ├É┬▒├æΓÇ╣├æ┬ü├æΓÇÜ├æΓé¼├É┬╡├É┬╡')}</li>\n                        <li>{tr('cart.verify.info_online_point3', '├É┬í├É┬║├É┬╕├É┬┤├É┬║├É┬░ ├É┬╕ ├É┬▒├É┬╛├É┬╜├æ╞Æ├æ┬ü├æΓÇ╣ (├É┬╡├æ┬ü├É┬╗├É┬╕ ├É┬╡├æ┬ü├æΓÇÜ├æ┼Æ) ├É┬┐├æΓé¼├É┬╕├É┬╝├É┬╡├É┬╜├æ┬Å├æ┼╜├æΓÇÜ├æ┬ü├æ┬Å ├É┬░├É┬▓├æΓÇÜ├É┬╛├É┬╝├É┬░├æΓÇÜ├É┬╕├æΓÇí├É┬╡├æ┬ü├É┬║├É┬╕')}</li>\n                      </ul>\n                    ) : (\n                      <ul className=\"text-sm text-slate-700 list-disc pl-5 space-y-2\">\n                        <li>{tr('cart.verify.info_table_code_point1', '├É┼í├É┬╛├É┬┤ ├É┬╛├É┬▒├æΓÇ╣├æΓÇí├É┬╜├É┬╛ ├æ╞Æ├É┬║├É┬░├É┬╖├É┬░├É┬╜ ├É┬╜├É┬░ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬╡')}</li>\n                        <li>{tr('cart.verify.info_table_code_point2', '├ÉΓÇó├æ┬ü├É┬╗├É┬╕ ├É┬╜├É┬╡ ├É┬▓├É┬╕├É┬┤├É┬╜├É┬╛ ├óΓé¼ΓÇ¥ ├æ┬ü├É┬┐├æΓé¼├É┬╛├æ┬ü├É┬╕├æΓÇÜ├É┬╡ ├æ╞Æ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├É┬░')}</li>\n                      </ul>\n                    )}\n                  </div>\n                </div>\n              )}\n\n\n            </div>\n          </CardContent>\n        </Card>\n      )}\n\n      {/* Add more link - removed, use ├ó┼ôΓÇó to close */}\n\n      {/* Spacer so sticky button doesn't overlap last content */}\n      {cart.length > 0 && <div className=\"h-20\" />}\n\n      {/* AC-08: Error state with retry */}\n      {submitError && cart.length > 0 && (\n        <div className=\"mx-0 mb-2 p-3 bg-red-50 border border-red-200 rounded-lg text-center\">\n          <p className=\"text-sm font-medium text-red-700\">{submitError}</p>\n          <p className=\"text-xs text-red-500 mt-1\">\n            {tr('error.send.subtitle', '├ÉΓÇÖ├É┬░├æ╦å ├É┬╖├É┬░├É┬║├É┬░├É┬╖ ├æ┬ü├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├æΓÇÿ├É┬╜. ├É┼╕├É┬╛├É┬┐├æΓé¼├É┬╛├É┬▒├æ╞Æ├É┬╣├æΓÇÜ├É┬╡ ├æ┬ü├É┬╜├É┬╛├É┬▓├É┬░')}\n          </p>\n        </div>\n      )}\n\n      {/* Submit button - sticky at bottom of drawer scroll area */}\n      {cart.length > 0 && (\n        <div className=\"sticky bottom-0 bg-white border-t border-slate-200 p-4 -mx-4\">\n          <Button\n            size=\"lg\"\n            className={`w-full ${\n              isSubmitting\n                ? 'bg-slate-100 text-slate-400 cursor-not-allowed hover:bg-slate-100'\n                : isTableVerified === false\n                  ? 'bg-gray-300 text-gray-500 cursor-not-allowed hover:bg-gray-300'\n                  : submitError\n                    ? 'bg-red-600 hover:bg-red-700'\n                    : 'bg-green-600 hover:bg-green-700'\n            }`}\n            onClick={() => {\n              if (submitError && setSubmitError) setSubmitError(null);\n              handleSubmitOrder();\n            }}\n            disabled={isSubmitting || isTableVerified === false}\n          >\n            {isSubmitting\n              ? tr('cta.sending', '├É┼╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├æ┬Å├É┬╡├É┬╝...')\n              : submitError\n                ? tr('cta.retry', '├É┼╕├É┬╛├É┬▓├æΓÇÜ├É┬╛├æΓé¼├É┬╕├æΓÇÜ├æ┼Æ ├É┬╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬║├æ╞Æ')\n                : tr('cart.send_to_waiter', '├É┼╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╕├æΓÇÜ├æ┼Æ ├É┬╖├É┬░├É┬║├É┬░├É┬╖ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ')}\n          </Button>\n          {isTableVerified === false && (\n            <p className=\"text-xs text-gray-400 text-center mt-1\">\n              {tr('cart.enter_table_code_hint', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ ├É┬║├É┬╛├É┬┤ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░ ├æΓÇí├æΓÇÜ├É┬╛├É┬▒├æΓÇ╣ ├É┬╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╕├æΓÇÜ├æ┼Æ ├É┬╖├É┬░├É┬║├É┬░├É┬╖')}\n            </p>\n          )}\n        </div>\n      )}\n    </div>\n  );\n}\n```\n\n## Known Bugs (BUGS.md)\n---\nversion: \"22.0\"\nupdated: \"2026-03-13\"\nsession: 119\n---\n\n# PublicMenu ├óΓé¼ΓÇ¥ Bug Registry\n\n├É┬á├É┬╡├É┬│├É┬╕├æ┬ü├æΓÇÜ├æΓé¼ ├É┬▓├æ┬ü├É┬╡├æΓÇª ├É┬╕├É┬╖├É┬▓├É┬╡├æ┬ü├æΓÇÜ├É┬╜├æΓÇ╣├æΓÇª ├É┬▒├É┬░├É┬│├É┬╛├É┬▓ ├æ┬ü├æΓÇÜ├æΓé¼├É┬░├É┬╜├É┬╕├æΓÇá├æΓÇ╣ ├É┬┐├æ╞Æ├É┬▒├É┬╗├É┬╕├æΓÇí├É┬╜├É┬╛├É┬│├É┬╛ ├É┬╝├É┬╡├É┬╜├æ┼╜ (x.jsx + useTableSession.jsx).\n├É┬ª├É┬╡├É┬╗├æ┼Æ: ├É┬╜├É┬╡ ├æΓÇÜ├É┬╡├æΓé¼├æ┬Å├æΓÇÜ├æ┼Æ ├É┬║├É┬╛├É┬╜├æΓÇÜ├É┬╡├É┬║├æ┬ü├æΓÇÜ, ├É┬▒├æΓÇ╣├æ┬ü├æΓÇÜ├æΓé¼├É┬╛ ├æΓÇí├É┬╕├É┬╜├É┬╕├æΓÇÜ├æ┼Æ ├É┬┐├É┬╛├É┬▓├æΓÇÜ├É┬╛├æΓé¼├É┬╜├æΓÇ╣├É┬╡ ├É┬▒├É┬░├É┬│├É┬╕, ├É┬╜├É┬╡ ├É┬┤├É┬╛├É┬┐├æ╞Æ├æ┬ü├É┬║├É┬░├æΓÇÜ├æ┼Æ ├æΓé¼├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├É┬╣.\n\n---\n\n## Active Bugs (├É┬╜├É┬╡ ├É┬╕├æ┬ü├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜├æΓÇ╣)\n\n*14 active bugs from S116 + 8 new bugs found in S119 CC review (2x P0, 1x P1, 4x P2, 1x P3).*\n\n### BUG-PM-026: tableCodeLength default regressed to 5 (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:101\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Default table code length is 5, but BUG-PM-S81-02 fixed it to 4. With partner config unset, guests enter wrong number of digits.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Change fallback from `return 5` to `return 4`.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-S81-02\n\n### BUG-PM-027: Loyalty/discount UI hidden for normal checkout (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:859, x.jsx:1937,3295\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Loyalty section gated on `showLoginPromptAfterRating` instead of `showLoyaltySection`. Email entry, balance display, and point redemption unavailable until after a dish rating exists (never for fresh cart).\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Use `showLoyaltySection` for checkout loyalty; keep `showLoginPromptAfterRating` only for review nudge.\n\n### BUG-PM-028: Failed star-rating saves leave dishes permanently locked (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:705,720,725; x.jsx:2039\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Item marked read-only when draftRating > 0, but async save can fail. Nothing clears the draft on failure, so user cannot retry.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Roll back draft rating on failure, or only lock from confirmed `reviewedItems`.\n\n### BUG-PM-029: Table-code auto-verify cannot retry same code after failure (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:174,184\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `lastSentVerifyCodeRef` never cleared on error or after cooldown unlock. Transient API failure forces guest to change digits to retry.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Clear `lastSentVerifyCodeRef` on failed verification, on unlock, and when input becomes incomplete.\n\n### BUG-PM-030: Review-reward banner shows before any dish is reviewable (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:386\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** \"├ÉΓÇö├É┬░ ├É┬╛├æΓÇÜ├É┬╖├æΓÇ╣├É┬▓ +N\" hint shows when `myOrders.length > 0` regardless of order status. Guests see reward prompt before anything is ready/served.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Gate banner on ready/served statuses + `reviewableItems.length > 0`.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-021\n\n### BUG-PM-031: Cart can still be closed during order submission (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:464, x.jsx:3269\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Close button active while `isSubmitting`. Drawer also closes unconditionally. Can hide in-flight errors.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Disable close button and block drawer close while `isSubmitting`.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-034 (S85)\n\n### BUG-PM-032: Order-status differentiation regressed (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:240\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `getSafeStatus()` missing `accepted` fallback. Render paths ignore `status.icon`. Sent/accepted/cooking/ready collapse into near-identical text.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Add `accepted` to fallback map. Render `{icon} {label}` in all badge locations.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-019\n\n### BUG-PM-033: Scroll position not reset after table verification (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:136\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `isTableVerified` effect only resets attempt counters, scroll-to-top fix is gone. Drawer stays stranded at bottom after code entry.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Restore scroll reset using `prevTableVerifiedRef` and nearest scrollable ancestor.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-S81-03\n\n### BUG-PM-034-R: Guest code leaked back into drawer header (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:274,281\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `#guestCode` appended to \"├ÉΓÇÖ├æΓÇ╣:\" label, exposing internal identifier even when `hallGuestCodeEnabled` is off.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Show code only in dedicated waiter-code block.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-020\n\n### BUG-PM-035: Verified-table block regresses mobile UX (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:1046,1007,1056\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Duplicate \"├É┬í├æΓÇÜ├É┬╛├É┬╗ ├É┬┐├É┬╛├É┬┤├æΓÇÜ├É┬▓├É┬╡├æΓé¼├É┬╢├É┬┤├É┬╡├É┬╜\" header after verification. Info buttons are tiny icon-only touch targets (< 44px).\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Restore `shouldShowOnlineOrderBlock` logic. Replace icon-only info controls with 44px labeled buttons.\n- **├É┬á├É┬╡├É┬│├æΓé¼├É┬╡├æ┬ü├æ┬ü├É┬╕├æ┬Å:** BUG-PM-008, BUG-PM-S81-07\n\n### BUG-PM-036: Loyalty amounts bypass app localization (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:398,922,925\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Hard-coded `toLocaleString('ru-RU')` and `├óΓÇÜ┬╕` instead of `formatPrice`. Wrong currency/locale for non-Russian/non-tenge partners.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Use same formatter/locale as rest of page.\n\n### BUG-PM-037: Reward email flow reports success without validation (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:514,520\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Accepts any non-empty string, toasts \"Email saved!\" immediately. Invalid email or failed loyalty lookup still shows success.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Validate email format, await persistence result, show error if failed.\n\n### BUG-PM-038: Submit-error copy says \"order saved\" when it may not be (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:1216, x.jsx:2591,2919\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Error subtitle always says \"├ÉΓÇÖ├É┬░├æ╦å ├É┬╖├É┬░├É┬║├É┬░├É┬╖ ├æ┬ü├É┬╛├æΓÇª├æΓé¼├É┬░├É┬╜├É┬╡├É┬╜. ├É┼╕├É┬╛├É┬┐├æΓé¼├É┬╛├É┬▒├æ╞Æ├É┬╣├æΓÇÜ├É┬╡ ├æ┬ü├É┬╜├É┬╛├É┬▓├É┬░\" but submit may have failed completely. Misleads guest.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Use neutral retry text, or pass explicit error type.\n\n### BUG-PM-039: 8-digit table codes overflow narrow phones (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S116 (Codex review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:100,1074\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Config allows up to 8 slots, but fixed `w-9` boxes + `gap-2` exceeds 320px viewport.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Make slot width/gap responsive, or switch to single-input layout for longer codes.\n\n### BUG-PM-040: Loyalty points debited before order creation ├óΓé¼ΓÇ¥ no rollback on failure (P0)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** x.jsx:2443-2455, x.jsx:2817-2829\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** In both `processHallOrder` and pickup/delivery flow, `LoyaltyTransaction` (redeem) and `LoyaltyAccount.update` (balance decrement) execute BEFORE `Order.create`. If order creation throws, points are permanently lost ├óΓé¼ΓÇ¥ catch block only sets `submitError`, never re-credits.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Move points deduction to after `Order.create` succeeds, or add compensating re-credit in catch block.\n\n### BUG-PM-041: Polling timer leak in useTableSession after cleanup (P0)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** useTableSession.jsx:670-685\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `scheduleNext()` creates recursive `setTimeout` chain. Cleanup sets `cancelled=true` and `clearTimeout(intervalId)`, but if `pollSessionData()` is mid-execution during cleanup, `scheduleNext` inside the callback fires, registering a new timeout the cleanup can't clear. Orphaned polling causes spurious state updates on stale components.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Guard `scheduleNext` with `if (cancelled) return` before scheduling next poll.\n\n### BUG-PM-042: isBillOnCooldown crashes in restricted environments (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** x.jsx:283-288\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `isBillOnCooldown()` calls `localStorage.getItem()` without try/catch. In private/incognito mode or strict security policies, `localStorage` access can throw. Called inside `useEffect` at x.jsx:2256 ├óΓé¼ΓÇ¥ unhandled exception crashes the component.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Add try/catch with `return false` fallback inside `isBillOnCooldown`.\n\n### BUG-PM-043: formatOrderTime and OrderStatusScreen.formatPrice hardcode ru-RU locale (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** x.jsx:973, x.jsx:1206\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `formatOrderTime` uses `d.toLocaleTimeString(\"ru-RU\", ...)` and `OrderStatusScreen.formatPrice` uses `num.toLocaleString(\"ru-RU\")`, ignoring active `lang` state. Wrong locale for non-Russian partners.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Pass `lang` or the parent's `formatPrice` as prop to `OrderStatusScreen`. Make `formatOrderTime` locale-aware.\n- **├É┬í├É┬▓├æ┬Å├É┬╖├É┬░├É┬╜├É┬╛:** BUG-PM-036 (same pattern in CartView)\n\n### BUG-PM-044: loyalty_redeem_rate falsy-coalescing shows wrong monetary value (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:925\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `(partner?.loyalty_redeem_rate || 1)` treats rate of `0` as falsy, falls back to `1`. Partner with explicit `loyalty_redeem_rate = 0` shows inflated value to guests.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Use `??` (nullish coalescing) instead of `||`: `(partner?.loyalty_redeem_rate ?? 1)`.\n\n### BUG-PM-045: console.log left in production order submission paths (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** x.jsx:2589, x.jsx:2917\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Two `console.log(\"Order created\", order?.id)` calls remain in successful order submission paths (hall and pickup/delivery). Minor information leak, violates no-debug-log rule.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Remove both `console.log` calls.\n\n### BUG-PM-046: Redirect banner setTimeout not cleaned up on unmount (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** x.jsx:1871\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** `setTimeout(() => setRedirectBanner(null), 5000)` inside `useEffect` with no cleanup. If component unmounts or deps change within 5s, the stale timer fires `setRedirectBanner(null)` on an unmounted component ├óΓé¼ΓÇ¥ React dev warning.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Store timer ID and return cleanup function, same pattern as `viewTransitionTimerRef`.\n\n### BUG-PM-047: Multiple interactive elements missing aria-label (P3)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P3\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S119 (CC review)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx:424,449-450,1011,1060; MenuView.jsx:104,111,117\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Icon-only buttons (call-waiter bell, name editor ├ó┼ôΓÇ£/├ó┼ôΓÇó, info ├óΓÇ£╦£ buttons, list-mode add/stepper buttons) use `title` instead of `aria-label` or have no accessible label at all. Screen readers and mobile VoiceOver can't announce button purpose.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Add `aria-label` to all icon-only interactive elements. List-mode buttons should match tile-mode which already has proper labels.\n\n---\n\n## Fixed Bugs (├É┬╕├æ┬ü├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜├æΓÇ╣)\n\n### BUG-PM-023: reviewedItems.has() without null guard (P0) ├óΓé¼ΓÇ¥ FIXED S116\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S79 review (pre-existing from S74), fixed S116\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx, Mode 2 order render\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** If `reviewedItems` prop is undefined, calling `.has()` crashes the render\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `safeReviewedItems = reviewedItems || new Set()` in safe prop defaults block. All `.has()` calls use safeReviewedItems.\n\n### BUG-PM-024: loyaltyAccount.balance without null guard (P0) ├óΓé¼ΓÇ¥ FIXED S116\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S79 review (pre-existing from S74), fixed S116\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx, loyalty section\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** If `loyaltyAccount.balance` is undefined/null, `.toLocaleString()` crashes\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Wrapped all `loyaltyAccount.balance` usages with `Number(loyaltyAccount.balance || 0)`.\n\n### BUG-PM-025: draftRatings prop without null guard (P1) ├óΓé¼ΓÇ¥ FIXED S116\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S79 review (pre-existing from S74), fixed S116\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** CartView.jsx, Mode 2 order render\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** If `draftRatings` is undefined, accessing `draftRatings[itemId]` crashes\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `safeDraftRatings = draftRatings || {}` in safe prop defaults block. All `draftRatings[itemId]` uses safeDraftRatings.\n\n### BUG-PM-S87-03: CTA button \"Send to waiter\" looks active when disabled (P2) ├óΓé¼ΓÇ¥ FIXED S87\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S87 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `CartView.jsx` ├óΓé¼ΓÇ¥ submit button at bottom of cart drawer\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Button always shows `bg-green-600` regardless of disabled state. When `isTableVerified === false`, button looks clickable (green) but does nothing. Confusing UX.\n- **Root cause:** `className=\"w-full bg-green-600 hover:bg-green-700\"` was unconditional ├óΓé¼ΓÇ¥ no visual change for disabled state.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Conditional className: `isTableVerified === false` ├óΓÇáΓÇÖ `bg-gray-300 text-gray-500 cursor-not-allowed hover:bg-gray-300`. Added hint text `tr('cart.enter_table_code_hint', '├ÉΓÇÖ├É┬▓├É┬╡├É┬┤├É┬╕├æΓÇÜ├É┬╡ ├É┬║├É┬╛├É┬┤ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░ ├æΓÇí├æΓÇÜ├É┬╛├É┬▒├æΓÇ╣ ├É┬╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╕├æΓÇÜ├æ┼Æ ├É┬╖├É┬░├É┬║├É┬░├É┬╖')` below button when disabled.\n- **RELEASE:** pending (parallel mode, pre-merge)\n\n### BUG-PM-028: Table code input shows 5 boxes for 4-digit codes (S81-02, P0) ├óΓé¼ΓÇ¥ FIXED S82\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S81 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `CartView.jsx` ├óΓé¼ΓÇ¥ tableCodeLength useMemo\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** OTP input renders 5 boxes but real codes are 4 digits ├óΓÇáΓÇÖ auto-verify never fires ├óΓÇáΓÇÖ order blocked.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** tableCodeLength default 5├óΓÇáΓÇÖ4 (reads from partner.table_code_length if set).\n- **RELEASE:** `260305-03 CartView RELEASE.jsx` | **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ:** `e9050d3`\n\n### BUG-PM-029: No visible feedback after Hall order sent (S81-17, P1) ├óΓé¼ΓÇ¥ FIXED S82\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S81 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ processHallOrder()\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Toast appeared for 2s (too short); on failure `setSubmitError` invisible in drawer.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Toast duration 2s├óΓÇáΓÇÖ4s; added `toast.error` in catch; cart cleared on success.\n- **RELEASE:** `260305-05 x RELEASE.jsx` | **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ:** `02ae5e5`\n\n### BUG-PM-030: Pickup/Delivery checkout used fullscreen instead of drawer (S81-14, P0) ├óΓé¼ΓÇ¥ FIXED S82\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S81 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ handleCheckoutClick, StickyCartBar for pickup/delivery\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** ├É┬¥├É┬░├É┬╢├É┬░├æΓÇÜ├É┬╕├É┬╡ ├é┬½├É┼╛├æΓÇ₧├É┬╛├æΓé¼├É┬╝├É┬╕├æΓÇÜ├æ┼Æ├é┬╗ ├É┬▓ ├æΓé¼├É┬╡├É┬╢├É┬╕├É┬╝├É┬░├æΓÇª ├É┬í├É┬░├É┬╝├É┬╛├É┬▓├æΓÇ╣├É┬▓├É┬╛├É┬╖/├ÉΓÇ¥├É┬╛├æ┬ü├æΓÇÜ├É┬░├É┬▓├É┬║├É┬░ ├É┬╛├æΓÇÜ├É┬║├æΓé¼├æΓÇ╣├É┬▓├É┬░├É┬╗├É┬╛ fullscreen checkout (├É┬╛├æΓÇÜ├É┬┤├É┬╡├É┬╗├æ┼Æ├É┬╜├æΓÇ╣├É┬╣ ├æ┬ì├É┬║├æΓé¼├É┬░├É┬╜) ├É┬▓├É┬╝├É┬╡├æ┬ü├æΓÇÜ├É┬╛ bottom drawer. ├É┬¥├É┬╡├æ┬ü├É┬╛├É┬│├É┬╗├É┬░├æ┬ü├É┬╛├É┬▓├É┬░├É┬╜├É┬╜├æΓÇ╣├É┬╣ UX ├æ┬ü ├æΓé¼├É┬╡├É┬╢├É┬╕├É┬╝├É┬╛├É┬╝ ├é┬½├ÉΓÇÖ ├É┬╖├É┬░├É┬╗├É┬╡├é┬╗.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** ├ÉΓÇ¥├É┬╛├É┬▒├É┬░├É┬▓├É┬╗├É┬╡├É┬╜ `PickupDeliveryCheckoutContent` ├óΓé¼ΓÇ¥ drawer-├É┬║├É┬╛├É┬╜├æΓÇÜ├É┬╡├É┬╜├æΓÇÜ ├æ┬ü ├É┬┐├É┬╛├É┬╗├æ┬Å├É┬╝├É┬╕: ├É╦£├É┬╝├æ┬Å + ├É┬ó├É┬╡├É┬╗├É┬╡├æΓÇ₧├É┬╛├É┬╜ (├É┬╛├É┬▒├æ┬Å├É┬╖├É┬░├æΓÇÜ├É┬╡├É┬╗├æ┼Æ├É┬╜├æΓÇ╣├É┬╡) + ├É┬É├É┬┤├æΓé¼├É┬╡├æ┬ü (├æΓÇÜ├É┬╛├É┬╗├æ┼Æ├É┬║├É┬╛ ├ÉΓÇ¥├É┬╛├æ┬ü├æΓÇÜ├É┬░├É┬▓├É┬║├É┬░) + ├É┼í├É┬╛├É┬╝├É┬╝├É┬╡├É┬╜├æΓÇÜ├É┬░├æΓé¼├É┬╕├É┬╣ + Total + CTA. `handleCheckoutClick` ├æΓÇÜ├É┬╡├É┬┐├É┬╡├æΓé¼├æ┼Æ ├æ╞Æ├æ┬ü├æΓÇÜ├É┬░├É┬╜├É┬░├É┬▓├É┬╗├É┬╕├É┬▓├É┬░├É┬╡├æΓÇÜ `drawerMode = 'checkout'` ├É┬▓├É┬╝├É┬╡├æ┬ü├æΓÇÜ├É┬╛ `setView(\"checkout\")`. Drawer ├É┬╕├æ┬ü├É┬┐├É┬╛├É┬╗├æ┼Æ├É┬╖├æ╞Æ├É┬╡├æΓÇÜ `SNAP_FULL` (90% ├É┬▓├æΓÇ╣├æ┬ü├É┬╛├æΓÇÜ├æΓÇ╣) ├É┬┤├É┬╗├æ┬Å ├É┬╛├æΓÇÜ├É┬╛├É┬▒├æΓé¼├É┬░├É┬╢├É┬╡├É┬╜├É┬╕├æ┬Å ├æΓÇ₧├É┬╛├æΓé¼├É┬╝├æΓÇ╣. Drawer ├É┬╜├É┬╡├É┬╗├æ┼Æ├É┬╖├æ┬Å ├É┬╖├É┬░├É┬║├æΓé¼├æΓÇ╣├æΓÇÜ├æ┼Æ ├É┬▓├É┬╛ ├É┬▓├æΓé¼├É┬╡├É┬╝├æ┬Å submit (`isSubmitting` guard). ├É┼╛├æ╦å├É┬╕├É┬▒├É┬║├É┬╕ ├É┬╛├æΓÇí├É┬╕├æΓÇ░├É┬░├æ┼╜├æΓÇÜ├æ┬ü├æ┬Å ├É┬┐├æΓé¼├É┬╕ ├É┬╖├É┬░├É┬║├æΓé¼├æΓÇ╣├æΓÇÜ├É┬╕├É┬╕ (`onOpenChange`).\n- **RELEASE:** `260305-05 x RELEASE.jsx` | **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ:** `02ae5e5`\n\n### BUG-PM-031: Duplicate restaurant name in header (S81-07, P1) ├óΓé¼ΓÇ¥ FIXED S84\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S84 Quick Test ├óΓé¼ΓÇ¥ regression from S79 (logo addition)\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ PublicMenuHeader + logo+name block\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Restaurant name shown twice: (1) in PublicMenuHeader h1, (2) in logo+name block below.\n- **Root cause:** S79 patch added logo+name block but didn't suppress the name already shown by PublicMenuHeader.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Pass `partner={showLogo ? { ...partner, name: undefined } : partner}` to PublicMenuHeader. When logo block shows the name, PublicMenuHeader gets partner without name field.\n- **RELEASE:** `260306-00 x RELEASE.jsx` | **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ├æΓÇ╣:** `a89ce7c`, `03b2eb9`\n\n### BUG-PM-032: CTA button ├é┬½├É┼╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╕├æΓÇÜ├æ┼Æ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ├é┬╗ below viewport (S81-03, P0) ├óΓé¼ΓÇ¥ FIXED S84\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S84 Quick Test ├óΓé¼ΓÇ¥ regression: S82 fix (SNAP_FULL) was not enough\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ cart drawer structure\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** \"Send to Waiter\" button at y├óΓÇ░╦å729 (viewport 736px), not visible without manual scroll.\n- **Root cause:** RELEASE removed the `overflow-y-auto` wrapper around CartView (flex-col DrawerContent without scroll container). `sticky bottom-0` in CartView requires a scroll container parent.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `<div className=\"flex-1 overflow-y-auto min-h-0\">` wrapper around CartView (and PickupDeliveryCheckoutContent) inside DrawerContent. Also added `isSubmitting` guard to `onOpenChange`.\n- **RELEASE:** `260306-00 x RELEASE.jsx` | **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ├æΓÇ╣:** `32d7e8a`, `03b2eb9`\n\n### BUG-PM-033: Drawer drag handle swipe-to-close not working (S81-01, P0) ├óΓé¼ΓÇ¥ FIXED S84\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S84 Quick Test ├óΓé¼ΓÇ¥ regression: S82 `setActiveSnapPoint(null)` approach didn't work\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ Drawer component\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Swipe down on drag handle (gray bar at top of drawer) did not close drawer.\n- **Root cause:** `setActiveSnapPoint(null)` relied on vaul snap point API that may not fire consistently. No fallback touch handler.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added custom drag handle div with `onTouchStart`/`onTouchEnd` handlers. Swipe >80px triggers close. Added `isSubmitting` guard. Applied to both cart and checkout drawers.\n- **RELEASE:** `260306-00 x RELEASE.jsx` | **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ├æΓÇ╣:** `270ad06`, `03b2eb9`\n\n### BUG-PM-034: Cart drawer setActiveSnapPoint missing !isSubmitting guard (P1) ├óΓé¼ΓÇ¥ FIXED S85\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S85 ├óΓé¼ΓÇ¥ found during task-260306-003505 verification\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ cart Drawer setActiveSnapPoint handler\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Cart drawer could be closed via vaul snap API swipe even during order submission (vaul internal swipe). Inconsistency with checkout drawer which already had the guard.\n- **Root cause:** Cart drawer `setActiveSnapPoint` used `if (sp === null)` without `!isSubmitting`, unlike checkout drawer which used `if (sp === null && !isSubmitting)`.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `&& !isSubmitting` to cart drawer `setActiveSnapPoint` condition + changed `else` to `else if (sp !== null)` for symmetry with checkout drawer.\n- **RELEASE:** `260306-01 x RELEASE.jsx`\n\n### BUG-PM-S87-01: :::ARCHIVED::: marker visible to guests in dish descriptions (P1) ├óΓé¼ΓÇ¥ FIXED S87\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S87 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ isDishArchived(), getCleanDescription(), getDishDescription()\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Guests see raw `:::ARCHIVED:::` text in dish descriptions (e.g., \"├É┬┐├æΓé¼├É┬╛├É┬┐├æΓé¼├É┬╛├É┬╗ :::ARCHIVED:::\").\n- **Root cause:** IS_ARCHIVED_TAG was lowercase `:::archived:::` but actual data has uppercase `:::ARCHIVED:::`. String.includes() and String.replace() are case-sensitive.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** isDishArchived() now uses `.toLowerCase().includes()`. getCleanDescription() now uses `/:::archived:::/gi` regex. getDishDescription() now also cleans translated descriptions.\n- **RELEASE:** `260306-01 x RELEASE.jsx`\n\n### BUG-PM-S87-02: Raw i18n keys visible after order submission (P1) ├óΓé¼ΓÇ¥ FIXED S87\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S87 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ OrderConfirmationScreen, StickyCartBar labels\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** After submitting order, confirmation screen shows raw keys like `confirmation.title`, `CART.MY_BILL` instead of Russian text.\n- **Root cause:** `t()` returns the key string when translation is missing. `|| \"fallback\"` pattern doesn't catch it because the key string is truthy. OrderConfirmationScreen used bare `t()` without fallbacks.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `tr()` helper to both x.jsx main component and OrderConfirmationScreen (same pattern as CartView). All confirmation.* keys and cart.* button labels now use `tr(\"key\", \"Russian fallback\")`. 28 i18n keys added to `i18n_pending.csv`.\n- **RELEASE:** `260306-01 x RELEASE.jsx`\n\n### BUG-PM-026: Drawer pull-down swipe doesn't close drawer (S81-01, P1) ├óΓé¼ΓÇ¥ FIXED S82\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S81 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ Drawer setActiveSnapPoint\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Swipe down on drag handle did not close the drawer.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** `setActiveSnapPoint` handler: `if (sp === null) setDrawerMode(null); else setDrawerSnapPoint(sp);`\n- **RELEASE:** `260305-05 x RELEASE.jsx`\n\n### BUG-PM-027: CTA button hidden at default drawer height (S81-03, P1) ├óΓé¼ΓÇ¥ FIXED S82\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** S81 testing\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` ├óΓé¼ΓÇ¥ drawer snap point auto-grow\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Drawer at SNAP_MID (60%); CTA outside visible area with 1-4 items.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Auto-expand to SNAP_FULL when `cart.length > 0` (was `> 4`).\n- **RELEASE:** `260305-05 x RELEASE.jsx`\n\n### BUG-PM-018: Confirmation screen shows \"├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖ ├É┬┐├æΓé¼├É┬╕├É┬╜├æ┬Å├æΓÇÜ!\" before waiter accepts (P0)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0 (wrong semantics breaks user trust)\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 74 (CC+GPT UX analysis)\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** After tapping \"├É┼╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╕├æΓÇÜ├æ┼Æ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ\", guest sees \"├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖ ├É┬┐├æΓé¼├É┬╕├É┬╜├æ┬Å├æΓÇÜ!\" ├óΓé¼ΓÇ¥ implies the waiter already accepted, which is false. The order was only sent.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Confirmation title now uses mode-dependent text: hall ├óΓÇáΓÇÖ \"├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖ ├É┬╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ├æ╞Æ\", pickup/delivery ├óΓÇáΓÇÖ \"├ÉΓÇö├É┬░├É┬║├É┬░├É┬╖ ├É┬╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜\". Added subtext: \"├É┬í├æΓÇÜ├É┬░├æΓÇÜ├æ╞Æ├æ┬ü ├É┬╛├É┬▒├É┬╜├É┬╛├É┬▓├É┬╕├æΓÇÜ├æ┬ü├æ┬Å, ├É┬║├É┬╛├É┬│├É┬┤├É┬░ ├É┬╛├æΓÇ₧├É┬╕├æΓÇá├É┬╕├É┬░├É┬╜├æΓÇÜ ├É┬┐├æΓé¼├É┬╕├É┬╝├É┬╡├æΓÇÜ ├É┬╖├É┬░├É┬║├É┬░├É┬╖\". New `tr()` helper added to `OrderConfirmationScreen` for safe fallbacks.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` (OrderConfirmationScreen)\n- **RELEASE:** `260304-00 x RELEASE.jsx`\n\n### BUG-PM-019: No visual status differentiation in guest \"├É┼ô├É┬╛├É┬╕ ├É┬╖├É┬░├É┬║├É┬░├É┬╖├æΓÇ╣\" (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 74\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** All orders showed generic blue badge without icon. Guest couldn't distinguish sent/accepted/cooking/ready status.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Enhanced `getSafeStatus()` with full STATUS_MAP: ├░┼╕┼╕┬í ├É┼╛├æΓÇÜ├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜ (new), ├░┼╕┼╕┬ó ├É┼╕├æΓé¼├É┬╕├É┬╜├æ┬Å├æΓÇÜ (accepted), ├░┼╕ΓÇ¥┬╡ ├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓├É┬╕├æΓÇÜ├æ┬ü├æ┬Å (cooking), ├ó┼ôΓÇª ├ÉΓÇ£├É┬╛├æΓÇÜ├É┬╛├É┬▓ (ready). Badge now shows `{icon} {label}` instead of just `{label}`.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `CartView.jsx`\n- **RELEASE:** `260304-00 CartView RELEASE.jsx`\n\n### BUG-PM-020: Session ID \"#1313\" shown to guest in drawer header (P2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P2\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 74\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Guest sees \"├ÉΓÇÖ├æΓÇ╣: ├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ 2 #1313\" ├óΓé¼ΓÇ¥ the `#1313` is a meaningless session code from localStorage.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** `guestDisplay` now uses only `guestBaseName` (name or \"├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ N\"). Session code logged to `console.debug` for debugging only.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `CartView.jsx`\n- **RELEASE:** `260304-00 CartView RELEASE.jsx`\n\n### BUG-PM-021: Rating banner shows before any order is ready (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 74\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** \"├ÉΓÇö├É┬░ ├É┬╛├æΓÇÜ├É┬╖├æΓÇ╣├É┬▓ +10 ├É┬▒├É┬░├É┬╗├É┬╗├É┬╛├É┬▓\" banner appears immediately when drawer opens, even if no order has been delivered. Premature and confusing.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** `shouldShowReviewRewardHint` now checks `hasReadyOrders` (at least one order with finish/ready/done/served status) AND `reviewableItems.length > 0`. Inline confirmation \"├É┬í├É┬┐├É┬░├æ┬ü├É┬╕├É┬▒├É┬╛! +N├ÉΓÇÿ\" next to stars replaces generic \"├ó┼ôΓÇ£\" checkmark when loyalty is active.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `CartView.jsx`\n- **RELEASE:** `260304-00 CartView RELEASE.jsx`\n\n### BUG-PM-022: Drawer opens at wrong height ├óΓé¼ΓÇ¥ header not visible (P0)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 74\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Cart drawer opens at wrong snap position ├óΓé¼ΓÇ¥ only bottom portion visible, header \"├É┬í├æΓÇÜ├É┬╛├É┬╗ / ├ÉΓÇ£├É┬╛├æ┬ü├æΓÇÜ├æ┼Æ / ├ó┼ôΓÇó\" is offscreen.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `snapPoints={[0.85]}` to Drawer component to force 85% viewport height. Added `paddingBottom: env(safe-area-inset-bottom)` for mobile safe area support.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx`\n- **RELEASE:** `260304-00 x RELEASE.jsx`\n\n### BUG-PM-013: track_order button shows dish popup instead of OrderStatusScreen (GAP-02) (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 71 (├É┬╜├É┬░├É┬╣├É┬┤├É┬╡├É┬╜ Arman ├É┬┐├æΓé¼├É┬╕ ├æΓÇÜ├É┬╡├æ┬ü├æΓÇÜ├É┬╕├æΓé¼├É┬╛├É┬▓├É┬░├É┬╜├É┬╕├É┬╕ 260303-03)\n- **├É┬í├É┬╕├É┬╝├É┬┐├æΓÇÜ├É┬╛├É┬╝:** Clicking \"Track Order\" on OrderConfirmationScreen briefly shows a \"├É┬í├æΓÇÜ├É┬╡├É┬╣├É┬║\" product popup, then returns to menu. OrderStatusScreen never appears.\n- **Root cause:** `CONFIRMATION_AUTO_DISMISS_MS = 10000` (10s timer). The auto-dismiss fires `setView(\"menu\")` + `setConfirmationData(null)`, removing the full-screen confirmation overlay. A pending touch/click event from the user then falls through to the menu grid underneath, hitting a dish card (├É┬í├æΓÇÜ├É┬╡├É┬╣├É┬║) which opens `DishReviewsModal`. This is a ghost-click race condition on mobile.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Removed auto-dismiss timer entirely. The confirmation screen has 3 explicit navigation buttons (back to menu, my orders, track order) ├óΓé¼ΓÇ¥ auto-dismiss is unnecessary and harmful. Removed `CONFIRMATION_AUTO_DISMISS_MS` constant, `confirmationTimerRef` ref, all timer setup/cleanup code.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` (PublicMenu main page)\n- **RELEASE:** `260303-04 x RELEASE.jsx`\n\n### BUG-PM-012: /orderstatus returns 404 ├óΓé¼ΓÇ¥ B44 routing doesn't register page (GAP-02) (P1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 71 (├É┬╜├É┬░├É┬╣├É┬┤├É┬╡├É┬╜ ├É┬┐├æΓé¼├É┬╕ ├É┬┤├É┬╡├É┬┐├É┬╗├É┬╛├É┬╡ GAP-02)\n- **Root cause:** B44 platform routing is managed internally ├óΓé¼ΓÇ¥ simply adding a `pages/orderstatus.jsx` file and updating `PUBLIC_ROUTES` in Layout.js does not register a route. The SPA route `/orderstatus` returned \"Page Not Found\". The `track_order` button in `OrderConfirmationScreen` used `window.location.href = '/orderstatus?token=...'` which triggered a full page navigation to a non-existent route.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Embedded `OrderStatusScreen` as a view state inside `x.jsx` (like `OrderConfirmationScreen`). View state expanded to `menu|checkout|confirmation|orderstatus`. Button now sets `setView(\"orderstatus\")` instead of navigating. Sub-reviewer fixes: P0 timer leak after terminal, P1 token regex widened, P1 token generator fixed (substring(2,10)), P1 staleTime added, P1 pollTimerRef├óΓÇáΓÇÖclosure, P1 orderStatusToken cleared in dismissConfirmation.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` (PublicMenu main page)\n- **├É┼í├É┬╛├É┬╝├É┬╝├É┬╕├æΓÇÜ:** `f080b62`\n- **RELEASE:** `260303-03 x RELEASE.jsx`\n\n### BUG-PM-011: Active tables expired based on opened_at alone ├óΓé¼ΓÇ¥ activity guard missing (P0)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 68 (├É┬╜├É┬░├É┬╣├É┬┤├É┬╡├É┬╜ ├É┬┐├æΓé¼├É┬╕ ├É┬░├É┬╜├É┬░├É┬╗├É┬╕├É┬╖├É┬╡ P0-1 ├É┬┐├É┬╡├æΓé¼├É┬╡├É┬┤ ├É┬┤├É┬╡├É┬┐├É┬╗├É┬╛├É┬╡├É┬╝)\n- **Root cause:** `isSessionExpired()` in `sessionHelpers.js` checks only `opened_at`. A table open 8+ hours with recent orders (e.g., `last_activity_at` updated 1 hour ago) would be incorrectly expired. The cleanup logic in STEP 1 and STEP 2 of `restoreSession()` would close an active table and cancel orders.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `hasRecentActivity(session)` helper that checks `last_activity_at || updated_at || opened_at`. Both `isSessionExpired` call sites now use combined condition: `isSessionExpired(s) && !hasRecentActivity(s)` ├óΓé¼ΓÇ¥ session is expired only if BOTH old `opened_at` AND no recent activity.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `useTableSession.jsx` (lines 11-18, 293, 332)\n- **RELEASE:** `260302-06 useTableSession RELEASE.jsx`\n\n### BUG-PM-009: Expired sessions reused ├óΓé¼ΓÇ¥ old orders leak into new visits (P0-1)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 65 (├É┬╜├É┬░├É┬╣├É┬┤├É┬╡├É┬╜ Arman), Session 66 (├É┬╕├æ┬ü├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜)\n- **Root cause:** `useTableSession.restoreSession()` called `isSessionExpired()` to skip expired sessions, but never closed them in DB. Old sessions stayed `status: 'open'` forever. When a new guest scanned QR, `getOrCreateSession` found the old open session and reused it ├óΓé¼ΓÇ¥ new guest saw all historical orders.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** Added `closeExpiredSessionInDB()` helper: closes session (`status: expired`) + cancels unprocessed orders (`new` ├óΓÇáΓÇÖ `cancelled`). Called in STEP 1 (saved session) and STEP 2 (DB query) of `restoreSession()`.\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `useTableSession.jsx`\n- **RELEASE:** `260302-00 useTableSession RELEASE.jsx`\n\n### BUG-PM-010: Order created without valid table_session (P0-2)\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P0\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 65 (├É┬┤├É┬╕├É┬░├É┬│├É┬╜├É┬╛├É┬╖), Session 66 (├É┬╕├æ┬ü├É┬┐├æΓé¼├É┬░├É┬▓├É┬╗├É┬╡├É┬╜)\n- **Root cause:** `processHallOrder()` used `tableSession?.id || null` for `table_session` field. If session was expired or missing, order was created with `table_session: null`. This broke session-based filtering ├óΓé¼ΓÇ¥ the order was invisible to the current session or leaked into all views.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** `handleSubmitOrder` now validates session before proceeding: if expired ├óΓÇáΓÇÖ close in DB + create new. Hard guard rejects if no valid session. `processHallOrder` receives `validatedSession` parameter (no stale closure).\n- **├É┬ñ├É┬░├É┬╣├É┬╗:** `x.jsx` (PublicMenu main page)\n- **RELEASE:** `260302-00 x RELEASE.txt`\n\n### BUG-PM-006: Drawer ├É┬┐├É┬╛├æ┬ü├É┬╗├É┬╡ ├É┬┐├É┬╛├É┬┤├æΓÇÜ├É┬▓├É┬╡├æΓé¼├É┬╢├É┬┤├É┬╡├É┬╜├É┬╕├æ┬Å ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░ ├É┬╛├æΓÇÜ├É┬║├æΓé¼├æΓÇ╣├É┬▓├É┬░├É┬╡├æΓÇÜ├æ┬ü├æ┬Å ├É┬┐├æΓé¼├É┬╛├æ┬ü├É┬║├æΓé¼├É┬╛├É┬╗├É┬╗├É┬╗├É┬╡├É┬╜├É┬╜├æΓÇ╣├É┬╝ ├É┬▓├É┬╜├É┬╕├É┬╖\n- **├É┼╕├æΓé¼├É┬╕├É┬╛├æΓé¼├É┬╕├æΓÇÜ├É┬╡├æΓÇÜ:** P1\n- **├É┼í├É┬╛├É┬│├É┬┤├É┬░:** Session 29 (├É┬╜├É┬░├É┬╣├É┬┤├É┬╡├É┬╜ Arman)\n- **Root cause:** ├É┼╕├æΓé¼├É┬╕ ├É┬▓├É┬▓├É┬╛├É┬┤├É┬╡ ├É┬║├É┬╛├É┬┤├É┬░ ├æ┬ü├æΓÇÜ├É┬╛├É┬╗├É┬░ ├É┬▓ ├É┬╜├É┬╕├É┬╢├É┬╜├É┬╡├É┬╣ ├æΓÇí├É┬░├æ┬ü├æΓÇÜ├É┬╕ CartView ├É┬╕ ├æ╞Æ├æ┬ü├É┬┐├É┬╡├æ╦å├É┬╜├É┬╛├É┬╝ ├É┬┐├É┬╛├É┬┤├æΓÇÜ├É┬▓├É┬╡├æΓé¼├É┬╢├É┬┤├É┬╡├É┬╜├É┬╕├É┬╕, drawer ├É┬╛├æ┬ü├æΓÇÜ├É┬░├É┬▓├É┬░├É┬╗├æ┬ü├æ┬Å ├É┬┐├æΓé¼├É┬╛├æ┬ü├É┬║├æΓé¼├É┬╛├É┬╗├É┬╗├É┬╗├É┬╡├É┬╜├É┬╜├æΓÇ╣├É┬╝ ├É┬▓├É┬╜├É┬╕├É┬╖. Scroll position ├É┬╜├É┬╡ ├æ┬ü├É┬▒├æΓé¼├É┬░├æ┬ü├æΓÇ╣├É┬▓├É┬░├É┬╗├æ┬ü├æ┬Å.\n- **├É┬ñ├É┬╕├É┬║├æ┬ü:** `prevTableVerifiedRef` ├É┬╛├æΓÇÜ├æ┬ü├É┬╗├É┬╡├É┬╢├É┬╕├É┬▓├É┬░├É┬╡├æΓÇÜ ├É┬┐├É┬╡├æΓé¼├