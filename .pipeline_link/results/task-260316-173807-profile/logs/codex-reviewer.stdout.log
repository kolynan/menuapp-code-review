{"type":"item.completed","item":{"id":"item_21","type":"command_execution","command":"\"C:\\\\WINDOWS\\\\System32\\\\WindowsPowerShell\\\\v1.0\\\\powershell.exe\" -Command '$i=0; Get-Content '\"'.\\\\pages\\\\Profile\\\\base\\\\profile.jsx' | ForEach-Object { \"'$i++; '\"'{0,4}: {1}' -f \"'$i, $_ }'","aggregated_output":"   1: // ============================================================\r\n   2: // BLOCK 00 в”ңГіО“Г©ВјО“ГҮВҘ IMPORTS & CONSTANTS\r\n   3: // ============================================================\r\n   4: \r\n   5: import React, { useState, useEffect, useRef } from \"react\";\r\n   6: import { useNavigate } from \"react-router-dom\";\r\n   7: import { base44 } from \"@/api/base44Client\";\r\n   8: import { useI18n } from \"@/components/i18n\";\r\n   9: import { Button } from \"@/components/ui/button\";\r\n  10: import { Input } from \"@/components/ui/input\";\r\n  11: import { Label } from \"@/components/ui/label\";\r\n  12: import { Card, CardContent, CardHeader, CardTitle } from \"@/components/ui/card\";\r\n  13: import { ArrowLeft, AlertCircle, Loader2, Check } from \"lucide-react\";\r\n  14: import { toast } from \"sonner\";\r\n  15: import PartnerShell from \"@/components/PartnerShell\";\r\n  16: \r\n  17: const GLOBAL_ADMIN_PARTNER = \"global_admin\";\r\n  18: const BACK_ROUTE = \"/partnerhome\";\r\n  19: \r\n  20: const ROLE_BADGE_CLASSES = {\r\n  21:   admin: \"bg-red-100 text-red-800\",\r\n  22:   partner_owner: \"bg-purple-100 text-purple-800\",\r\n  23:   partner_manager: \"bg-blue-100 text-blue-800\",\r\n  24:   partner_staff: \"bg-green-100 text-green-800\",\r\n  25:   kitchen: \"bg-orange-100 text-orange-800\",\r\n  26: };\r\n  27: \r\n  28: // ============================================================\r\n  29: // BLOCK 01 в”ңГіО“Г©ВјО“ГҮВҘ MAIN COMPONENT\r\n  30: // ============================================================\r\n  31: \r\n  32: /**\r\n  33:  * ProfileContent в”ңГіО“Г©ВјО“ГҮВҘ inner component rendered inside PartnerShell.\r\n  34:  * Loads and displays the current user's profile (name, email, role, restaurant).\r\n  35:  * Allows editing the full name field and saving changes via base44.auth.updateMe().\r\n  36:  */\r\n  37: function ProfileContent() {\r\n  38:   const navigate = useNavigate();\r\n  39:   const { t } = useI18n();\r\n  40: \r\n  41:   // Safe translation with fallback (t() returns key when missing)\r\n  42:   const tr = (key, fallback) => {\r\n  43:     const val = typeof t === \"function\" ? t(key) : \"\";\r\n  44:     if (!val || typeof val !== \"string\") return fallback;\r\n  45:     const norm = val.trim();\r\n  46:     if (norm === key || norm.startsWith(key + \":\")) return fallback;\r\n  47:     return norm;\r\n  48:   };\r\n  49: \r\n  50:   const [user, setUser] = useState(null);\r\n  51:   const [partnerName, setPartnerName] = useState(null);\r\n  52:   const [fullName, setFullName] = useState(\"\");\r\n  53:   const [initialFullName, setInitialFullName] = useState(\"\");\r\n  54:   const [isUserLoading, setIsUserLoading] = useState(true);\r\n  55:   const [isLoadError, setIsLoadError] = useState(false);\r\n  56:   const [isPartnerLoading, setIsPartnerLoading] = useState(false);\r\n  57:   const [saveStatus, setSaveStatus] = useState(\"idle\"); // idle | saving | success\r\n  58:   const timerRef = useRef(null);\r\n  59:   const isMountedRef = useRef(true);\r\n  60: \r\n  61:   // Cleanup timer on unmount\r\n  62:   useEffect(() => {\r\n  63:     return () => {\r\n  64:       isMountedRef.current = false;\r\n  65:       if (timerRef.current) clearTimeout(timerRef.current);\r\n  66:     };\r\n  67:   }, []);\r\n  68: \r\n  69:   // ============================================================\r\n  70:   // BLOCK 02 в”ңГіО“Г©ВјО“ГҮВҘ DATA LOADING\r\n  71:   // ============================================================\r\n  72: \r\n  73:   useEffect(() => {\r\n  74:     let isMounted = true;\r\n  75:     const loadUser = async () => {\r\n  76:       try {\r\n  77:         const userData = await base44.auth.me();\r\n  78:         if (!isMounted) return;\r\n  79:         setUser(userData);\r\n  80:         setFullName((userData.full_name || \"\").trim());\r\n  81:         setInitialFullName((userData.full_name || \"\").trim());\r\n  82: \r\n  83:         if (isMounted) setIsUserLoading(false);\r\n  84: \r\n  85:         // Load partner name if exists\r\n  86:         if (userData.partner && userData.partner !== GLOBAL_ADMIN_PARTNER) {\r\n  87:           if (isMounted) setIsPartnerLoading(true);\r\n  88:           try {\r\n  89:             const partner = await base44.entities.Partner.get(userData.partner);\r\n  90:             if (isMounted && partner) {\r\n  91:               setPartnerName(partner.name);\r\n  92:             }\r\n  93:           } catch (err) {\r\n  94:             // Partner load failed в”ңГіО“Г©ВјО“ГҮВҘ falls back to \"no restaurant\" label\r\n  95:           } finally {\r\n  96:             if (isMounted) setIsPartnerLoading(false);\r\n  97:           }\r\n  98:         }\r\n  99:       } catch (error) {\r\n 100:         if (!isMounted) return;\r\n 101:         setIsLoadError(true);\r\n 102:         setIsUserLoading(false);\r\n 103:       }\r\n 104:     };\r\n 105: \r\n 106:     loadUser();\r\n 107:     return () => { isMounted = false; };\r\n 108:   }, []); // eslint-disable-line react-hooks/exhaustive-deps\r\n 109: \r\n 110:   // ============================================================\r\n 111:   // BLOCK 03 в”ңГіО“Г©ВјО“ГҮВҘ HANDLERS\r\n 112:   // ============================================================\r\n 113: \r\n 114:   const hasChanges = fullName.trim() !== initialFullName;\r\n 115:   const canSave = hasChanges && fullName.trim().length > 0;\r\n 116: \r\n 117:   const handleSave = async () => {\r\n 118:     if (!canSave || saveStatus === \"saving\") return;\r\n 119: \r\n 120:     setSaveStatus(\"saving\");\r\n 121:     try {\r\n 122:       await base44.auth.updateMe({ full_name: fullName.trim() });\r\n 123:       if (!isMountedRef.current) return;\r\n 124:       setInitialFullName(fullName.trim());\r\n 125:       setSaveStatus(\"success\");\r\n 126:       toast.success(tr(\"toast.saved\", \"в”ңГүв”¬Гӯв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•ӣ\"), { id: \"mm1\" });\r\n 127: \r\n 128:       timerRef.current = setTimeout(() => {\r\n 129:         if (isMountedRef.current) setSaveStatus(\"idle\");\r\n 130:       }, 2000);\r\n 131:     } catch (error) {\r\n 132:       if (!isMountedRef.current) return;\r\n 133:       toast.error(tr(\"toast.error\", \"в”ңГүв”јв•ӣв”ңГҰв•ҰГҘв”ңГүв”¬в••в”ңГүв”¬в–’в”ңГүв”¬в•‘в”ңГүв”¬в–‘\"), { id: \"mm1\" });\r\n 134:       setSaveStatus(\"idle\");\r\n 135:     }\r\n 136:   };\r\n 137: \r\n 138:   const getRoleLabel = (userRole) => {\r\n 139:     return tr(`profile.role.${userRole}`, userRole);\r\n 140:   };\r\n 141: \r\n 142:   const getRoleBadgeClass = (userRole) => {\r\n 143:     return ROLE_BADGE_CLASSES[userRole] || \"bg-gray-100 text-gray-800\";\r\n 144:   };\r\n 145: \r\n 146:   // ============================================================\r\n 147:   // BLOCK 04 в”ңГіО“Г©ВјО“ГҮВҘ LOADING STATE\r\n 148:   // ============================================================\r\n 149: \r\n 150:   if (isUserLoading) {\r\n 151:     return (\r\n 152:       <div className=\"min-h-screen bg-gray-50 flex items-center justify-center\">\r\n 153:         <div className=\"flex items-center gap-2 text-gray-500\" role=\"status\" aria-live=\"polite\">\r\n 154:           <Loader2 className=\"w-5 h-5 animate-spin\" />\r\n 155:           <span>{tr(\"common.loading\", \"в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в•‘в”ңГүв”¬в–‘...\")}</span>\r\n 156:         </div>\r\n 157:       </div>\r\n 158:     );\r\n 159:   }\r\n 160: \r\n 161:   if (isLoadError) {\r\n 162:     return (\r\n 163:       <div className=\"min-h-screen bg-gray-50 flex flex-col items-center justify-center gap-4 p-4\">\r\n 164:         <AlertCircle className=\"w-10 h-10 text-red-400\" />\r\n 165:         <p className=\"text-gray-600 text-center\">{tr(\"profile.load_error\", \"в”ңГүв”¬ВҘв”ңГүв”¬в•Ў в”ңГҰв•һГҶв”ңГүв”¬в”Өв”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰв”јГҶ в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в”җв”ңГҰО“Г©Вјв”ңГүв”¬в•ӣв”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГүв”¬в•—в”ңГҰв”јГҶ\")}</p>\r\n 166:         <Button\r\n 167:           variant=\"outline\"\r\n 168:           onClick={() => navigate(BACK_ROUTE)}\r\n 169:           className=\"min-h-[44px] min-w-[44px]\"\r\n 170:         >\r\n 171:           <ArrowLeft className=\"w-4 h-4 mr-2\" />\r\n 172:           {tr(\"common.back\", \"в”ңГүв”¬ВҘв”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в”Ө\")}\r\n 173:         </Button>\r\n 174:       </div>\r\n 175:     );\r\n 176:   }\r\n 177: \r\n 178:   // ============================================================\r\n 179:   // BLOCK 05 в”ңГіО“Г©ВјО“ГҮВҘ SAVE BUTTON CONTENT\r\n 180:   // ============================================================\r\n 181: \r\n 182:   const getSaveButtonContent = () => {\r\n 183:     if (saveStatus === \"saving\") {\r\n 184:       return (\r\n 185:         <>\r\n 186:           <Loader2 className=\"w-4 h-4 animate-spin mr-2\" />\r\n 187:           {tr(\"common.saving\", \"в”ңГүв”¬Гӯв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГүв”¬в•Ў...\")}\r\n 188:         </>\r\n 189:       );\r\n 190:     }\r\n 191:     if (saveStatus === \"success\") {\r\n 192:       return (\r\n 193:         <>\r\n 194:           <Check className=\"w-4 h-4 mr-2\" />\r\n 195:           {tr(\"common.saved\", \"в”ңГүв”¬Гӯв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•ӣ\")}\r\n 196:         </>\r\n 197:       );\r\n 198:     }\r\n 199:     return tr(\"common.save\", \"в”ңГүв”¬Гӯв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ\");\r\n 200:   };\r\n 201: \r\n 202:   // ============================================================\r\n 203:   // BLOCK 06 в”ңГіО“Г©ВјО“ГҮВҘ RENDER\r\n 204:   // ============================================================\r\n 205: \r\n 206:   const restaurantDisplay = partnerName || tr(\"profile.no_restaurant\", \"в”ңГүв”¬ВҘв”ңГүв”¬в•Ў в”ңГүв”¬в”җв”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГүв”¬в–“в”ңГҰв”¬Г…в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•ң\");\r\n 207: \r\n 208:   return (\r\n 209:     <div className=\"min-h-screen bg-gray-50\">\r\n 210:       {/* Header */}\r\n 211:       <div className=\"bg-white border-b px-4 py-3\">\r\n 212:         <Button\r\n 213:           variant=\"ghost\"\r\n 214:           size=\"sm\"\r\n 215:           onClick={() => navigate(BACK_ROUTE)}\r\n 216:           className=\"flex items-center gap-1 -ml-2 min-h-[44px]\"\r\n 217:         >\r\n 218:           <ArrowLeft className=\"w-4 h-4\" />\r\n 219:           {tr(\"common.back\", \"в”ңГүв”¬ВҘв”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в”Ө\")}\r\n 220:         </Button>\r\n 221:       </div>\r\n 222: \r\n 223:       {/* Content */}\r\n 224:       <div className=\"p-4 max-w-lg mx-auto\">\r\n 225:         <Card>\r\n 226:           <CardHeader>\r\n 227:             <CardTitle>{tr(\"profile.title\", \"в”ңГүв”јв••в”ңГҰО“Г©Вјв”ңГүв”¬в•ӣв”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГүв”¬в•—в”ңГҰв”јГҶ\")}</CardTitle>\r\n 228:           </CardHeader>\r\n 229:           <CardContent>\r\n 230:             <form className=\"space-y-4\" onSubmit={(e) => { e.preventDefault(); handleSave(); }}>\r\n 231:             {/* Full Name - editable */}\r\n 232:             <div className=\"space-y-2\">\r\n 233:               <Label htmlFor=\"fullName\">{tr(\"profile.full_name\", \"в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГүв”¬в•ңв”ңГүв”¬в•ӣв”ңГүв”¬в•Ў в”ңГүв”¬в••в”ңГүв”¬в•қв”ңГҰв”¬Г…\")}</Label>\r\n 234:               <Input\r\n 235:                 id=\"fullName\"\r\n 236:                 value={fullName}\r\n 237:                 onChange={(e) => setFullName(e.target.value)}\r\n 238:               />\r\n 239:             </div>\r\n 240: \r\n 241:             {/* Email - readonly */}\r\n 242:             <div className=\"space-y-2\">\r\n 243:               <Label htmlFor=\"email\">{tr(\"profile.email\", \"Email\")}</Label>\r\n 244:               <Input\r\n 245:                 id=\"email\"\r\n 246:                 value={user?.email || \"\"}\r\n 247:                 readOnly\r\n 248:                 className=\"bg-gray-50 text-gray-600\"\r\n 249:               />\r\n 250:             </div>\r\n 251: \r\n 252:             {/* Role - badge */}\r\n 253:             <div className=\"space-y-2\">\r\n 254:               <p className=\"text-sm font-medium\">{tr(\"profile.role\", \"в”ңГүв”¬ГЎв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв”јГҶ\")}</p>\r\n 255:               <div>\r\n 256:                 <span\r\n 257:                   className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${getRoleBadgeClass(user?.user_role)}`}\r\n 258:                 >\r\n 259:                   {getRoleLabel(user?.user_role)}\r\n 260:                 </span>\r\n 261:               </div>\r\n 262:             </div>\r\n 263: \r\n 264:             {/* Restaurant - text */}\r\n 265:             <div className=\"space-y-2\">\r\n 266:               <p className=\"text-sm font-medium\">{tr(\"profile.restaurant\", \"в”ңГүв”¬ГЎв”ңГүв”¬в•Ўв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ң\")}</p>\r\n 267:               {isPartnerLoading ? (\r\n 268:                 <div className=\"flex items-center gap-1 text-gray-400\" role=\"status\" aria-live=\"polite\">\r\n 269:                   <Loader2 className=\"w-3 h-3 animate-spin\" />\r\n 270:                   <span className=\"text-sm\">{tr(\"common.loading\", \"в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в•‘в”ңГүв”¬в–‘...\")}</span>\r\n 271:                 </div>\r\n 272:               ) : (\r\n 273:                 <p className=\"text-sm text-gray-700\">{restaurantDisplay}</p>\r\n 274:               )}\r\n 275:             </div>\r\n 276: \r\n 277:               {/* Save Button */}\r\n 278:               <Button\r\n 279:                 type=\"submit\"\r\n 280:                 disabled={!canSave || saveStatus !== \"idle\"}\r\n 281:                 className=\"w-full min-h-[44px]\"\r\n 282:               >\r\n 283:                 {getSaveButtonContent()}\r\n 284:               </Button>\r\n 285:             </form>\r\n 286:           </CardContent>\r\n 287:         </Card>\r\n 288:       </div>\r\n 289:     </div>\r\n 290:   );\r\n 291: }\r\n 292: \r\n 293: // ============================================================\r\n 294: // BLOCK 07 в”ңГіО“Г©ВјО“ГҮВҘ PARTNERSHELL WRAPPER\r\n 295: // ============================================================\r\n 296: \r\n 297: /**\r\n 298:  * Profile в”ңГіО“Г©ВјО“ГҮВҘ default export. Wraps ProfileContent in PartnerShell\r\n 299:  * to provide partner context, navigation tabs, and auth gating.\r\n 300:  */\r\n 301: export default function Profile() {\r\n 302:   return (\r\n 303:     <PartnerShell>\r\n 304:       <ProfileContent />\r\n 305:     </PartnerShell>\r\n 306:   );\r\n 307: }\r\n","exit_code":0,"status":"completed"}}
