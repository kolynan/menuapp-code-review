”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ\");\r\n 200:   };\r\n 201: \r\n 202:   // ============================================================\r\n 203:   // BLOCK 06 в”ңГіО“Г©ВјО“ГҮВҘ RENDER\r\n 204:   // ============================================================\r\n 205: \r\n 206:   const restaurantDisplay = partnerName || tr(\"profile.no_restaurant\", \"в”ңГүв”¬ВҘв”ңГүв”¬в•Ў в”ңГүв”¬в”җв”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГүв”¬в–“в”ңГҰв”¬Г…в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•ң\");\r\n 207: \r\n 208:   return (\r\n 209:     <div className=\"min-h-screen bg-gray-50\">\r\n 210:       {/* Header */}\r\n 211:       <div className=\"bg-white border-b px-4 py-3\">\r\n 212:         <Button\r\n 213:           variant=\"ghost\"\r\n 214:           size=\"sm\"\r\n 215:           onClick={() => navigate(BACK_ROUTE)}\r\n 216:           className=\"flex items-center gap-1 -ml-2 min-h-[44px]\"\r\n 217:         >\r\n 218:           <ArrowLeft className=\"w-4 h-4\" />\r\n 219:           {tr(\"common.back\", \"в”ңГүв”¬ВҘв”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в”Ө\")}\r\n 220:         </Button>\r\n 221:       </div>\r\n 222: \r\n 223:       {/* Content */}\r\n 224:       <div className=\"p-4 max-w-lg mx-auto\">\r\n 225:         <Card>\r\n 226:           <CardHeader>\r\n 227:             <CardTitle>{tr(\"profile.title\", \"в”ңГүв”јв••в”ңГҰО“Г©Вјв”ңГүв”¬в•ӣв”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГүв”¬в•—в”ңГҰв”јГҶ\")}</CardTitle>\r\n 228:           </CardHeader>\r\n 229:           <CardContent>\r\n 230:             <form className=\"space-y-4\" onSubmit={(e) => { e.preventDefault(); handleSave(); }}>\r\n 231:             {/* Full Name - editable */}\r\n 232:             <div className=\"space-y-2\">\r\n 233:               <Label htmlFor=\"fullName\">{tr(\"profile.full_name\", \"в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГүв”¬в•ңв”ңГүв”¬в•ӣв”ңГүв”¬в•Ў в”ңГүв”¬в••в”ңГүв”¬в•қв”ңГҰв”¬Г…\")}</Label>\r\n 234:               <Input\r\n 235:                 id=\"fullName\"\r\n 236:                 value={fullName}\r\n 237:                 onChange={(e) => setFullName(e.target.value)}\r\n 238:               />\r\n 239:             </div>\r\n 240: \r\n 241:             {/* Email - readonly */}\r\n 242:             <div className=\"space-y-2\">\r\n 243:               <Label htmlFor=\"email\">{tr(\"profile.email\", \"Email\")}</Label>\r\n 244:               <Input\r\n 245:                 id=\"email\"\r\n 246:                 value={user?.email || \"\"}\r\n 247:                 readOnly\r\n 248:                 className=\"bg-gray-50 text-gray-600\"\r\n 249:               />\r\n 250:             </div>\r\n 251: \r\n 252:             {/* Role - badge */}\r\n 253:             <div className=\"space-y-2\">\r\n 254:               <p className=\"text-sm font-medium\">{tr(\"profile.role\", \"в”ңГүв”¬ГЎв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв”јГҶ\")}</p>\r\n 255:               <div>\r\n 256:                 <span\r\n 257:                   className={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${getRoleBadgeClass(user?.user_role)}`}\r\n 258:                 >\r\n 259:                   {getRoleLabel(user?.user_role)}\r\n 260:                 </span>\r\n 261:               </div>\r\n 262:             </div>\r\n 263: \r\n 264:             {/* Restaurant - text */}\r\n 265:             <div className=\"space-y-2\">\r\n 266:               <p className=\"text-sm font-medium\">{tr(\"profile.restaurant\", \"в”ңГүв”¬ГЎв”ңГүв”¬в•Ўв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ң\")}</p>\r\n 267:               {isPartnerLoading ? (\r\n 268:                 <div className=\"flex items-center gap-1 text-gray-400\" role=\"status\" aria-live=\"polite\">\r\n 269:                   <Loader2 className=\"w-3 h-3 animate-spin\" />\r\n 270:                   <span className=\"text-sm\">{tr(\"common.loading\", \"в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в•‘в”ңГүв”¬в–‘...\")}</span>\r\n 271:                 </div>\r\n 272:               ) : (\r\n 273:                 <p className=\"text-sm text-gray-700\">{restaurantDisplay}</p>\r\n 274:               )}\r\n 275:             </div>\r\n 276: \r\n 277:               {/* Save Button */}\r\n 278:               <Button\r\n 279:                 type=\"submit\"\r\n 280:                 disabled={!canSave || saveStatus !== \"idle\"}\r\n 281:                 className=\"w-full min-h-[44px]\"\r\n 282:               >\r\n 283:                 {getSaveButtonContent()}\r\n 284:               </Button>\r\n 285:             </form>\r\n 286:           </CardContent>\r\n 287:         </Card>\r\n 288:       </div>\r\n 289:     </div>\r\n 290:   );\r\n 291: }\r\n 292: \r\n 293: // ============================================================\r\n 294: // BLOCK 07 в”ңГіО“Г©ВјО“ГҮВҘ PARTNERSHELL WRAPPER\r\n 295: // ============================================================\r\n 296: \r\n 297: /**\r\n 298:  * Profile в”ңГіО“Г©ВјО“ГҮВҘ default export. Wraps ProfileContent in PartnerShell\r\n 299:  * to provide partner context, navigation tabs, and auth gating.\r\n 300:  */\r\n 301: export default function Profile() {\r\n 302:   return (\r\n 303:     <PartnerShell>\r\n 304:       <ProfileContent />\r\n 305:     </PartnerShell>\r\n 306:   );\r\n 307: }\r\n","exit_code":0,"status":"completed"}}
