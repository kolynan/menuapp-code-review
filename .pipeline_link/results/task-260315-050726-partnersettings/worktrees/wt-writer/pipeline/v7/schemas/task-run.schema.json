{
  "$schema": "https://example.local/menuapp/pipeline-v7/task-run.schema.json",
  "type": "object",
  "required": [
    "task_id",
    "workflow",
    "metadata",
    "task",
    "paths",
    "git"
  ],
  "properties": {
    "task_id": {
      "type": "string"
    },
    "workflow": {
      "type": "string",
      "enum": [
        "code-review",
        "ux-discussion"
      ]
    },
    "metadata": {
      "type": "object",
      "required": [
        "type",
        "budget",
        "page",
        "topic",
        "agent"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "page": {
          "type": "string"
        },
        "topic": {
          "type": "string"
        },
        "budget": {
          "type": "string"
        },
        "agent": {
          "type": "string"
        }
      }
    },
    "task": {
      "type": "object",
      "properties": {
        "body": {
          "type": "string"
        },
        "raw": {
          "type": "string"
        },
        "images": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "required": [
        "body",
        "raw",
        "images"
      ]
    },
    "paths": {
      "type": "object"
    },
    "git": {
      "type": "object"
    }
  }
}
