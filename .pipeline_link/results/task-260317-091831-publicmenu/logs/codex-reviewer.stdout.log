ypeof t === \"function\" ? t(key, params) : \"\";\r\n    if (!val || typeof val !== \"string\") return fallback;\r\n    const norm = val.trim();\r\n    if (norm === key || norm.startsWith(key)) return fallback;\r\n    return norm;\r\n  };\r\n\r\n  // Safe status label - prevents showing raw translation keys like \"orderprocess.default.new\"\r\n  const getSafeStatus = (status) => {\r\n    if (!status) {\r\n      return { icon: 'в”ңв–‘в”јв••О“ГҮВҘв”¬в•Ў', label: tr('status.new', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в•ӣ'), color: '#3B82F6' };\r\n    }\r\n\r\n    let label = status.label || '';\r\n\r\n    // Check if label is a raw translation key (contains dots and looks like a key)\r\n    if (label.includes('.') && (label.startsWith('orderprocess') || label.startsWith('status'))) {\r\n      // Extract code from key like \"orderprocess.default.new\" в”ңГіО“ГҮГЎО“ГҮГ– \"new\"\r\n      const parts = label.split('.');\r\n      const code = parts[parts.length - 1];\r\n\r\n      // Use human-readable fallbacks based on code\r\n      const fallbacks = {\r\n        'new': tr('status.new', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в•ӣ'),\r\n        'start': tr('status.cooking', 'в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”¬Гјв”ңГҰв”¬Г…'),\r\n        'cook': tr('status.cooking', 'в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”¬Гјв”ңГҰв”¬Г…'),\r\n        'cooking': tr('status.cooking', 'в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”¬Гјв”ңГҰв”¬Г…'),\r\n        'finish': tr('status.ready', 'в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в•ӣ'),\r\n        'ready': tr('status.ready', 'в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в•ӣ'),\r\n        'done': tr('status.ready', 'в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в•ӣ'),\r\n        'cancel': tr('status.cancelled', 'в”ңГүв”јв•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•қв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГҰО“ГҮГҝв”ңГүв”¬в•ң'),\r\n        'cancelled': tr('status.cancelled', 'в”ңГүв”јв•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•қв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГҰО“ГҮГҝв”ңГүв”¬в•ң'),\r\n      };\r\n\r\n      label = fallbacks[code] || tr('status.new', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в•ӣ');\r\n    }\r\n\r\n    return {\r\n      icon: status.icon || 'в”ңв–‘в”јв••О“ГҮВҘв”¬в•Ў',\r\n      label: label,\r\n      color: status.color || '#3B82F6'\r\n    };\r\n  };\r\n\r\n  // Guest code from localStorage (e.g., \"#6475\")\r\n  const guestCodeFromStorage = React.useMemo(() => {\r\n    if (typeof window === \"undefined\") return null;\r\n    try {\r\n      const raw = window.localStorage.getItem(\"menu_guest_code\");\r\n      return raw ? String(raw).trim() : null;\r\n    } catch {\r\n      return null;\r\n    }\r\n  }, []);\r\n\r\n  // Effective guest code: prop takes priority, fallback to localStorage\r\n  const effectiveGuestCode = guestCode || guestCodeFromStorage;\r\n\r\n  // Guest display: \"в”ңГүв•ҰВЈв”ңГүв”¬в•қв”ңГҰв”¬Г… #6475\" or \"в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ #6475\"\r\n  const guestBaseName = currentGuest\r\n    ? (currentGuest.name || getGuestDisplayName(currentGuest))\r\n    : tr(\"cart.guest\", \"в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ\");\r\n\r\n  const guestDisplay = effectiveGuestCode \r\n    ? `${guestBaseName} #${effectiveGuestCode}` \r\n    : guestBaseName;\r\n\r\n  // Table label: avoid \"в”ңГүв”¬Гӯв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•— в”ңГүв”¬Гӯв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•— 3\"\r\n  const tablePrefix = tr(\"form.table\", \"в”ңГүв”¬Гӯв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•—\");\r\n  const rawTableLabel = currentTable?.name || currentTable?.code || \"в”ңГіО“Г©ВјО“ГҮВҘ\";\r\n  const tableLabel = React.useMemo(() => {\r\n    if (typeof rawTableLabel !== \"string\" || typeof tablePrefix !== \"string\") {\r\n      return `${tablePrefix} ${rawTableLabel}`;\r\n    }\r\n    if (rawTableLabel.trim().toLowerCase().startsWith(tablePrefix.trim().toLowerCase())) {\r\n      return rawTableLabel;\r\n    }\r\n    return `${tablePrefix} ${rawTableLabel}`;\r\n  }, [rawTableLabel, tablePrefix]);\r\n\r\n  // Cart grand total (after discounts)\r\n  const cartGrandTotal = Math.max(\r\n    0,\r\n    (Number(cartTotalAmount) || 0) - (Number(discountAmount) || 0) - (Number(pointsDiscountAmount) || 0)\r\n  );\r\n\r\n  // ===== Guest count (stable, from orders OR guests) =====\r\n  const guestCountFromOrders = React.useMemo(() => {\r\n    try {\r\n      const ids = new Set(\r\n        (sessionOrders || [])\r\n          .map(o => (getLinkId ? getLinkId(o.guest) : o.guest))\r\n          .filter(Boolean)\r\n          .map(x => String(x))\r\n      );\r\n      return ids.size;\r\n    } catch {\r\n      return 0;\r\n    }\r\n  }, [sessionOrders, getLinkId]);\r\n\r\n  const guestCount = Math.max(\r\n    Array.isArray(sessionGuests) ? sessionGuests.length : 0,\r\n    guestCountFromOrders,\r\n    1\r\n  );\r\n  const canSplit = guestCount > 1;\r\n\r\n  // ===== Table Orders from sessionOrders =====\r\n  const ordersByGuestId = React.useMemo(() => {\r\n    const map = new Map();\r\n    (sessionOrders || []).forEach((o) => {\r\n      const gid = getLinkId ? getLinkId(o.guest) : o.guest;\r\n      if (!gid) return;\r\n      const k = String(gid);\r\n      if (!map.has(k)) map.set(k, []);\r\n      map.get(k).push(o);\r\n    });\r\n    return map;\r\n  }, [sessionOrders, getLinkId]);\r\n\r\n  const myGuestId = currentGuest?.id ? String(currentGuest.id) : null;\r\n\r\n  const otherGuestIdsFromOrders = React.useMemo(() => {\r\n    return Array.from(ordersByGuestId.keys()).filter((gid) => !myGuestId || gid !== myGuestId);\r\n  }, [ordersByGuestId, myGuestId]);\r\n\r\n  const tableOrdersTotal = React.useMemo(() => {\r\n    let sum = 0;\r\n    otherGuestIdsFromOrders.forEach((gid) => {\r\n      const orders = ordersByGuestId.get(gid) || [];\r\n      orders.forEach((o) => {\r\n        sum += Number(o.total_amount) || 0;\r\n      });\r\n    });\r\n    return sum;\r\n  }, [ordersByGuestId, otherGuestIdsFromOrders]);\r\n\r\n  const getGuestLabelById = (guestId) => {\r\n    const gid = String(guestId);\r\n    const found = (sessionGuests || []).find((g) => String(g.id) === gid);\r\n    if (found) return getGuestDisplayName(found);\r\n    const suffix = gid.length >= 4 ? gid.slice(-4) : gid;\r\n    return `${tr(\"cart.guest\", \"в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ\")} ${suffix}`;\r\n  };\r\n\r\n  const showTableOrdersSection = otherGuestIdsFromOrders.length > 0;\r\n\r\n  // ===== Review Reward Flow (P1) =====\r\n  const reviewRewardPoints = Number(partner?.loyalty_review_points || 0);\r\n  const isReviewRewardActive = Number.isFinite(reviewRewardPoints) && reviewRewardPoints > 0;\r\n\r\n  // в”ңГүО“ГҮГ¶в”ңГүв”¬в–“в”ңГҰО“ГҮГҝв”ңГүв”¬в•–в”ңГүв”¬в”Өв”ңГҰО“ГҮв•Ј в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГүв”¬в•Ўв”ңГүв”¬в•қ в”ңГүв”¬в•Ўв”ңГҰв”¬Гјв”ңГүв”¬в•—в”ңГүв”¬в••: show_dish_reviews в”ңГүв•ҰВЈв”ңГүО“ГҮв•‘в”ңГүв•ҰВЈ в”ңГүв”¬в•Ўв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в•ңв”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в”Өв”ңГүв”¬в–‘ в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“\r\n  const reviewsEnabled = Boolean(partner?.show_dish_reviews || isReviewRewardActive);\r\n\r\n  // в”ңГүО“ГҮГів”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в•—в”ңГүв”¬в•• в”ңГҰО“ГҮВӘв”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в•ӣв”ңГүв”¬в”Өв”ңГүв”¬в•ңв”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГҰО“ГҮГЎв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•‘в”ңГүв”¬в–‘ (draft в”ңГүв”¬в••в”ңГүв”¬в•—в”ңГүв”¬в•• в”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГҰО“ГҮГҝв”ңГүв”¬в•ңв”ңГүв”¬в•ңв”ңГүв”¬в–‘в”ңГҰв”¬Г…)\r\n  const hasAnyRating = React.useMemo(() => {\r\n    const reviewedCount = safeReviewedItems.size ? Number(safeReviewedItems.size) : 0;\r\n    const draftCount = safeDraftRatings ? Object.values(safeDraftRatings).filter(v => Number(v) > 0).length : 0;\r\n    return reviewedCount > 0 || draftCount > 0;\r\n  }, [reviewedItems, draftRatings]);\r\n\r\n  // в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в••в”ңГүв”¬в”Өв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГҰО“ГҮГңв”ңГүв”¬в••в”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГҰО“Г©Вјв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГүв”¬в•ң?\r\n  const isCustomerIdentified = Boolean(\r\n    loyaltyAccount?.id || loyaltyAccount?._id || loyaltyAccount?.email || (customerEmail && String(customerEmail).trim())\r\n  );\r\n\r\n  // в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГҰО“ГҮГңв”ңГҰв”јГҶ hint \"в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“ +N в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГүв”¬в–“\" в”ңГҰв”¬Гјв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰв•һГҶ\r\n  const shouldShowReviewRewardHint = isReviewRewardActive && (myOrders?.length > 0);\r\n\r\n  // в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГҰО“ГҮГңв”ңГҰв”јГҶ nudge \"в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў email\" в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГүв”¬в•—в”ңГүв”¬в•Ў в”ңГүв”¬в”җв”ңГүв”¬в•Ўв”ңГҰО“Г©Вјв”ңГүв”¬в–“в”ңГүв”¬в•ӣв”ңГүв”¬в•Ј в”ңГүв”¬в•ӣв”ңГҰО“ГҮГЎв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•‘в”ңГүв”¬в••\r\n  const shouldShowReviewRewardNudge = isReviewRewardActive && hasAnyRating && !isCustomerIdentified;\r\n\r\n  // Split summary text\r\n  const splitSummary = splitType === \"all\" \r\n    ? `${tr('cart.for_all', 'в”ңГүв”¬ВҘв”ңГүв”¬в–‘ в”ңГүв”¬в–“в”ңГҰв”¬Гјв”ңГүв”¬в•Ўв”ңГҰО“ГҮВӘ')} (в”ңГўв”¬в•–${guestCount})`\r\n    : tr('cart.only_me', 'в”ңГүв”¬Гів”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв”јГҶв”ңГүв”¬в•‘в”ңГүв”¬в•ӣ в”ңГҰв”¬Г…');\r\n\r\n  // Loyalty summary\r\n  const loyaltySummary = React.useMemo(() => {\r\n    if (Number(loyaltyAccount?.balance || 0) > 0) {\r\n      return `${Number(loyaltyAccount.balance || 0).toLocaleString('ru-RU')} ${tr('loyalty.points_short', 'в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГүв”¬в•ӣв”ңГүв”¬в–“')}`;\r\n    }\r\n    if (earnedPoints > 0) {\r\n      return `+${earnedPoints}`;\r\n    }\r\n    return null;\r\n  }, [loyaltyAccount, earnedPoints]);\r\n\r\n  // Reward for review (shown in Loyalty header if partner configured)\r\n  const reviewRewardLabel = React.useMemo(() => {\r\n    const pts = Number(partner?.loyalty_review_points);\r\n    if (Number.isFinite(pts) && pts > 0) return `+${pts}`;\r\n    return null;\r\n  }, [partner?.loyalty_review_points]);\r\n\r\n  return (\r\n    <div className=\"max-w-2xl mx-auto px-4 mt-2 pb-4\">\r\n      {/* P0 Header: [в”ңв–‘в”јв••О“ГҮВҘО“ГҮВҘ] в”ңГүв”¬Гӯв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•— в”ңГ©в”¬в•– в”ңГүО“ГҮВЈв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГҰв”јГҶ [в”ңГів”јГҙО“ГҮГі] */}\r\n      <div className=\"bg-white rounded-lg shadow-sm border p-3 mb-4\">\r\n        <div className=\"flex items-center justify-between\">\r\n          {/* Left: Call waiter */}\r\n          {onCallWaiter && (\r\n            <button\r\n              onClick={onCallWaiter}\r\n              className=\"p-2 rounded-full bg-amber-50 text-amber-600 hover:bg-amber-100\"\r\n              title={tr('help.call_waiter', 'в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•–в”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в•ӣв”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГҰО“ГҮГңв”ңГүв”¬в–‘')}\r\n            >\r\n              <Bell className=\"w-5 h-5\" />\r\n            </button>\r\n          )}\r\n\r\n          {/* Center: Table & Guest */}\r\n          <div className=\"text-center flex-1 mx-2\">\r\n            <div className=\"text-sm font-medium text-slate-700\">{tableLabel}</div>\r\n            <div className=\"flex items-center justify-center gap-1 text-xs\">\r\n              <span className=\"text-slate-500\">{tr('cart.you', 'в”ңГүО“ГҮГ–в”ңГҰО“ГҮв•Ј')}:</span>\r\n              {isEditingName ? (\r\n                <span className=\"inline-flex items-center gap-1\">\r\n                  <input\r\n                    type=\"text\"\r\n                    value={guestNameInput}\r\n                    onChange={(e) => setGuestNameInput(e.target.value)}\r\n                    placeholder={tr('guest.name_placeholder', 'в”ңГүв•ҰВЈв”ңГүв”¬в•қв”ңГҰв”¬Г…')}\r\n                    className=\"w-20 px-1 py-0.5 text-xs border rounded\"\r\n                    autoFocus\r\n                    onKeyDown={(e) => {\r\n                      if (e.key === 'Enter' && guestNameInput.trim()) handleUpdateGuestName();\r\n                      if (e.key === 'Escape') { setIsEditingName(false); setGuestNameInput(''); }\r\n                    }}\r\n                  />\r\n                  <button onClick={handleUpdateGuestName} disabled={!guestNameInput.trim()} className=\"text-green-600\">в”ңГів”јГҙО“ГҮВЈ</button>\r\n                  <button onClick={() => { setIsEditingName(false); setGuestNameInput(''); }} className=\"text-slate-400\">в”ңГів”јГҙО“ГҮГі</button>\r\n                </span>\r\n              ) : (\r\n                <button \r\n                  onClick={() => { setGuestNameInput(currentGuest?.name || ''); setIsEditingName(true); }}\r\n                  className=\"text-indigo-600 hover:underline\"\r\n                >\r\n                  {guestDisplay} {(!currentGuest?.name) && <span className=\"text-xs\">в”ңГів”јГҙв”¬Г…в”ңВ»в”¬в••в”¬Г…</span>}\r\n                </button>\r\n              )}\r\n            </div>\r\n          </div>\r\n\r\n          {/* Right: Close */}\r\n          <button\r\n            onClick={() => onClose ? onClose() : setView(\"menu\")}\r\n            className=\"p-2 rounded-full bg-slate-100 text-slate-500 hover:bg-slate-200\"\r\n          >\r\n            <X className=\"w-5 h-5\" />\r\n          </button>\r\n        </div>\r\n      </div>\r\n\r\n      {/* Review reward hint */}\r\n      {shouldShowReviewRewardHint && (\r\n        <div className=\"mb-4 text-xs text-amber-700 bg-amber-50 rounded-md px-3 py-2 flex items-center gap-2\">\r\n          <span>в”ңГів”¬ВЎв”¬Гү</span>\r\n          <span>{tr('loyalty.review_reward_hint', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“')} +{reviewRewardPoints} {tr('loyalty.points_short', 'в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГүв”¬в–“')}</span>\r\n        </div>\r\n      )}\r\n\r\n      {/* Review reward nudge - в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГүв”¬в•Ўв”ңГүв”¬в•қ в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГүв”¬в•—в”ңГүв”¬в•Ў в”ңГүв”¬в”җв”ңГүв”¬в•Ўв”ңГҰО“Г©Вјв”ңГүв”¬в–“в”ңГүв”¬в•ӣв”ңГүв”¬в•Ј в”ңГүв”¬в•ӣв”ңГҰО“ГҮГЎв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•‘в”ңГүв”¬в•• в”ңГҰв”¬Гј в”ңГҰО“ГҮвӮ§в”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в•қв”ңГүв”¬в•ӣв”ңГүв”¬в•Ј email */}\r\n      {shouldShowReviewRewardNudge && (\r\n        <div className=\"mb-4 text-sm bg-green-50 border border-green-200 rounded-md p-3\">\r\n          {!showRewardEmailForm ? (\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"text-slate-700\">\r\n                в”ңГів”јГҙО“ГҮВӘ {tr('loyalty.thanks_for_rating', 'в”ңГүв”¬Гӯв”ңГүв”¬в”җв”ңГүв”¬в–‘в”ңГҰв”¬Гјв”ңГүв”¬в••в”ңГүв”¬в–’в”ңГүв”¬в•ӣ в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГҰО“ГҮГЎв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•‘в”ңГҰв•һГҶ!')}\r\n              </span>\r\n              <button\r\n                type=\"button\"\r\n                className=\"text-indigo-600 hover:underline font-medium text-sm\"\r\n                onClick={() => setShowRewardEmailForm(true)}\r\n              >\r\n                {tr('loyalty.get_bonus', 'в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв•һГҶв”ңГҰО“ГҮГӯв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГҰО“ГҮв•Ј')} в”ңГіО“ГҮГЎО“ГҮГ–\r\n              </button>\r\n            </div>\r\n          ) : (\r\n            <div className=\"space-y-2\">\r\n              <p className=\"text-slate-700 text-xs\">\r\n                {tr('loyalty.enter_email_for_bonus', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў email в”ңГүв”¬в”Өв”ңГүв”¬в•—в”ңГҰв”¬Г… в”ңГүв”¬в•ңв”ңГүв”¬в–‘в”ңГҰО“ГҮГӯв”ңГүв”¬в••в”ңГҰв”¬Гјв”ңГүв”¬в•—в”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰв”¬Г… в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГүв”¬в–“:')}\r\n              </p>\r\n              <div className=\"flex gap-2\">\r\n                <Input\r\n                  type=\"email\"\r\n                  value={rewardEmail}\r\n                  onChange={(e) => setRewardEmail(e.target.value)}\r\n                  placeholder=\"email@example.com\"\r\n                  className=\"flex-1 h-9 text-sm\"\r\n                />\r\n                <Button\r\n                  size=\"sm\"\r\n                  className=\"h-9\"\r\n                  disabled={!rewardEmail.trim() || rewardEmailSubmitting}\r\n                  onClick={() => {\r\n                    if (!rewardEmail.trim()) return;\r\n                    setRewardEmailSubmitting(true);\r\n                    // в”ңГүв•ҰВЈв”ңГҰв”¬Гјв”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв”јГҶв”ңГүв”¬в•–в”ңГҰв•һГҶв”ңГүв”¬в•Ўв”ңГүв”¬в•қ в”ңГҰв”¬Гјв”ңГҰв•һГҶв”ңГҰО“ГҮв–‘в”ңГүв”¬в•Ўв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в–“в”ңГҰв•һГҶв”ңГҰв”јв•ңв”ңГҰО“ГҮв–‘в”ңГүв”¬в••в”ңГүв”¬в•Ј setCustomerEmail в”ңГүв”¬в”Өв”ңГүв”¬в•—в”ңГҰв”¬Г… в”ңГҰв”¬Гјв”ңГүв”¬в••в”ңГүв”¬в•ңв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГүв”¬в••\r\n                    if (setCustomerEmail) setCustomerEmail(rewardEmail);\r\n                    // в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“в”ңГүв”¬в–‘в”ңГүв”¬в•Ўв”ңГүв”¬в•қ toast\r\n                    if (toast) toast.success(tr('loyalty.email_saved', 'Email в”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГҰО“ГҮГҝв”ңГүв”¬в•ң! в”ңГүО“ГҮГҝв”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГҰО“ГҮв•Ј в”ңГүв”¬в–’в”ңГҰв•һГҶв”ңГүв”¬в”Өв”ңГҰв•һГҶв”ңГҰО“ГҮГң в”ңГүв”¬в•ңв”ңГүв”¬в–‘в”ңГҰО“ГҮГӯв”ңГүв”¬в••в”ңГҰв”¬Гјв”ңГүв”¬в•—в”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГҰО“ГҮв•Ј.'));\r\n                    setTimeout(() => {\r\n                      setRewardEmailSubmitting(false);\r\n                      setShowRewardEmailForm(false);\r\n                    }, 1000);\r\n                  }}\r\n                >\r\n                  {rewardEmailSubmitting ? '...' : tr('common.save', 'в”ңГүв”¬Гӯв”ңГүв”¬в•ӣв”ңГҰО“ГҮВӘв”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ')}\r\n                </Button>\r\n              </div>\r\n            </div>\r\n          )}\r\n        </div>\r\n      )}\r\n\r\n      {/* SECTION 5: TABLE ORDERS (other guests) - STABLE based on sessionOrders */}\r\n      {showTableOrdersSection && (\r\n        <Card className=\"mb-4\">\r\n          <CardContent className=\"p-4\">\r\n            <button\r\n              onClick={() => setOtherGuestsExpanded(!otherGuestsExpanded)}\r\n              className=\"w-full flex items-center justify-between text-left\"\r\n            >\r\n              <div className=\"flex items-center gap-2\">\r\n                <Users className=\"w-4 h-4 text-slate-500\" />\r\n                <span className=\"text-sm font-semibold text-slate-600\">\r\n                  {tr('cart.table_orders', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Ј в”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГүв”¬в–‘')} ({otherGuestIdsFromOrders.length})\r\n                </span>\r\n              </div>\r\n              <div className=\"flex items-center gap-2\">\r\n                {sessionItems.length === 0 && sessionOrders.length > 0 ? (\r\n                  <span className=\"text-sm text-slate-400\">{tr('common.loading', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в•‘в”ңГүв”¬в–‘')}</span>\r\n                ) : (\r\n                  <span className=\"font-bold text-slate-700\">{formatPrice(tableOrdersTotal)}</span>\r\n                )}\r\n                {otherGuestsExpanded ? (\r\n                  <ChevronUp className=\"w-4 h-4 text-slate-400\" />\r\n                ) : (\r\n                  <ChevronDown className=\"w-4 h-4 text-slate-400\" />\r\n                )}\r\n              </div>\r\n            </button>\r\n\r\n            {otherGuestsExpanded && (\r\n              <div className=\"mt-4 pt-4 border-t space-y-4\">\r\n                {otherGuestIdsFromOrders.map((gid) => {\r\n                  const guestOrders = ordersByGuestId.get(gid) || [];\r\n                  const guestTotal = guestOrders.reduce((sum, o) => sum + (Number(o.total_amount) || 0), 0);\r\n\r\n                  return (\r\n                    <div key={gid} className=\"text-sm\">\r\n                      <div className=\"flex items-center justify-between mb-2\">\r\n                        <span className=\"font-medium text-slate-700\">{getGuestLabelById(gid)}</span>\r\n                        {sessionItems.length === 0 && sessionOrders.length > 0 ? (\r\n                          <span className=\"text-slate-400\">{tr('common.loading', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в•‘в”ңГүв”¬в–‘')}</span>\r\n                        ) : (\r\n                          <span className=\"font-bold text-slate-600\">{formatPrice(guestTotal)}</span>\r\n                        )}\r\n                      </div>\r\n\r\n                      {guestOrders.length > 0 ? (\r\n                        <div className=\"pl-2 border-l-2 border-slate-200 space-y-1\">\r\n                          {guestOrders.map((order) => {\r\n                            const items = itemsByOrder.get(order.id) || [];\r\n                            const status = getSafeStatus(getOrderStatus(order));\r\n\r\n                            if (items.length === 0) {\r\n                              return (\r\n                                <div key={order.id} className=\"flex justify-between items-center text-xs\">\r\n                                  <span className=\"text-slate-600\">\r\n                                    {tr('cart.order_total', 'в”ңГүв”¬Гӯв”ңГҰв•һГҶв”ңГүв”¬в•қв”ңГүв”¬в•қв”ңГүв”¬в–‘ в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘')}: {formatPrice(order.total_amount)}\r\n                                  </span>\r\n                                  <span className=\"text-xs\" style={{ color: status.color }}>{status.label}</span>\r\n                                </div>\r\n                              );\r\n                            }\r\n\r\n                            return items.map((item, idx) => (\r\n                              <div key={`${order.id}-${idx}`} className=\"flex justify-between items-center text-xs\">\r\n                                <span className=\"text-slate-600\">{item.dish_name} в”ңГўО“ГҮГ¶ {item.quantity}</span>\r\n                                <span className=\"text-xs\" style={{ color: status.color }}>{status.label}</span>\r\n                              </div>\r\n                            ));\r\n                          })}\r\n                        </div>\r\n                      ) : (\r\n                        <div className=\"pl-2 text-xs text-slate-400\">\r\n                          {tr('cart.no_orders_yet', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в•ӣв”ңГүв”¬в–“ в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в•‘в”ңГүв”¬в–‘ в”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГҰО“ГҮГң')}\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  );\r\n                })}\r\n\r\n                {/* Review button for other guests' dishes */}\r\n                {otherGuestsReviewableItems.length > 0 && (\r\n                  <Button\r\n                    variant=\"outline\"\r\n                    size=\"sm\"\r\n                    className=\"w-full mt-2\"\r\n                    onClick={() => openReviewDialog(otherGuestsReviewableItems)}\r\n                  >\r\n                    в”ңГів”¬ВЎв”¬Гү {tr('review.rate_others', 'в”ңГүв”јв•ӣв”ңГҰО“ГҮГЎв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в–’в”ңГүв”¬в•—в”ңГҰв”јв•ңв”ңГүв”¬в”Өв”ңГүв”¬в–‘ в”ңГүв”¬в”Ӯв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•Ўв”ңГүв”¬в•Ј')}\r\n                    {loyaltyAccount && ` (+${otherGuestsReviewableItems.length * (partner?.loyalty_review_points || 10)} ${tr('review.points', 'в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГүв”¬в•ӣв”ңГүв”¬в–“')})`}\r\n                  </Button>\r\n                )}\r\n              </div>\r\n            )}\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* SECTION 6: TABLE TOTAL */}\r\n      {(sessionGuests.length > 1 || showTableOrdersSection) && (\r\n        <Card className=\"mb-4 bg-slate-50\">\r\n          <CardContent className=\"p-4\">\r\n            <div className=\"flex items-center justify-between\">\r\n              <span className=\"font-medium text-slate-700\">{tr('cart.table_total', 'в”ңГүв”¬Гӯв”ңГҰО“ГҮГӯв”ңГҰО“ГҮГҝв”ңГҰО“ГҮГң в”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГүв”¬в–‘')}:</span>\r\n              <span className=\"text-xl font-bold text-slate-900\">{formatPrice(tableTotal)}</span>\r\n            </div>\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* SECTION 3: YOUR ORDERS (submitted) - COLLAPSIBLE */}\r\n      {myOrders.length > 0 && (\r\n        <Card className=\"mb-4\">\r\n          <CardContent className=\"p-4\">\r\n            <button\r\n              type=\"button\"\r\n              className=\"w-full flex items-center justify-between text-left\"\r\n              onClick={() => setMyOrdersExpanded(!myOrdersExpanded)}\r\n            >\r\n              <div className=\"flex items-center gap-2\">\r\n                <ShoppingBag className=\"w-4 h-4 text-green-600\" />\r\n                <span className=\"text-base font-semibold text-slate-800\">\r\n                  {tr('cart.your_orders', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–‘в”ңГҰв•ҰГҘв”ңГүв”¬в•• в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГҰО“ГҮв•Ј')} ({myOrders.length})\r\n                </span>\r\n              </div>\r\n              <div className=\"flex items-center gap-2\">\r\n                <span className=\"font-bold text-slate-700\">{formatPrice(myBill.total)}</span>\r\n                {myOrdersExpanded ? (\r\n                  <ChevronUp className=\"w-4 h-4 text-slate-400\" />\r\n                ) : (\r\n                  <ChevronDown className=\"w-4 h-4 text-slate-400\" />\r\n                )}\r\n              </div>\r\n            </button>\r\n\r\n            {myOrdersExpanded && (\r\n              <div className=\"mt-4 pt-4 border-t space-y-3\">\r\n                {myOrders.map((order) => {\r\n                  const orderItems = itemsByOrder.get(order.id) || [];\r\n                  const rawStatus = getOrderStatus(order);\r\n                  const status = getSafeStatus(rawStatus);\r\n\r\n                  return (\r\n                    <div key={order.id} className=\"border-b pb-3 last:border-0 last:pb-0\">\r\n                      <div className=\"flex items-center justify-between mb-2\">\r\n                        <span className=\"text-xs text-slate-400\">\r\n                          {formatOrderTime(order)}\r\n                        </span>\r\n                        <span className=\"text-xs px-2 py-1 rounded-full\" style={{ backgroundColor: `${status.color}15`, color: status.color }}>\r\n                          {status.label}\r\n                        </span>\r\n                      </div>\r\n                      {/* Order items with draft rating stars */}\r\n                      {orderItems.length > 0 ? (\r\n                        <div className=\"space-y-2\">\r\n                          {orderItems.map((item, idx) => {\r\n                            const itemId = item.id || `${order.id}_${idx}`;\r\n                            const hasReview = safeReviewedItems.has(itemId);\r\n                            const draftRating = safeDraftRatings[itemId] || 0;\r\n\r\n                            return (\r\n                              <div key={itemId} className=\"space-y-1\">\r\n                                <div className=\"flex justify-between items-center text-sm\">\r\n                                  <span className=\"text-slate-700\">{item.dish_name} в”ңГўО“ГҮГ¶ {item.quantity}</span>\r\n                                  <span className=\"text-slate-600\">{formatPrice(item.line_total ?? (item.dish_price * item.quantity))}</span>\r\n                                </div>\r\n\r\n                                {/* Draft rating stars - show always if reviews enabled */}\r\n                                {reviewsEnabled && (\r\n                                  <div className=\"flex items-center gap-2 pl-2\">\r\n                                    <Rating\r\n                                      value={draftRating}\r\n                                      onChange={(val) => {\r\n                                        if (draftRating > 0 || hasReview) return; // в”ңГҰв•һГҶв”ңГүв”¬в•ўв”ңГүв”¬в•Ў в”ңГүв”¬в•ӣв”ңГҰО“ГҮГЎв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•ӣ\r\n                                        updateDraftRating(itemId, val);\r\n                                        if (val > 0 && handleRateDish) {\r\n                                          const dishId = typeof item.dish === 'object' ? item.dish?.id : item.dish;\r\n                                          handleRateDish({\r\n                                            itemId,\r\n                                            dishId,\r\n                                            orderId: order.id,\r\n                                            rating: val,\r\n                                          });\r\n                                        }\r\n                                      }}\r\n                                      size=\"sm\"\r\n                                      readonly={draftRating > 0 || hasReview || ratingSavingByItemId?.[itemId]}\r\n                                    />\r\n                                    {ratingSavingByItemId?.[itemId] && (\r\n                                      <Loader2 className=\"w-3 h-3 animate-spin text-slate-400\" />\r\n                                    )}\r\n                                    {(draftRating > 0 || hasReview) && !ratingSavingByItemId?.[itemId] && (\r\n                                      <span className=\"text-xs text-green-600\">в”ңГів”јГҙО“ГҮВЈ</span>\r\n                                    )}\r\n                                  </div>\r\n                                )}\r\n                              </div>\r\n                            );\r\n                          })}\r\n                        </div>\r\n                      ) : (\r\n                        <div className=\"text-sm text-slate-500\">\r\n                          {tr('cart.order_total', 'в”ңГүв”¬Гӯв”ңГҰв•һГҶв”ңГүв”¬в•қв”ңГүв”¬в•қв”ңГүв”¬в–‘ в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘')}: {formatPrice(order.total_amount)}\r\n                        </div>\r\n                      )}\r\n                    </div>\r\n                  );\r\n                })}\r\n\r\n                {/* Review button */}\r\n                {reviewableItems.length > 0 && (\r\n                  <Button\r\n                    variant=\"outline\"\r\n                    size=\"sm\"\r\n                    className=\"w-full mt-3\"\r\n                    onClick={() => openReviewDialog(reviewableItems)}\r\n                  >\r\n                    в”ңв–‘в”јв••О“ГҮГ–в”¬Вј {tr('review.add_comments', 'в”ңГүО“ГҮВҘв”ңГүв”¬в•ӣв”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в–“в”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в•қв”ңГүв”¬в•қв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГҰО“ГҮГңв”ңГүв”¬в–‘в”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГүв”¬в••')}\r\n                  </Button>\r\n                )}\r\n              </div>\r\n            )}\r\n          </CardContent>\r\n        </Card>\r\n      )}\r\n\r\n      {/* SECTION 2: NEW ORDER */}\r\n      {cart.length > 0 && (\r\n        <Card className=\"mb-4\">\r\n          <CardContent className=\"p-4\">\r\n            <h2 className=\"text-base font-semibold text-slate-800 mb-3 flex items-center gap-2\">\r\n              в”ңв–‘в”јв••О“ГҮв•‘О“ГҮГ– {tr('cart.new_order', 'в”ңГүв”¬ВҘв”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГҰО“ГҮв•Јв”ңГүв”¬в•Ј в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–')}\r\n            </h2>\r\n\r\n            <div className=\"space-y-2\">\r\n              {cart.map((item) => (\r\n                <div key={item.dishId} className=\"flex items-center justify-between py-2 border-b last:border-0\">\r\n                  <div className=\"flex-1\">\r\n                    <div className=\"font-medium text-slate-900\">{item.name}</div>\r\n                    <div className=\"text-xs text-slate-500\">{formatPrice(item.price)} в”ңГўО“ГҮГ¶ {item.quantity}</div>\r\n                  </div>\r\n                  <div className=\"flex items-center gap-3\">\r\n                    <span className=\"font-semibold text-slate-900\">{formatPrice(item.price * item.quantity)}</span>\r\n                    <button \r\n                      onClick={() => updateQuantity(item.dishId, -item.quantity)}\r\n                      className=\"p-1.5 rounded-full hover:bg-red-50 text-slate-400 hover:text-red-600 transition-colors\"\r\n                    >\r\n                      <XIcon className=\"w-4 h-4\" />\r\n                    </button>\r\n                  </div>\r\n                </div>\r\n              ))}\r\n            </div>\r\n\r\n            {/* P1: Split toggle - STABLE (always visible, disabled if < 2 guests) */}\r\n            {isTableVerified === true && (\r\n            <div className=\"mt-4 pt-4 border-t\">\r\n              <button\r\n                type=\"button\"\r\n                className={`w-full flex items-center justify-between text-left ${\r\n                  canSplit ? \"cursor-pointer\" : \"cursor-not-allowed\"\r\n                }`}\r\n                onClick={() => canSplit && setSplitExpanded(!splitExpanded)}\r\n                disabled={!canSplit}\r\n              >\r\n                <span className=\"text-sm font-medium text-slate-700\">\r\n                  {tr('cart.split_title', 'в”ңГүО“ГҮВҘв”ңГүв”¬в•—в”ңГҰв”¬Г… в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в”Ӯв”ңГүв”¬в•ӣ в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–')}\r\n                </span>\r\n                <div className=\"flex items-center gap-2\">\r\n                  <span className={`text-sm ${canSplit ? 'text-slate-600' : 'text-slate-400'}`}>\r\n                    {splitSummary}\r\n                  </span>\r\n                  {canSplit ? (\r\n                    splitExpanded ? (\r\n                      <ChevronUp className=\"w-4 h-4 text-slate-400\" />\r\n                    ) : (\r\n                      <ChevronDown className=\"w-4 h-4 text-slate-400\" />\r\n                    )\r\n                  ) : (\r\n                    <span className=\"text-xs text-slate-400\">\r\n                      {tr('cart.split_disabled_hint', '(2+ в”ңГүв”¬в”Ӯв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•Ўв”ңГүв”¬в•Ј)')}\r\n                    </span>\r\n                  )}\r\n                </div>\r\n              </button>\r\n\r\n              {splitExpanded && canSplit && (\r\n                <div className=\"mt-3 flex items-center justify-center gap-6\">\r\n                  <label className=\"flex items-center gap-2 cursor-pointer\">\r\n                    <input\r\n                      type=\"radio\"\r\n                      name=\"splitType\"\r\n                      checked={splitType === 'single'}\r\n                      onChange={() => setSplitType('single')}\r\n                      className=\"w-4 h-4 text-indigo-600\"\r\n                    />\r\n                    <span className=\"text-sm text-slate-700\">{tr('cart.only_me', 'в”ңГүв”¬Гів”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв”јГҶв”ңГүв”¬в•‘в”ңГүв”¬в•ӣ в”ңГҰв”¬Г…')}</span>\r\n                  </label>\r\n                  <label className=\"flex items-center gap-2 cursor-pointer\">\r\n                    <input\r\n                      type=\"radio\"\r\n                      name=\"splitType\"\r\n                      checked={splitType === 'all'}\r\n                      onChange={() => setSplitType('all')}\r\n                      className=\"w-4 h-4 text-indigo-600\"\r\n                    />\r\n                    <span className=\"text-sm text-slate-700\">{tr('cart.for_all', 'в”ңГүв”¬ВҘв”ңГүв”¬в–‘ в”ңГүв”¬в–“в”ңГҰв”¬Гјв”ңГүв”¬в•Ўв”ңГҰО“ГҮВӘ')} (в”ңГўв”¬в•–{guestCount})</span>\r\n                  </label>\r\n                  {/* P2 placeholder - disabled until data model supports custom split */}\r\n                  <label className=\"flex items-center gap-2 opacity-50 cursor-not-allowed\">\r\n                    <input\r\n                      type=\"radio\"\r\n                      disabled\r\n                      className=\"w-4 h-4\"\r\n                    />\r\n                    <span className=\"text-sm text-slate-400\">\r\n                      {tr('cart.split_pick_guests_soon', 'в”ңГүО“ГҮГ–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–’в”ңГҰО“Г©Вјв”ңГүв”¬в–‘в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в”Ӯв”ңГүв”¬в•ӣв”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•Ўв”ңГүв”¬в•Ј (в”ңГҰв”¬Гјв”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в•ӣ)')}\r\n                    </span>\r\n                  </label>\r\n                </div>\r\n              )}\r\n            </div>\r\n            )}\r\n\r\n            {/* P1: Loyalty section - COLLAPSIBLE */}\r\n            {showLoginPromptAfterRating && (\r\n              <div className=\"mt-4 pt-4 border-t\">\r\n                <button\r\n                  type=\"button\"\r\n                  className=\"w-full flex items-center justify-between text-left\"\r\n                  onClick={() => setLoyaltyExpanded(!loyaltyExpanded)}\r\n                >\r\n                  <div className=\"flex items-center gap-2\">\r\n                    <Gift className=\"w-4 h-4 text-amber-500\" />\r\n                    <span className=\"text-sm font-medium text-slate-700\">\r\n                      {tr('loyalty.title', 'в”ңГүО“ГҮГҝв”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГҰО“ГҮв•Ј')}\r\n                      {reviewRewardLabel && (\r\n                        <span className=\"ml-2 text-xs text-slate-500 font-normal\">\r\n                          в”ңГіО“Г©Вјв”¬Гі {tr('loyalty.review_reward_prefix', 'в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГҰО“ГҮГңв”ңГүв”¬в•–в”ңГҰО“ГҮв•Јв”ңГүв”¬в–“')} {reviewRewardLabel}\r\n                        </span>\r\n                      )}\r\n                    </span>\r\n                  </div>\r\n                  <div className=\"flex items-center gap-2\">\r\n                    {loyaltySummary && (\r\n                      <span className=\"text-sm font-semibold text-green-600\">\r\n                        {loyaltySummary}\r\n                      </span>\r\n                    )}\r\n                    {loyaltyExpanded ? (\r\n                      <ChevronUp className=\"w-4 h-4 text-slate-400\" />\r\n                    ) : (\r\n                      <ChevronDown className=\"w-4 h-4 text-slate-400\" />\r\n                    )}\r\n                  </div>\r\n                </button>\r\n\r\n                {loyaltyExpanded && (\r\n                  <div className=\"mt-3 space-y-3\">\r\n                    <div className=\"space-y-2\">\r\n                      <label className=\"text-sm font-medium text-slate-700\">\r\n                        {tr('loyalty.email_label', 'Email в”ңГүв”¬в”Өв”ңГүв”¬в•—в”ңГҰв”¬Г… в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГүв”¬в–“')}\r\n                      </label>\r\n                      <Input\r\n                        type=\"email\"\r\n                        value={customerEmail}\r\n                        onChange={(e) => setCustomerEmail(e.target.value)}\r\n                        placeholder={tr('loyalty.email_placeholder', 'email@example.com')}\r\n                      />\r\n                    </div>\r\n\r\n                    {!customerEmail.trim() ? (\r\n                      <p className=\"text-xs text-slate-500\">{tr('loyalty.enter_email_hint', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў email в”ңГүв”¬в”Өв”ңГүв”¬в•—в”ңГҰв”¬Г… в”ңГүв”¬в•ңв”ңГүв”¬в–‘в”ңГҰО“ГҮГӯв”ңГүв”¬в••в”ңГҰв”¬Гјв”ңГүв”¬в•—в”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰв”¬Г… в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГүв”¬в–“')}</p>\r\n                    ) : loyaltyLoading ? (\r\n                      <div className=\"flex items-center gap-2 text-xs text-slate-500\">\r\n                        <Loader2 className=\"w-3 h-3 animate-spin\" />\r\n                        {tr('common.loading', 'в”ңГүО“ГҮГ¶в”ңГүв”¬в–‘в”ңГүв”¬в”Ӯв”ңГҰО“Г©Вјв”ңГҰв•һГҶв”ңГүв”¬в•–в”ңГүв”¬в•‘в”ңГүв”¬в–‘')}\r\n                      </div>\r\n                    ) : !loyaltyAccount ? (\r\n                      partner?.loyalty_enabled && (\r\n                        <div className=\"text-xs text-green-600 bg-green-50 p-2 rounded-lg\">\r\n                          {trFormat('loyalty.new_customer', { points: earnedPoints }, `в”ңГүО“ГҮГ–в”ңГҰО“ГҮв•Ј в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГҰв•һГҶв”ңГҰО“ГҮГӯв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў ${earnedPoints} в”ңГүв”¬в–’в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГүв”¬в•ӣв”ңГүв”¬в–“ в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в”җв”ңГүв”¬в•Ўв”ңГҰО“Г©Вјв”ңГүв”¬в–“в”ңГҰО“ГҮв•Јв”ңГүв”¬в•Ј в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–`)}\r\n                        </div>\r\n                      )\r\n                    ) : (\r\n                      <div className=\"space-y-2\">\r\n                        <div className=\"bg-indigo-50 p-2 rounded-lg text-xs\">\r\n                          <div className=\"text-slate-600\">\r\n                            {trFormat('loyalty.your_balance', { points: Number(loyaltyAccount.balance || 0).toLocaleString('ru-RU') }, `в”ңГүО“ГҮГ–в”ңГүв”¬в–‘в”ңГҰв•ҰГҘ в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГҰв”¬Гј: ${Number(loyaltyAccount.balance || 0).toLocaleString('ru-RU')} в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГүв”¬в•ӣв”ңГүв”¬в–“`)}\r\n                          </div>\r\n                          <div className=\"text-slate-500\">\r\n                            = {(Number(loyaltyAccount.balance || 0) * (partner?.loyalty_redeem_rate || 1)).toLocaleString('ru-RU')}в”ңГіО“ГҮГңв”¬в••\r\n                          </div>\r\n                        </div>\r\n\r\n                        {loyaltyAccount.balance > 0 && maxRedeemPoints > 0 && (\r\n                          <div className=\"space-y-1\">\r\n                            <label className=\"text-xs font-medium text-slate-700\">\r\n                              {tr('loyalty.redeem_points', 'в”ңГүв”¬Гӯв”ңГүв”¬в”җв”ңГүв”¬в••в”ңГҰв”¬Гјв”ңГүв”¬в–‘в”ңГҰО“ГҮГңв”ңГҰв”јГҶ в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГҰО“ГҮв•Ј')}\r\n                            </label>\r\n                            <div className=\"flex items-center gap-2\">\r\n                              <Input\r\n                                type=\"number\"\r\n                                min={0}\r\n                                max={maxRedeemPoints}\r\n                                value={redeemedPoints}\r\n                                onChange={(e) => {\r\n                                  const val = parseInt(e.target.value) || 0;\r\n                                  setRedeemedPoints(Math.min(Math.max(0, val), maxRedeemPoints));\r\n                                }}\r\n                                className=\"w-24 h-8 text-sm\"\r\n                              />\r\n                              <Button\r\n                                size=\"sm\"\r\n                                className=\"h-8 text-xs\"\r\n                                onClick={() => {\r\n                                  setRedeemedPoints(maxRedeemPoints);\r\n                                  toast.success(tr('loyalty.points_applied', 'в”ңГүО“ГҮГҝв”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГҰО“ГҮв•Ј в”ңГүв”¬в”җв”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГүв”¬в•қв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГҰО“ГҮв•Ј'), { id: 'mm1' });\r\n                                }}\r\n                              >\r\n                                {tr('loyalty.apply', 'в”ңГүв”јв••в”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГүв”¬в•қв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГҰв”јГҶ')}\r\n                              </Button>\r\n                            </div>\r\n                            <p className=\"text-xs text-slate-500\">\r\n                              {trFormat('loyalty.max_redeem', { \r\n                                max: maxRedeemPoints.toLocaleString('ru-RU'), \r\n                                percent: partner?.loyalty_max_redeem_percent || 0 \r\n                              }, `в”ңГүв”јГҙв”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГҰв”¬Гјв”ңГүв”¬в••в”ңГүв”¬в•қв”ңГҰв•һГҶв”ңГүв”¬в•қ ${maxRedeemPoints} в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГүв”¬в•ӣв”ңГүв”¬в–“ (${partner?.loyalty_max_redeem_percent || 0}% в”ңГүв”¬в•ӣв”ңГҰО“ГҮГң в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в–‘)`) }\r\n                            </p>\r\n                          </div>\r\n                        )}\r\n                      </div>\r\n                    )}\r\n\r\n                    {partner?.discount_enabled && (\r\n                      partner.discount_allow_anonymous === true || customerEmail.trim() ? (\r\n                        <div className=\"text-xs text-green-600 bg-green-50 p-2 rounded-lg border border-green-200\">\r\n                          {trFormat('loyalty.instant_discount', { percent: partner.discount_percent || 0 }, `в”ңГүв”¬Гӯв”ңГүв”¬в•‘в”ңГүв”¬в••в”ңГүв”¬в”Өв”ңГүв”¬в•‘в”ңГүв”¬в–‘ ${partner.discount_percent || 0}% в”ңГүв”¬в”җв”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГүв”¬в•қв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в•Ўв”ңГүв”¬в•ңв”ңГүв”¬в–‘`)}\r\n                        </div>\r\n                      ) : (\r\n                        <div className=\"text-xs text-amber-600 bg-amber-50 p-2 rounded-lg border border-amber-200\">\r\n                          {trFormat('loyalty.enter_email_for_discount', { percent: partner.discount_percent || 0 }, `в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў email в”ңГүв”¬в”Өв”ңГүв”¬в•—в”ңГҰв”¬Г… в”ңГҰв”¬Гјв”ңГүв”¬в•‘в”ңГүв”¬в••в”ңГүв”¬в”Өв”ңГүв”¬в•‘в”ңГүв”¬в•• ${partner.discount_percent || 0}%`)}\r\n                        </div>\r\n                      )\r\n                    )}\r\n                  </div>\r\n                )}\r\n              </div>\r\n            )}\r\n\r\n            {/* Subtotal and submit */}\r\n            <div className=\"mt-4 pt-4 border-t space-y-3\">\r\n              {partner?.loyalty_enabled && earnedPoints > 0 && !loyaltyExpanded && (\r\n                <div className=\"flex justify-between text-sm text-green-600\">\r\n                  <span>{tr('loyalty.online_bonus_label', 'в”ңГүО“ГҮГҝв”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГҰО“ГҮв•Ј в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГүв”¬в•—в”ңГүв”¬в–‘в”ңГүв”¬в•Јв”ңГүв”¬в•ң-в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–')}</span>\r\n                  <span>+{Number(earnedPoints || 0).toLocaleString('ru-RU')}в”ңГүО“ГҮГҝ</span>\r\n                </div>\r\n              )}\r\n\r\n              {/* в”ңГүв•ҰВЈв”ңГүв”¬Гів”ңГүв”јв•ӣв”ңГүО“ГҮВЈв”ңГүв”јв•ӣ - bold total */}\r\n              <div className=\"flex justify-between items-end pt-2 border-t\">\r\n                <span className=\"text-sm font-semibold text-slate-700 uppercase tracking-wide\">\r\n                  {tr('cart.total', 'в”ңГүв•ҰВЈв”ңГүв”¬Гів”ңГүв”јв•ӣв”ңГүО“ГҮВЈв”ңГүв”јв•ӣ')}:\r\n                </span>\r\n                <span className=\"text-lg font-bold text-slate-900\">{formatPrice(Number(cartTotalAmount) || 0)}</span>\r\n              </div>\r\n\r\n              {/* Online order to waiter (verification + benefits) */}\r\n              <div className=\"mt-4 p-3 bg-amber-50 border border-amber-200 rounded-lg\">\r\n                <div className=\"flex items-center justify-between mb-2\">\r\n                  <p className=\"text-amber-900 font-semibold text-sm\">\r\n                    {tr('cart.verify.online_order_title', 'в”ңГүв”јв•ӣв”ңГүв”¬в•ңв”ңГүв”¬в•—в”ңГүв”¬в–‘в”ңГүв”¬в•Јв”ңГүв”¬в•ң-в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•– в”ңГүв”¬в•ӣв”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГҰО“ГҮГңв”ңГҰв•һГҶ')}\r\n                  </p>\r\n                  <button\r\n                    type=\"button\"\r\n                    className=\"text-amber-700 hover:text-amber-900 text-sm px-2\"\r\n                    onClick={() => setInfoModal('online')}\r\n                    title={tr('common.info', 'в”ңГүв•ҰВЈв”ңГүв”¬в•ңв”ңГҰО“ГҮвӮ§в”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в•қв”ңГүв”¬в–‘в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГҰв”¬Г…')}\r\n                  >\r\n                    в”ңГіО“ГҮВЈв•ҰВЈ\r\n                  </button>\r\n                </div>\r\n\r\n                {/* AC-03: Expected savings в”ңГіО“Г©ВјО“ГҮВҘ separate from total, not subtracted */}\r\n                {(discountAmount > 0 || (partner?.loyalty_enabled && earnedPoints > 0) || pointsDiscountAmount > 0) && (\r\n                  <p className=\"text-xs text-amber-700 font-medium mb-1\">\r\n                    {tr('cart.expected_savings', 'в”ңГүв”јв•ӣв”ңГүв”¬в•ўв”ңГүв”¬в••в”ңГүв”¬в”Өв”ңГүв”¬в–‘в”ңГүв”¬в•Ўв”ңГүв”¬в•қв”ңГүв”¬в–‘в”ңГҰв”¬Г… в”ңГүв”¬в–“в”ңГҰО“ГҮв•Јв”ңГүв”¬в”Ӯв”ңГүв”¬в•ӣв”ңГүв”¬в”Өв”ңГүв”¬в–‘')}:\r\n                  </p>\r\n                )}\r\n                {discountAmount > 0 && (\r\n                  <div className=\"flex justify-between text-sm text-amber-900\">\r\n                    <span>{tr('cart.verify.discount_label', 'в”ңГүв”¬Гӯв”ңГүв”¬в•‘в”ңГүв”¬в••в”ңГүв”¬в”Өв”ңГүв”¬в•‘в”ңГүв”¬в–‘ в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГүв”¬в•—в”ңГүв”¬в–‘в”ңГүв”¬в•Јв”ңГүв”¬в•ң-в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–')}</span>\r\n                    <span>в”ңГів•ҰГҘО“ГҮГ–{formatPrice(discountAmount)}</span>\r\n                  </div>\r\n                )}\r\n\r\n                {partner?.loyalty_enabled && earnedPoints > 0 && (\r\n                  <div className=\"flex justify-between text-sm text-amber-900\">\r\n                    <span>{tr('cart.verify.bonus_label', 'в”ңГүО“ГҮГҝв”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГҰв•һГҶв”ңГҰв”¬Гјв”ңГҰО“ГҮв•Ј в”ңГүв”¬в•–в”ңГүв”¬в–‘ в”ңГүв”¬в•ӣв”ңГүв”¬в•ңв”ңГүв”¬в•—в”ңГүв”¬в–‘в”ңГүв”¬в•Јв”ңГүв”¬в•ң-в”ңГүв”¬в•–в”ңГүв”¬в–‘в”ңГүв”¬в•‘в”ңГүв”¬в–‘в”ңГүв”¬в•–')}</span>\r\n                    <span>+{Number(earnedPoints || 0).toLocaleString('ru-RU')}в”ңГүО“ГҮГҝ</span>\r\n                  </div>\r\n                )}\r\n\r\n                {/* Redeem points (if user applied) */}\r\n                {pointsDiscountAmount > 0 && (\r\n                  <div className=\"flex justify-between text-sm text-amber-900\">\r\n                    <span>{tr('cart.verify.points_discount_label', 'в”ңГүв”¬Гӯв”ңГүв”¬в”җв”ңГүв”¬в••в”ңГҰв”¬Гјв”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГүв”¬в••в”ңГүв”¬в•Ў в”ңГүв”¬в–’в”ңГүв”¬в–‘в”ңГүв”¬в•—в”ңГүв”¬в•—в”ңГүв”¬в•ӣв”ңГүв”¬в–“')}</span>\r\n                    <span>в”ңГів•ҰГҘО“ГҮГ–{formatPrice(pointsDiscountAmount)}</span>\r\n                  </div>\r\n                )}\r\n\r\n                <div className=\"mt-3 pt-3 border-t border-amber-200\">\r\n                  {isTableVerified === true ? (\r\n                    <div className=\"text-sm text-green-700 text-center\">\r\n                      в”ңГів”јГҙО“ГҮВӘ {tr('cart.verify.table_verified', 'в”ңГүв”¬Гӯв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•— в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в”Өв”ңГҰО“ГҮГңв”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГҰО“Г©Вјв”ңГүв”¬в•ўв”ңГүв”¬в”Өв”ңГҰО“ГҮГҝв”ңГүв”¬в•ң')}\r\n                    </div>\r\n                  ) : (\r\n                    <>\r\n                      <div className=\"flex items-center justify-between mb-2\">\r\n                        <p className=\"text-amber-900 font-medium text-sm\">\r\n                          {tr('cart.verify.enter_table_code', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в”Ө в”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГүв”¬в–‘')}\r\n                        </p>\r\n                        <button\r\n                          type=\"button\"\r\n                          className=\"text-amber-700 hover:text-amber-900 text-sm px-2\"\r\n                          onClick={() => setInfoModal('tableCode')}\r\n                          title={tr('common.info', 'в”ңГүв•ҰВЈв”ңГүв”¬в•ңв”ңГҰО“ГҮвӮ§в”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в•қв”ңГүв”¬в–‘в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГҰв”¬Г…')}\r\n                        >\r\n                          в”ңГіО“ГҮВЈв•ҰВЈ\r\n                        </button>\r\n                      </div>\r\n\r\n                      {/* Slots UI + invisible input (auto-verify when fully entered) */}\r\n                      <div className=\"space-y-2\">\r\n                        <div className=\"flex items-center justify-center gap-3\">\r\n                          <div className={`relative ${isCodeLocked ? 'opacity-60' : ''}`}>\r\n                            <div\r\n                              className=\"flex items-center gap-2\"\r\n                              onClick={() => !isCodeLocked && codeInputRef.current && codeInputRef.current.focus()}\r\n                            >\r\n                              <div className=\"flex gap-2\">\r\n                                {Array.from({ length: tableCodeLength }).map((_, idx) => {\r\n                                  const safe = String(tableCodeInput || '').replace(/\\D/g, '').slice(0, tableCodeLength);\r\n                                  const ch = safe[idx] || '_';\r\n                                  return (\r\n                                    <div\r\n                                      key={idx}\r\n                                      className=\"w-9 h-11 rounded-lg border border-amber-200 bg-white flex items-center justify-center text-xl font-mono text-amber-900\"\r\n                                    >\r\n                                      {ch}\r\n                                    </div>\r\n                                  );\r\n                                })}\r\n                              </div>\r\n                              {isVerifyingCode && (\r\n                                <Loader2 className=\"w-4 h-4 animate-spin text-amber-700\" />\r\n                              )}\r\n                            </div>\r\n\r\n                            <Input\r\n                              ref={codeInputRef}\r\n                              type=\"text\"\r\n                              inputMode=\"numeric\"\r\n                              maxLength={tableCodeLength}\r\n                              value={String(tableCodeInput || '').replace(/\\D/g, '').slice(0, tableCodeLength)}\r\n                              disabled={isCodeLocked}\r\n                              onChange={(e) => {\r\n                                const next = String(e.target.value || '').replace(/\\D/g, '').slice(0, tableCodeLength);\r\n                                if (typeof setTableCodeInput === 'function') setTableCodeInput(next);\r\n                              }}\r\n                              className=\"absolute inset-0 opacity-0 cursor-text\"\r\n                              aria-label={tr('cart.verify.enter_table_code', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в”Ө в”ңГҰв”¬Гјв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•—в”ңГүв”¬в–‘')}\r\n                              placeholder={tr('cart.verify.enter_code_placeholder', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в”Ө')}\r\n                            />\r\n                          </div>\r\n                        </div>\r\n\r\n                        {!String(tableCodeInput || '').trim() && (\r\n                          <div className=\"text-center text-xs text-amber-700\">\r\n                            {tr('cart.verify.enter_code_placeholder', 'в”ңГүО“ГҮГ–в”ңГүв”¬в–“в”ңГүв”¬в•Ўв”ңГүв”¬в”Өв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в”Ө')}\r\n                          </div>\r\n                        )}\r\n\r\n                        {isCodeLocked ? (\r\n                          <div className=\"text-center text-xs text-amber-800\">\r\n                            в”ңГів”¬Г…в”¬в”Ӯ {tr('cart.verify.locked', 'в”ңГүв”¬Гӯв”ңГүв”¬в•—в”ңГүв”¬в••в”ңГҰв•ҰГҘв”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в•қ в”ңГүв”¬в•қв”ңГүв”¬в•ңв”ңГүв”¬в•ӣв”ңГүв”¬в”Ӯв”ңГүв”¬в•ӣ в”ңГүв”¬в”җв”ңГүв”¬в•ӣв”ңГүв”¬в”җв”ңГҰО“ГҮв•Јв”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГүв”¬в•‘. в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГҰО“Г©Вјв”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў в”ңГҰО“ГҮГӯв”ңГүв”¬в•Ўв”ңГҰО“Г©Вјв”ңГүв”¬в•Ўв”ңГүв”¬в•–')}{' '}\r\n                            {String(Math.floor(codeSecondsLeft / 60)).padStart(2, '0')}:{String(codeSecondsLeft % 60).padStart(2, '0')}\r\n                          </div>\r\n                        ) : (\r\n                          <>\r\n                            {codeVerificationError && !isVerifyingCode && (\r\n                              <div className=\"text-center text-xs text-red-700\">\r\n                                {codeVerificationError}\r\n                                {maxCodeAttempts > 0 && (\r\n                                  <div className=\"mt-1 text-red-600\">\r\n                                    {tr('cart.verify.attempts', 'в”ңГүв”јв••в”ңГүв”¬в•ӣв”ңГүв”¬в”җв”ңГҰО“ГҮв•Јв”ңГҰО“ГҮГңв”ңГүв”¬в•‘в”ңГүв”¬в••')}: {Math.min(codeAttempts, maxCodeAttempts)} {tr('common.of', 'в”ңГүв”¬в••в”ңГүв”¬в•–')} {maxCodeAttempts}\r\n                                  </div>\r\n                                )}\r\n                              </div>\r\n                            )}\r\n                          </>\r\n                        )}\r\n\r\n                        {/* Option 2: Tell code to waiter (same effect) */}\r\n                        {hallGuestCodeEnabled && effectiveGuestCode && (\r\n                          <div className=\"mt-3 pt-3 border-t border-amber-200 text-center\">\r\n                            <div className=\"flex items-center justify-center gap-2 text-xs text-amber-600 mb-2\">\r\n                              <span className=\"flex-1 border-t border-amber-300\"></span>\r\n                              <span>{tr('common.or', 'в”ңГүв”¬в••в”ңГүв”¬в•—в”ңГүв”¬в••')}</span>\r\n                              <span className=\"flex-1 border-t border-amber-300\"></span>\r\n                            </div>\r\n                            <p className=\"text-xs text-amber-800 mb-1\">\r\n                              {tr('cart.tell_code_to_waiter', 'в”ңГүв”¬ВҘв”ңГүв”¬в–‘в”ңГүв”¬в•–в”ңГүв”¬в•ӣв”ңГүв”¬в–“в”ңГүв”¬в••в”ңГҰО“ГҮГңв”ңГүв”¬в•Ў в”ңГүв”¬в•ӣв”ңГҰО“ГҮвӮ§в”ңГүв”¬в••в”ңГҰО“ГҮГЎв”ңГүв”¬в••в”ңГүв”¬в–‘в”ңГүв”¬в•ңв”ңГҰО“ГҮГңв”ңГҰв•һГҶ в”ңГҰв”¬Г¬в”ңГҰО“ГҮГңв”ңГүв”¬в•ӣв”ңГҰО“ГҮГң в”ңГүв”¬в•‘в”ңГүв”¬в•ӣв”ңГүв”¬в”Ө')}:\r\n                            </p>\r\n                            <p className=\"text-2xl font-bold text-amber-900 font-mono\">\r\n                              {String(effectiveGuestCode)}\r\n                            </p>\r\n                          </div>\r\n                        )}\r\n                      </div>\r\n                    </>\r\n                  )}\r\n                </div>\r\n              </div>\r\n\r\n              {/* Info modal */}\r\n              {infoModal && (\r\n                <div\r\n                  className=\"fixed inset-0 z-50 flex items-center justi