895: grep -n "openSessionByTableId = useMemo" "menuapp-code-review/pages/StaffOrdersMobile/staffordersmobile.jsx"
896: # Ожидание: 1 hit, строка ~3554. Вставить useEffect сразу после `}, [openSessions]);` этого useMemo.
