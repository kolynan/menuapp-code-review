 188: // ============================================================
 189: // FUNCTION 9: isSessionExpired
 190: // Checks if session timeout has passed
 191: // ============================================================
 192: export function isSessionExpired(session, hoursTimeout = 8) {
 193:   if (!session) return true;
 194:   if (session.status === "closed") return true;
 195: 
 196:   const openedAt = new Date(session.opened_at);
 197:   const now = new Date();
 198:   const hoursDiff = (now - openedAt) / (1000 * 60 * 60);
 199: 
 200:   return hoursDiff > hoursTimeout;
 201: }
