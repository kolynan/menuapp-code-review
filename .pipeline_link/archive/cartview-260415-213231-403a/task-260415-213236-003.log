  25: // ============================================================
  26: // FUNCTION 2: getNextOrderNumber
  27: // Generates next order number (ZAL-001, SV-002, DOS-003)
  28: // Resets counter on new business day
  29: // ============================================================
  30: export function getNextOrderNumber(partner, channel) {
  31:   const now = new Date();
  32:   const businessDayStart = partner.business_day_start || "06:00";
  33:   const currentBusinessDate = getBusinessDate(now, businessDayStart);
