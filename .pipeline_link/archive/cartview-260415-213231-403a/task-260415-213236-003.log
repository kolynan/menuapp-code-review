  37:   // Reset counters if new business day
  38:   if (updated.order_counter_date !== currentBusinessDate) {
  39:     updated.order_counter_hall = 0;
  40:     updated.order_counter_pickup = 0;
  41:     updated.order_counter_delivery = 0;
  42:     updated.order_counter_date = currentBusinessDate;
  43:   }
  44: 
  45:   // Increment counter for channel
  46:   const counterKey = `order_counter_${channel}`;
  47:   updated[counterKey] = (updated[counterKey] || 0) + 1;
  48: 
  49:   // Generate order number
  50:   const prefixes = { hall: "Ð—ÐÐ›", pickup: "Ð¡Ð’", delivery: "Ð”ÐžÐ¡" };
  51:   const prefix = prefixes[channel] || "ORD";
  52:   const number = String(updated[counterKey]).padStart(3, "0");
  53: 
  54:   return {
  55:     orderNumber: `${prefix}-${number}`,
  56:     updatedCounters: {
  57:       order_counter_hall: updated.order_counter_hall,
  58:       order_counter_pickup: updated.order_counter_pickup,
  59:       order_counter_delivery: updated.order_counter_delivery,
  60:       order_counter_date: updated.order_counter_date,
  61:     }
  62:   };
  63: }
