# Commands executed during review

[timeout] Get-ChildItem -Name
[timeout] Get-Content README.md
[timeout] Get-Content BUGS.md
[timeout] Get-Content MenuView.jsx
[timeout] Get-Content x.jsx
[timeout] Get-ChildItem | Select-Object Name,Length
Get-Content README.md -Raw
Get-Content BUGS.md -Raw
[timeout] Select-String -Path MenuView.jsx -Pattern 'Math\.round\(dish\.price|line-clamp-1|w-9 h-9|renderListCard|renderTileCard' -Context 4,6
[timeout] Select-String -Path x.jsx -Pattern 'Math\.round\(detailDish\.price|DishRating|showReviews|dishRatings\[detailDish\.id\]|import Rating' -Context 4,8
$lines = Get-Content MenuView.jsx; for ($i=90; $i -le 185; $i++) { if ($i -lt $lines.Length) { '{0,5}: {1}' -f ($i+1), $lines[$i] } }
$lines = Get-Content MenuView.jsx; for ($i=268; $i -le 288; $i++) { if ($i -lt $lines.Length) { '{0,5}: {1}' -f ($i+1), $lines[$i] } }
$lines = Get-Content x.jsx; for ($i=90; $i -le 102; $i++) { if ($i -lt $lines.Length) { '{0,5}: {1}' -f ($i+1), $lines[$i] } }
$lines = Get-Content x.jsx; for ($i=3888; $i -le 3922; $i++) { if ($i -lt $lines.Length) { '{0,5}: {1}' -f ($i+1), $lines[$i] } }
Select-String -Path MenuView.jsx -Pattern 'Math\.round\(dish\.price|line-clamp-1|w-9 h-9'
Select-String -Path x.jsx -Pattern 'Math\.round\(detailDish\.price|DishRating|showReviews && dishRatings\?\.\[detailDish\.id\]'
