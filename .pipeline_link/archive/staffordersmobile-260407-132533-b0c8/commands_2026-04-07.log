git fetch origin 2>$null; git reset --hard origin/main
Get-ChildItem -Force
Get-Content README.md
Get-Content BUGS.md
Get-Content 'StaffOrdersMobile README.md'
(Get-Content 'staffordersmobile.jsx' | Measure-Object -Line).Lines
Select-String -Path 'staffordersmobile.jsx' -Pattern 'group\.type === "table" \?'
Select-String -Path 'staffordersmobile.jsx' -Pattern 'rounded-xl border border-slate-200 bg-white/80 p-3 space-y-2'
Get-Content 'staffordersmobile.jsx' | Select-Object -Skip 1750 -First 220
Get-Content 'staffordersmobile.jsx' | Select-Object -Skip 2080 -First 340
Select-String -Path 'staffordersmobile.jsx' -Pattern 'ownerHintTimerRef|renderHallSummaryItem|handleSingleAction|setUndoToast\(|closeDisabledReasons\.map|const isLastOfOrder|rows\.map\(\(row, idx\) => \{|overdueMinutes' -Context 3,8
Get-Content 'staffordersmobile.jsx' | Select-Object -Skip 2032 -First 70
Select-String -Path 'staffordersmobile.jsx' -Pattern 'scrollToSection|rowId|reasonToKind|urgencyClass|stopPropagation|handleSingleAction\('
(Select-String -Path 'staffordersmobile.jsx' -Pattern 'scrollToSection').Count; (Select-String -Path 'staffordersmobile.jsx' -Pattern 'rowId').Count; (Select-String -Path 'staffordersmobile.jsx' -Pattern 'reasonToKind').Count; (Select-String -Path 'staffordersmobile.jsx' -Pattern 'urgencyClass').Count; (Select-String -Path 'staffordersmobile.jsx' -Pattern 'rounded-xl border border-slate-200 bg-white/80 p-3 space-y-2').Count
Select-String -Path 'staffordersmobile.jsx' -Pattern 'handleSingleAction\(' -Context 0,1
Get-ChildItem -Force 'pipeline/chain-state'
