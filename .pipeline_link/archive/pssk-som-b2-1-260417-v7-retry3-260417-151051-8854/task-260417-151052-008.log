900: ```js
901:   const handleBannerNavigate = useCallback((maybeTableIdOrCompositeKey) => {
902:     if (!maybeTableIdOrCompositeKey) return;
903: 
904:     // Б2.1: если передан tableId без sessionId (current flow: banner.groupId = tableId) —
