 543:     // where B44 sets internal_code === 'cancel' (stage-based cancel, not raw-status-only cancel).
 544:     // isCancelledOrder covers BOTH cases ГўвҖ вҖҷ consistent with Fix 1/4 aggregates.
 545:     // ГўЕ“вҖҰ TDZ-safe (v13): isCancelledOrder declared in Fix 1 Part A at line ~455 ГўвӮ¬вҖқ ABOVE statusBuckets
 546:     // at line 456. After Fix 1 Part A applied, const isCancelledOrder is in scope here.
 547:     const isCancelled = isCancelledOrder(o);
 548:     // Fix 2 (R1): pending_unconfirmed = 'submitted' status (awaiting waiter confirmation).
 549:     // Priority: server-side stageInfo wins; only raw status === 'submitted' AND no stage info ГўвҖ вҖҷ pending.
 550:     const isPending = !stageInfo?.internal_code && rawStatus === 'submitted';
 551: 
 552:     if (isServed) groups.served.push(o);
 553:     else if (isPending) groups.pending_unconfirmed.push(o);
 554:     else if (!isCancelled) groups.in_progress.push(o);
 555:   });
 556:   return groups;
 557: }, [todayMyOrders, getOrderStatus]);
 558: ```
