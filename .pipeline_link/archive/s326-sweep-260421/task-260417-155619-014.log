  const filteredGroups = useMemo(() => {
    if (!orderGroups) return [];

    return orderGroups.filter(group => {
      if (group.type === 'table') {
        // Ð‘2.1: group belongs to Â«ÐÐºÑ‚Ð¸Ð²Ð½Ñ‹ÐµÂ» ONLY if its sessionId matches the current open session
