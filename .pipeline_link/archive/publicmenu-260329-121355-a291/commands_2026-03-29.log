[timeout] Get-ChildItem -Name pages/PublicMenu
[timeout] Get-Content pages/PublicMenu/README.md
[timeout] Get-Content pages/PublicMenu/BUGS.md
Get-ChildItem pages/PublicMenu | Select-Object -ExpandProperty Name
Get-Content pages/PublicMenu/README.md -TotalCount 250
Get-Content pages/PublicMenu/BUGS.md -TotalCount 250
Select-String -Path pages/PublicMenu/x.jsx -Pattern 'hallStickyBillTotal|OrderConfirmationScreen|confirmation\.your_order|confirmation\.guest_label|<StickyCartBar|showBillAmount|formattedBillTotal' -Context 6,10
Select-String -Path pages/PublicMenu/CartView.jsx -Pattern 'new_order|renderBucketOrders|Отправить официанту|submit' -Context 6,12
Select-String -Path pages/PublicMenu/MenuView.jsx -Pattern 'renderListCard|line-clamp-' -Context 4,6
Get-Content pages/PublicMenu/StickyCartBar.jsx
[timeout] $i=1; Get-Content pages/PublicMenu/x.jsx | ForEach-Object { if($i -ge 697 -and $i -le 741){ '{0}:{1}' -f $i, $_ }; $i++ }
[timeout] $i=1; Get-Content pages/PublicMenu/x.jsx | ForEach-Object { if($i -ge 2281 -and $i -le 2288){ '{0}:{1}' -f $i, $_ }; $i++ }
[timeout] $i=1; Get-Content pages/PublicMenu/MenuView.jsx | ForEach-Object { if($i -ge 90 -and $i -le 98){ '{0}:{1}' -f $i, $_ }; $i++ }
[timeout] $i=1; Get-Content pages/PublicMenu/StickyCartBar.jsx | ForEach-Object { '{0}:{1}' -f $i, $_; $i++ }
Get-Content pages/PublicMenu/x.jsx -TotalCount 741 | Select-Object -Last 45
Get-Content pages/PublicMenu/x.jsx -TotalCount 2288 | Select-Object -Last 10
Get-Content pages/PublicMenu/MenuView.jsx -TotalCount 98 | Select-Object -Last 12
Get-Content pages/PublicMenu/StickyCartBar.jsx -TotalCount 200
Get-Content pages/PublicMenu/CartView.jsx -TotalCount 1016 | Select-Object -Last 25
Get-Content pages/PublicMenu/CartView.jsx -TotalCount 1047 | Select-Object -Last 35
Select-String -Path pages/PublicMenu/StickyCartBar.jsx -Pattern 'fixed bottom-0|Button|onButtonClick|cartTotalItems|formattedCartTotal|formattedBillTotal|hallModeLabel|showBillAmount|buttonLabel' -Context 0,2
Select-String -Path pages/PublicMenu/CartView.jsx -Pattern 'Spacer so sticky footer|h-20|SECTION 2: NEW ORDER|Card className=\"mb-2\"|sticky bottom-0' -Context 1,2
